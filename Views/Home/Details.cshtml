@model ClothingStore.Models.ViewModels.ProductDetailViewModel
@using System.Text.Json
@{
    ViewData["Title"] = Model.ProductName;
    Layout = "~/Views/Shared/_StoreLayout.cshtml";

    var variantData = Model.Variants.Select(v => new
    {
        variantId   = v.VariantID,
        colorName   = v.ColorName,
        hexCode     = v.HexCode,
        sizeCode    = v.SizeCode,
        price       = v.EffectivePrice,
        origPrice   = v.SellingPrice,
        hasDiscount = v.HasDiscount,
        stock       = v.StockQuantity,
        images      = v.ImageUrls
    });
    var variantJson = JsonSerializer.Serialize(variantData);

    var distinctColors = Model.Variants
        .GroupBy(v => v.ColorName)
        .Select(g => g.First())
        .ToList();

    var allImages = Model.ImageUrls;
    var mainImage = allImages.FirstOrDefault();
}

<style>
    .detail-main-img {
        position: relative; width: 100%;
        padding-bottom: 125%; /* 4:5 */
        overflow: hidden; background-color: #f0eded;
    }
    .detail-main-img img, .detail-main-img .placeholder {
        position: absolute; top:0; left:0; width:100%; height:100%;
    }
    .detail-main-img img { object-fit: cover; transition: opacity .3s ease, transform .5s ease; }
    .detail-main-img img.fade { opacity: 0; }
    .placeholder { display:flex; flex-direction:column; align-items:center;
        justify-content:center; gap:10px; color:#b0a59f; }

    .thumb {
        position:relative; padding-bottom:100%; overflow:hidden;
        background:#f0eded; cursor:pointer;
        border: 2px solid transparent; transition: border-color .2s;
    }
    .thumb img { position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover; }
    .thumb.active { border-color: #553722; }
    .thumb:hover:not(.active) { border-color: #a88c7d; }

    .color-dot { transition: transform .15s, border-color .15s; }
    .color-dot.active { border-color: #553722 !important; transform: scale(1.2); }

    .sz-btn {
        min-width: 48px; padding: 6px 12px;
        border: 1px solid #d1c4bd; font-size: 15px; font-weight: 500;
        transition: background .2s, border-color .2s, color .2s; cursor:pointer;
        background: white; color: #553722;
    }
    .sz-btn.active { background: #553722; color: white; border-color: #553722; }
    .sz-btn:hover:not(.active):not(:disabled) { border-color: #553722; }
    .sz-btn:disabled { opacity:.38; cursor:not-allowed; }
</style>

<div class="max-w-5xl mx-auto px-4 md:px-8 py-8">

    <!-- Breadcrumb -->
    <nav class="text-[10px] uppercase tracking-widest text-gray-400 mb-6 font-medium">
        <a href="@Url.Action("Index","Home")" class="hover:text-[#553722]">Trang chủ</a>
        <span class="mx-2">/</span>
        <a href="@Url.Action("ShopAll","Home")" class="hover:text-[#553722]">Tất cả sản phẩm</a>
        <span class="mx-2">/</span>
        <span class="text-[#553722]">@Model.ProductName</span>
    </nav>

    <!-- Product Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">

        <!-- ═══ Left: Gallery ═══ -->
        <div>
            <!-- Main Image -->
            <div class="detail-main-img mb-3">
                @if (!string.IsNullOrWhiteSpace(mainImage))
                {
                    <img id="main-img" src="@mainImage" alt="@Model.ProductName" />
                }
                else
                {
                    <div class="placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 opacity-25" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M6 4h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2zm8 4a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                        <p class="text-sm font-medium">Chưa có hình ảnh</p>
                    </div>
                }
            </div>

            <!-- Thumbnails -->
            @if (allImages.Count > 1)
            {
                <div class="grid grid-cols-5 gap-2" id="thumb-grid">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        <div class="thumb @(i == 0 ? "active" : "")"
                             data-src="@allImages[i]"
                             onclick="switchImg(this)">
                            <img src="@allImages[i]" alt="Thumb @(i+1)" loading="lazy" />
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ═══ Right: Info ═══ -->
        <div class="flex flex-col">
            <!-- Category + Name -->
            <div class="text-xs uppercase tracking-widest text-gray-400 mb-1">@Model.CategoryName</div>
            <h1 class="font-['Playfair_Display'] text-3xl md:text-4xl text-[#553722] leading-snug mb-4">
                @Model.ProductName
            </h1>

            <!-- Price -->
            <div class="mb-6 flex items-baseline gap-3">
                @if (Model.HasDiscount)
                {
                    <span class="line-through text-gray-400 text-lg" id="orig-price">
                        @Model.Variants.Max(v => v.SellingPrice).ToString("N0")đ
                    </span>
                }
                <span id="eff-price" class="text-3xl font-semibold text-[#553722]">
                    @Model.MinEffectivePrice.ToString("N0")đ
                </span>
            </div>

            <!-- Description -->
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="text-gray-600 text-lg leading-relaxed mb-6 italic font-['Playfair_Display']">
                    @Model.Description
                </p>
            }

            <!-- Form -->
            <form asp-controller="Cart" asp-action="Add" method="post" class="flex flex-col gap-5">
                @Html.AntiForgeryToken()
                <input type="hidden" name="VariantID" id="sel-variant" value="@(Model.Variants.FirstOrDefault(v => v.StockQuantity > 0)?.VariantID)" />

                @if (!Model.Variants.Any())
                {
                    <p class="text-red-500 text-sm italic">Không có biến thể nào đang hoạt động.</p>
                }
                else
                {
                    <!-- Color -->
                    @if (distinctColors.Count > 0)
                    {
                        <div>
                            <p class="text-sm uppercase tracking-widest text-[#553722] font-semibold mb-3">
                                Màu sắc: <span id="color-label" class="font-normal normal-case text-gray-500 ml-1">@distinctColors.First().ColorName</span>
                            </p>
                            <div class="flex flex-wrap gap-2" id="color-swatches">
                                @for (int i = 0; i < distinctColors.Count; i++)
                                {
                                    var c = distinctColors[i];
                                    <button type="button"
                                            class="color-dot w-7 h-7 rounded-full border-2 p-[2px] focus:outline-none @(i == 0 ? "active border-[#553722]" : "border-gray-200")"
                                            data-color="@c.ColorName" title="@c.ColorName"
                                            onclick="selectColor(this)">
                                        <span class="block w-full h-full rounded-full border border-gray-100" style="background-color:@c.HexCode"></span>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <!-- Size -->
                    <div>
                        <p class="text-sm uppercase tracking-widest text-[#553722] font-semibold mb-3">
                            Kích thước: <span id="size-label" class="font-normal normal-case text-gray-500 ml-1"></span>
                        </p>
                        <div class="flex flex-wrap gap-2" id="size-btns">
                            @{
                                var firstColor = distinctColors.FirstOrDefault()?.ColorName;
                                var sizesForFirst = Model.Variants
                                    .Where(v => v.ColorName == firstColor)
                                    .OrderBy(v => v.SizeCode).ToList();
                                var firstAvail = sizesForFirst.FirstOrDefault(v => v.StockQuantity > 0);
                            }
                            @foreach (var v in sizesForFirst)
                            {
                                <button type="button" class="sz-btn @(v == firstAvail ? "active" : "")"
                                        data-vid="@v.VariantID" data-size="@v.SizeCode"
                                        data-avail="@v.StockQuantity"
                                        @(v.StockQuantity == 0 ? "disabled" : "")
                                        onclick="selectSize(this)">
                                    @v.SizeCode
                                </button>
                            }
                        </div>
                        <p id="stock-info" class="text-sm text-green-600 mt-2 min-h-[20px]">
                            @if (firstAvail != null) { @($"Còn {firstAvail.StockQuantity} sản phẩm") }
                        </p>
                    </div>

                    <!-- Qty + Add to Cart -->
                    <div class="flex gap-3 items-stretch">
                        <div class="flex items-center border border-gray-300 rounded" style="height:44px">
                            <button type="button" onclick="chQty(-1)"
                                    class="px-3 text-gray-500 hover:text-[#553722] text-lg select-none">−</button>
                            <input id="qty" name="Quantity" type="number" min="1" value="1"
                                   class="w-10 text-center border-0 focus:ring-0 text-sm p-0" />
                            <button type="button" onclick="chQty(1)"
                                    class="px-3 text-gray-500 hover:text-[#553722] text-lg select-none">+</button>
                        </div>
                        <button type="submit" id="add-to-cart-btn"
                                class="flex-grow bg-[#553722] text-white text-[11px] uppercase tracking-widest font-semibold hover:bg-[#3d2716] transition-colors rounded flex items-center justify-center gap-2 disabled:bg-gray-400 disabled:cursor-not-allowed"
                                style="height:44px">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                            </svg>
                            <span id="add-to-cart-text">Thêm vào giỏ hàng</span>
                        </button>
                    </div>
                }
            </form>

            <!-- Shipping note -->
            <div class="flex items-center gap-2 text-xs text-gray-400 mt-5 pt-5 border-t border-gray-100">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2l1-12"/>
                </svg>
                Miễn phí vận chuyển cho đơn từ 500.000đ
            </div>

            <!-- Specs -->
            <div class="mt-5 border-t border-gray-100 text-base divide-y divide-gray-100">
                @if (!string.IsNullOrWhiteSpace(Model.Material))
                {
                    <div class="flex justify-between py-2.5">
                        <span class="text-xs uppercase tracking-widest text-gray-400">Chất liệu</span>
                        <span class="text-[#553722] font-medium text-base">@Model.Material</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.FitType))
                {
                    <div class="flex justify-between py-2.5">
                        <span class="text-xs uppercase tracking-widest text-gray-400">Dáng</span>
                        <span class="text-[#553722] font-medium text-base">@Model.FitType</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Gender))
                {
                    <div class="flex justify-between py-2.5">
                        <span class="text-xs uppercase tracking-widest text-gray-400">Giới tính</span>
                        <span class="text-[#553722] font-medium text-base">@Model.Gender</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.CareInstructions))
                {
                    <div class="flex justify-between py-2.5">
                        <span class="text-xs uppercase tracking-widest text-gray-400">Bảo quản</span>
                        <span class="text-[#553722] font-medium text-base text-right max-w-[60%]">@Model.CareInstructions</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Customer Reviews -->
    <section class="mt-[80px] pt-12 border-t border-gray-100" id="reviews-section">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
            <div>
                <h2 class="font-['Playfair_Display'] text-[28px] font-medium text-[#553722] mb-2">Đánh giá sản phẩm</h2>
                <div class="flex items-center gap-3">
                    <div class="flex text-yellow-400 text-lg">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Round(Model.ReviewStats.AverageRating))
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                            }
                        }
                    </div>
                    <span class="text-sm text-gray-500 font-medium">@Model.ReviewStats.AverageRating.ToString("0.0") / 5</span>
                    <span class="text-sm text-gray-400">(@Model.ReviewStats.TotalReviews đánh giá)</span>
                </div>
            </div>
            
            @if (User.Identity?.IsAuthenticated == true)
            {
                if (Model.CanReview)
                {
                    <button type="button" onclick="openReviewModal()" class="px-6 py-2.5 bg-white border border-[#553722] text-[#553722] text-sm font-semibold uppercase tracking-widest hover:bg-[#553722] hover:text-white transition-colors rounded">
                        Viết đánh giá
                    </button>
                }
            }
            else
            {
                <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString)" class="px-6 py-2.5 bg-white border border-[#553722] text-[#553722] text-sm font-semibold uppercase tracking-widest hover:bg-[#553722] hover:text-white transition-colors rounded">
                    Đăng nhập để đánh giá
                </a>
            }
        </div>

        @if (Model.ReviewStats.TotalReviews > 0)
        {
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10 bg-[#fcfaf9] p-6 rounded-lg border border-[#f0eded]">
                <!-- Rating Breakdown -->
                <div class="col-span-1 border-r border-gray-200 pr-0 md:pr-8">
                    <div class="space-y-2">
                        @foreach (var star in new[] { 5, 4, 3, 2, 1 })
                        {
                            var count = star switch { 5 => Model.ReviewStats.Star5Count, 4 => Model.ReviewStats.Star4Count, 3 => Model.ReviewStats.Star3Count, 2 => Model.ReviewStats.Star2Count, _ => Model.ReviewStats.Star1Count };
                            var pct = Model.ReviewStats.TotalReviews > 0 ? (count * 100) / Model.ReviewStats.TotalReviews : 0;
                            <div class="flex items-center text-sm">
                                <span class="w-10 text-gray-600 font-medium">@star Sao</span>
                                <div class="flex-grow mx-3 h-2 bg-gray-200 rounded-full overflow-hidden">
                                    <div class="h-full bg-yellow-400 rounded-full" style="width: @pct%"></div>
                                </div>
                                <span class="w-8 text-right text-gray-500">@count</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Filters -->
                <div class="col-span-1 md:col-span-2 flex flex-col justify-center">
                    <div class="mb-4">
                        <span class="text-xs font-semibold uppercase tracking-widest text-gray-400 block mb-2">Lọc theo số sao</span>
                        <div class="flex flex-wrap gap-2" id="rating-filters">
                            <button type="button" aria-pressed="true" data-val="" class="filter-btn active px-4 py-1.5 text-sm border rounded transition-colors bg-[#553722] text-white border-[#553722]">Tất cả</button>
                            <button type="button" aria-pressed="false" data-val="5" class="filter-btn px-4 py-1.5 text-sm border rounded transition-colors bg-white text-gray-600 hover:bg-gray-50 border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#553722] focus:ring-offset-1">5 Sao</button>
                            <button type="button" aria-pressed="false" data-val="4" class="filter-btn px-4 py-1.5 text-sm border rounded transition-colors bg-white text-gray-600 hover:bg-gray-50 border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#553722] focus:ring-offset-1">4 Sao</button>
                            <button type="button" aria-pressed="false" data-val="3" class="filter-btn px-4 py-1.5 text-sm border rounded transition-colors bg-white text-gray-600 hover:bg-gray-50 border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#553722] focus:ring-offset-1">3 Sao</button>
                            <button type="button" aria-pressed="false" data-val="2" class="filter-btn px-4 py-1.5 text-sm border rounded transition-colors bg-white text-gray-600 hover:bg-gray-50 border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#553722] focus:ring-offset-1">2 Sao</button>
                            <button type="button" aria-pressed="false" data-val="1" class="filter-btn px-4 py-1.5 text-sm border rounded transition-colors bg-white text-gray-600 hover:bg-gray-50 border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#553722] focus:ring-offset-1">1 Sao</button>
                        </div>
                    </div>
                    <div>
                        <span class="text-xs font-semibold uppercase tracking-widest text-gray-400 block mb-2">Cảm xúc</span>
                        <div class="flex flex-wrap gap-2" id="sentiment-filters">
                            <button type="button" aria-pressed="false" data-val="positive" class="sentiment-btn px-4 py-1.5 text-sm border rounded transition-colors bg-white text-gray-600 hover:bg-gray-50 border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#553722] focus:ring-offset-1">Tích cực (@Model.ReviewStats.PositivePercent%)</button>
                            <button type="button" aria-pressed="false" data-val="neutral" class="sentiment-btn px-4 py-1.5 text-sm border rounded transition-colors bg-white text-gray-600 hover:bg-gray-50 border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#553722] focus:ring-offset-1">Trung tính (@Model.ReviewStats.NeutralPercent%)</button>
                            <button type="button" aria-pressed="false" data-val="negative" class="sentiment-btn px-4 py-1.5 text-sm border rounded transition-colors bg-white text-gray-600 hover:bg-gray-50 border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#553722] focus:ring-offset-1">Tiêu cực (@Model.ReviewStats.NegativePercent%)</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sorting -->
            <div class="flex justify-end mb-6">
                <select id="review-sort" class="text-sm border-gray-300 rounded focus:ring-[#553722] focus:border-[#553722]" onchange="changeSort()">
                    <option value="newest">Mới nhất</option>
                    <option value="mosthelpful">Hữu ích nhất</option>
                    <option value="oldest">Cũ nhất</option>
                    <option value="highest">Điểm cao nhất</option>
                    <option value="lowest">Điểm thấp nhất</option>
                </select>
            </div>

            <!-- Review Container -->
            <div id="reviews-container" class="min-h-[200px] relative">
                <!-- Loader -->
                <div id="reviews-loader" class="absolute inset-0 bg-white/80 flex items-center justify-center z-10 hidden">
                    <svg class="animate-spin h-8 w-8 text-[#553722]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
                <div id="reviews-content"></div>
            </div>
        }
        else
        {
            <div class="text-center py-12 bg-[#fcfaf9] rounded-lg border border-[#f0eded]">
                <p class="text-gray-500 text-sm">Sản phẩm này chưa có đánh giá nào.</p>
            </div>
        }
    </section>

    <!-- Related Products with Filters -->
    @if (Model.RelatedProducts.Any() || Model.BestSellingProducts.Any() || Model.InStockProducts.Any())
    {
        <section class="mt-[120px] pt-12">
            <h2 class="font-['Playfair_Display'] text-[28px] font-medium text-[#553722] text-center mb-6">Gợi ý phối đồ</h2>
            <!-- Filter Tabs -->
            <div class="flex justify-center mb-12">
                <div class="flex space-x-8 border-b border-gray-200">
                    <button type="button" class="pb-2 text-[13px] uppercase tracking-wider font-semibold border-b-2 border-[#553722] text-[#553722] transition-colors filter-tab" onclick="switchTab('all', this)">Sản phẩm liên quan</button>
                    <button type="button" class="pb-2 text-[13px] uppercase tracking-wider font-semibold border-b-2 border-transparent text-gray-400 hover:text-[#553722] transition-colors filter-tab" onclick="switchTab('bestseller', this)">Bán chạy</button>
                    <button type="button" class="pb-2 text-[13px] uppercase tracking-wider font-semibold border-b-2 border-transparent text-gray-400 hover:text-[#553722] transition-colors filter-tab" onclick="switchTab('instock', this)">Còn hàng</button>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 tab-content" id="tab-all">
                @if (Model.RelatedProducts.Any())
                {
                    @foreach (var p in Model.RelatedProducts)
                    {
                        <partial name="_ProductCard" model="p" />
                    }
                }
                else
                {
                    <div class="col-span-full text-center text-gray-500 py-8">Chưa có sản phẩm liên quan.</div>
                }
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 tab-content hidden" id="tab-bestseller">
                @if (Model.BestSellingProducts.Any())
                {
                    @foreach (var p in Model.BestSellingProducts)
                    {
                        <partial name="_ProductCard" model="p" />
                    }
                }
                else
                {
                    <div class="col-span-full text-center text-gray-500 py-8">Chưa có sản phẩm bán chạy.</div>
                }
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 tab-content hidden" id="tab-instock">
                @if (Model.InStockProducts.Any())
                {
                    @foreach (var p in Model.InStockProducts)
                    {
                        <partial name="_ProductCard" model="p" />
                    }
                }
                else
                {
                    <div class="col-span-full text-center text-gray-500 py-8">Chưa có sản phẩm nào.</div>
                }
            </div>
        </section>
    }
</div>

<!-- Modal Review -->
<div id="review-modal" class="fixed inset-0 z-50 hidden bg-black/60 flex items-center justify-center backdrop-blur-sm transition-opacity duration-300 opacity-0">
    <div class="bg-white w-full max-w-lg rounded-xl shadow-2xl p-6 md:p-8 relative transform scale-95 transition-transform duration-300">
        <button onclick="closeReviewModal()" type="button" class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-full p-2 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        
        <h3 class="font-['Playfair_Display'] text-2xl font-semibold text-[#553722] mb-1">Viết đánh giá</h3>
        <p class="text-xs text-gray-500 mb-6 pb-4 border-b border-gray-100">Chia sẻ cảm nhận của bạn về sản phẩm này</p>

        <form asp-controller="Reviews" asp-action="Create" method="post" enctype="multipart/form-data" id="review-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ProductID" value="@Model.ProductID" />
            <input type="hidden" name="Rating" id="rating-input" value="5" />

            <div class="mb-5 flex flex-col items-center">
                <p class="text-sm font-medium text-gray-700 mb-2">Chất lượng sản phẩm</p>
                <div class="flex gap-1 text-3xl cursor-pointer" id="star-rating">
                    <span class="star text-yellow-400" data-val="1">★</span>
                    <span class="star text-yellow-400" data-val="2">★</span>
                    <span class="star text-yellow-400" data-val="3">★</span>
                    <span class="star text-yellow-400" data-val="4">★</span>
                    <span class="star text-yellow-400" data-val="5">★</span>
                </div>
                <p class="text-xs text-yellow-600 mt-2 font-medium" id="rating-text">Tuyệt vời</p>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-medium text-gray-700 mb-2">Nội dung đánh giá <span class="text-red-500">*</span></label>
                <textarea name="Comment" required minlength="10" maxlength="1000" rows="4" class="w-full border-gray-300 rounded-lg shadow-sm focus:border-[#553722] focus:ring-[#553722] text-sm" placeholder="Sản phẩm mặc có thoải mái không? Form dáng thế nào? (Tối thiểu 10 ký tự)"></textarea>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Thêm hình ảnh (Tối đa 3 ảnh, mỗi ảnh < 2MB)</label>
                <div class="flex items-center gap-3">
                    <label class="cursor-pointer bg-gray-50 border border-gray-200 border-dashed rounded-lg p-4 text-center hover:bg-gray-100 transition-colors w-full">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mx-auto text-gray-400 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M6 4h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2zm8 4a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        <span class="text-xs font-medium text-[#553722]">Bấm để chọn ảnh</span>
                        <input type="file" name="Images" id="review-images" multiple accept="image/jpeg,image/png,image/webp" class="hidden" onchange="previewImages(this)">
                    </label>
                </div>
                <div id="image-preview" class="flex gap-2 mt-3 empty:hidden"></div>
            </div>

            <button type="submit" class="w-full py-3 px-4 bg-[#553722] text-white text-sm uppercase tracking-widest font-semibold rounded-lg shadow hover:bg-[#3d2716] transition-colors">
                Gửi đánh giá
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
const variants = @Html.Raw(variantJson);
let selColor = variants.find(v => v.stock > 0)?.colorName ?? variants[0]?.colorName;

function switchImg(el) {
    const img = document.getElementById('main-img');
    if (!img) return;
    img.classList.add('fade');
    setTimeout(() => { img.src = el.dataset.src; img.classList.remove('fade'); }, 200);
    document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
}

function rebuildThumbs(images) {
    const grid = document.getElementById('thumb-grid');
    if (!grid || !images?.length) return;
    grid.innerHTML = images.map((src, i) =>
        `<div class="thumb${i===0?' active':''}" data-src="${src}" onclick="switchImg(this)">
            <img src="${src}" alt="Thumb ${i+1}" loading="lazy"/>
         </div>`
    ).join('');
    const img = document.getElementById('main-img');
    if (img) { img.classList.add('fade'); setTimeout(() => { img.src = images[0]; img.classList.remove('fade'); }, 200); }
}

function selectColor(btn) {
    selColor = btn.dataset.color;
    document.getElementById('color-label').textContent = selColor;
    document.querySelectorAll('.color-dot').forEach(b => { b.classList.remove('active','border-[#553722]'); b.classList.add('border-gray-200'); });
    btn.classList.add('active','border-[#553722]'); btn.classList.remove('border-gray-200');
    const cv = variants.filter(v => v.colorName === selColor);
    rebuildSizes(cv);
    const imgs = cv.flatMap(v => v.images).filter(Boolean);
    if (imgs.length) rebuildThumbs(imgs);
}

function rebuildSizes(cv) {
    const c = document.getElementById('size-btns'); if (!c) return;
    c.innerHTML = '';
    const first = cv.find(v => v.stock > 0);
    cv.forEach(v => {
        const b = document.createElement('button');
        b.type='button'; b.dataset.vid=v.variantId; b.dataset.size=v.sizeCode; b.dataset.avail=v.stock;
        b.className='sz-btn'+(v===first?' active':''); b.disabled=v.stock===0;
        b.textContent=v.sizeCode; b.onclick=()=>selectSize(b);
        c.appendChild(b);
    });
    if (first) selectSize(c.querySelector('.active'));
    else { 
        document.getElementById('sel-variant').value=''; 
        document.getElementById('size-label').textContent=''; 
        document.getElementById('stock-info').textContent='Hết hàng'; 
        const btnCart = document.getElementById('add-to-cart-btn');
        const txtCart = document.getElementById('add-to-cart-text');
        if (btnCart) { btnCart.disabled = true; btnCart.classList.add('bg-gray-400','cursor-not-allowed'); btnCart.classList.remove('bg-[#553722]','hover:bg-[#3d2716]'); }
        if (txtCart) txtCart.textContent = 'Hết hàng';
    }
}

function selectSize(btn) {
    if (!btn || btn.disabled) return;
    document.querySelectorAll('.sz-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('sel-variant').value = btn.dataset.vid;
    document.getElementById('size-label').textContent = btn.dataset.size;
    const v = variants.find(x => String(x.variantId)===String(btn.dataset.vid));
    if (v) {
        document.getElementById('eff-price').textContent = new Intl.NumberFormat('vi-VN').format(v.price)+'đ';
        const op = document.getElementById('orig-price');
        if (op) { op.style.display = v.hasDiscount?'inline':'none'; op.textContent = new Intl.NumberFormat('vi-VN').format(v.origPrice)+'đ'; }
        
        const btnCart = document.getElementById('add-to-cart-btn');
        const txtCart = document.getElementById('add-to-cart-text');
        if (v.stock > 0) {
            document.getElementById('stock-info').textContent = `Còn ${v.stock} sản phẩm`;
            document.getElementById('stock-info').className = 'text-sm mt-2 min-h-[20px] text-green-600';
            if (btnCart) { btnCart.disabled = false; btnCart.classList.remove('bg-gray-400','cursor-not-allowed'); btnCart.classList.add('bg-[#553722]','hover:bg-[#3d2716]'); }
            if (txtCart) txtCart.textContent = 'Thêm vào giỏ hàng';
        } else {
            document.getElementById('stock-info').textContent = 'Hết hàng';
            document.getElementById('stock-info').className = 'text-sm mt-2 min-h-[20px] text-red-500 font-medium';
            if (btnCart) { btnCart.disabled = true; btnCart.classList.add('bg-gray-400','cursor-not-allowed'); btnCart.classList.remove('bg-[#553722]','hover:bg-[#3d2716]'); }
            if (txtCart) txtCart.textContent = 'Hết hàng';
        }
    }
}

function chQty(d) {
    const i=document.getElementById('qty');
    i.value=Math.max(1, parseInt(i.value||1)+d);
}

document.addEventListener('DOMContentLoaded', () => {
    const first = document.querySelector('.sz-btn.active');
    if (first) selectSize(first);
    else if (variants.length === 0 || !variants.some(v => v.stock > 0)) {
        // Entire product is out of stock
        const btnCart = document.getElementById('add-to-cart-btn');
        const txtCart = document.getElementById('add-to-cart-text');
        document.getElementById('stock-info').textContent = 'Hết hàng';
        document.getElementById('stock-info').className = 'text-sm mt-2 min-h-[20px] text-red-500 font-medium';
        if (btnCart) { btnCart.disabled = true; btnCart.classList.add('bg-gray-400','cursor-not-allowed'); btnCart.classList.remove('bg-[#553722]','hover:bg-[#3d2716]'); }
        if (txtCart) txtCart.textContent = 'Hết hàng';
    }
});

function switchTab(filterType, btn) {
    // Update active tab styling
    document.querySelectorAll('.filter-tab').forEach(b => {
        b.classList.remove('border-[#553722]', 'text-[#553722]');
        b.classList.add('border-transparent', 'text-gray-400');
    });
    btn.classList.remove('border-transparent', 'text-gray-400');
    btn.classList.add('border-[#553722]', 'text-[#553722]');

    // Hide all tab contents
    document.querySelectorAll('.tab-content').forEach(el => {
        el.classList.add('hidden');
    });

    // Show the selected tab content
    document.getElementById('tab-' + filterType).classList.remove('hidden');
}

// Modal Review logic
const modal = document.getElementById('review-modal');
function openReviewModal() {
    modal.classList.remove('hidden');
    // slight delay to trigger transition
    setTimeout(() => {
        modal.classList.remove('opacity-0');
        modal.firstElementChild.classList.remove('scale-95');
    }, 10);
}
function closeReviewModal() {
    modal.classList.add('opacity-0');
    modal.firstElementChild.classList.add('scale-95');
    setTimeout(() => {
        modal.classList.add('hidden');
    }, 300);
}

// Star Rating logic
const stars = document.querySelectorAll('.star');
const ratingInput = document.getElementById('rating-input');
const ratingText = document.getElementById('rating-text');
const texts = ["Rất tệ", "Tệ", "Bình thường", "Tốt", "Tuyệt vời"];

stars.forEach((star, index) => {
    star.addEventListener('click', () => {
        const val = index + 1;
        ratingInput.value = val;
        ratingText.textContent = texts[val - 1];
        stars.forEach((s, i) => {
            if (i < val) {
                s.classList.add('text-yellow-400');
                s.classList.remove('text-gray-300');
            } else {
                s.classList.remove('text-yellow-400');
                s.classList.add('text-gray-300');
            }
        });
    });
});

// Image Preview & Validation logic
function previewImages(input) {
    const preview = document.getElementById('image-preview');
    preview.innerHTML = '';
    if (input.files && input.files.length > 0) {
        if (input.files.length > 3) {
            alert('Bạn chỉ được tải lên tối đa 3 ảnh.');
            input.value = '';
            return;
        }
        
        for (let i = 0; i < input.files.length; i++) {
            const file = input.files[i];
            if (file.size > 2 * 1024 * 1024) {
                alert(`Ảnh "${file.name}" vượt quá dung lượng 2MB.`);
                input.value = '';
                preview.innerHTML = '';
                return;
            }
            
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.className = 'w-16 h-16 object-cover rounded border border-gray-200';
                preview.appendChild(img);
            }
            reader.readAsDataURL(file);
        }
    }
}

// ---------------------------------------------------------
// Review Filtering, Sorting & Pagination with AJAX
// ---------------------------------------------------------
let reviewState = {
    productId: @Model.ProductID,
    rating: '',
    sentiment: '',
    sort: 'newest',
    page: 1
};
let abortController = null;

function fetchReviews() {
    const container = document.getElementById('reviews-content');
    const loader = document.getElementById('reviews-loader');
    if (!container || !loader) return;

    // Abort previous request if pending
    if (abortController) {
        abortController.abort();
    }
    abortController = new AbortController();
    const signal = abortController.signal;

    loader.classList.remove('hidden');
    container.style.opacity = '0.5';

    const params = new URLSearchParams({
        productId: reviewState.productId,
        page: reviewState.page,
        sort: reviewState.sort
    });
    if (reviewState.rating) params.append('rating', reviewState.rating);
    if (reviewState.sentiment) params.append('sentiment', reviewState.sentiment);

    // Update URL without reloading (Deep Linking)
    const newUrl = new URL(window.location);
    newUrl.searchParams.set('page', reviewState.page);
    newUrl.searchParams.set('sort', reviewState.sort);
    if (reviewState.rating) newUrl.searchParams.set('rating', reviewState.rating);
    else newUrl.searchParams.delete('rating');
    if (reviewState.sentiment) newUrl.searchParams.set('sentiment', reviewState.sentiment);
    else newUrl.searchParams.delete('sentiment');
    window.history.replaceState({}, '', newUrl);

    fetch(`/Reviews/ProductReviews?${params.toString()}`, { signal })
        .then(res => res.text())
        .then(html => {
            container.innerHTML = html;
            container.style.opacity = '1';
            loader.classList.add('hidden');
        })
        .catch(err => {
            if (err.name !== 'AbortError') {
                console.error('Error fetching reviews:', err);
                loader.classList.add('hidden');
                container.style.opacity = '1';
            }
        });
}

function loadReviews(page) {
    reviewState.page = page;
    fetchReviews();
    document.getElementById('reviews-section').scrollIntoView({ behavior: 'smooth' });
}

function changeSort() {
    const sel = document.getElementById('review-sort');
    reviewState.sort = sel.value;
    reviewState.page = 1; // Reset to page 1 on sort change
    fetchReviews();
}

document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        // Reset sentiment when filtering by rating
        document.querySelectorAll('.sentiment-btn').forEach(b => {
            b.classList.remove('bg-[#553722]', 'text-white', 'border-[#553722]');
            b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
            b.setAttribute('aria-pressed', 'false');
        });
        reviewState.sentiment = '';

        // Handle rating filter
        document.querySelectorAll('.filter-btn').forEach(b => {
            b.classList.remove('bg-[#553722]', 'text-white', 'border-[#553722]');
            b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
            b.setAttribute('aria-pressed', 'false');
        });
        this.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
        this.classList.add('bg-[#553722]', 'text-white', 'border-[#553722]');
        this.setAttribute('aria-pressed', 'true');

        reviewState.rating = this.dataset.val;
        reviewState.page = 1;
        fetchReviews();
    });
});

document.querySelectorAll('.sentiment-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        // Reset rating when filtering by sentiment
        document.querySelectorAll('.filter-btn').forEach(b => {
            b.classList.remove('bg-[#553722]', 'text-white', 'border-[#553722]');
            b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
            b.setAttribute('aria-pressed', 'false');
        });
        reviewState.rating = '';

        // Handle sentiment filter
        document.querySelectorAll('.sentiment-btn').forEach(b => {
            b.classList.remove('bg-[#553722]', 'text-white', 'border-[#553722]');
            b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
            b.setAttribute('aria-pressed', 'false');
        });
        this.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
        this.classList.add('bg-[#553722]', 'text-white', 'border-[#553722]');
        this.setAttribute('aria-pressed', 'true');

        reviewState.sentiment = this.dataset.val;
        reviewState.page = 1;
        fetchReviews();
    });
});

// Sync UI buttons with state
function syncUIWithState() {
    document.getElementById('review-sort').value = reviewState.sort;

    document.querySelectorAll('.filter-btn').forEach(btn => {
        if (btn.dataset.val === reviewState.rating) {
            btn.classList.add('bg-[#553722]', 'text-white', 'border-[#553722]');
            btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
            btn.setAttribute('aria-pressed', 'true');
        } else {
            btn.classList.remove('bg-[#553722]', 'text-white', 'border-[#553722]');
            btn.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
            btn.setAttribute('aria-pressed', 'false');
        }
    });

    document.querySelectorAll('.sentiment-btn').forEach(btn => {
        if (btn.dataset.val === reviewState.sentiment) {
            btn.classList.add('bg-[#553722]', 'text-white', 'border-[#553722]');
            btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
            btn.setAttribute('aria-pressed', 'true');
        } else {
            btn.classList.remove('bg-[#553722]', 'text-white', 'border-[#553722]');
            btn.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
            btn.setAttribute('aria-pressed', 'false');
        }
    });
}

// Initial load
document.addEventListener('DOMContentLoaded', () => {
    if (document.getElementById('reviews-container')) {
        // Read URL params for Deep Linking
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('page')) reviewState.page = parseInt(urlParams.get('page')) || 1;
        if (urlParams.has('sort')) reviewState.sort = urlParams.get('sort');
        if (urlParams.has('rating')) reviewState.rating = urlParams.get('rating');
        if (urlParams.has('sentiment')) reviewState.sentiment = urlParams.get('sentiment');

        syncUIWithState();
        fetchReviews();
    }
});

function toggleHelpful(reviewId, btn) {
    if (btn.disabled) return;

    const form = document.getElementById('review-form');
    const token = form ? form.querySelector('input[name="__RequestVerificationToken"]')?.value : null;
    if (!token) {
        alert("Có lỗi xảy ra, vui lòng tải lại trang.");
        return;
    }

    btn.disabled = true;
    const originalText = btn.innerHTML;

    const formData = new FormData();
    formData.append("reviewId", reviewId);
    formData.append("__RequestVerificationToken", token);

    fetch('/Reviews/ToggleHelpfulVote', {
        method: 'POST',
        body: formData
    })
    .then(res => {
        if (res.status === 401) {
            window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search);
            throw new Error('Unauthorized');
        }
        return res.json();
    })
    .then(data => {
        if (data.success) {
            btn.setAttribute('aria-pressed', data.isVoted);
            if (data.isVoted) {
                btn.classList.remove('bg-white', 'text-gray-500', 'border-gray-200', 'hover:bg-gray-50');
                btn.classList.add('bg-green-50', 'text-green-700', 'border-green-200');
            } else {
                btn.classList.add('bg-white', 'text-gray-500', 'border-gray-200', 'hover:bg-gray-50');
                btn.classList.remove('bg-green-50', 'text-green-700', 'border-green-200');
            }
            btn.querySelector('.helpful-count').textContent = data.helpfulCount;
        } else {
            alert(data.message);
        }
    })
    .catch(err => {
        if (err.message !== 'Unauthorized') {
            console.error(err);
        }
    })
    .finally(() => {
        btn.disabled = false;
    });
}
</script>
}
