<!-- BEGIN: BestSellersSection -->
@if (Model.BestSellers.Any())
{
    <section class="container mx-auto px-4 py-12">
        <div class="flex justify-between items-end mb-8">
            <h2 class="text-4xl font-serif text-brand-dark-brown">Best Sellers</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">
            @foreach (var product in Model.BestSellers)
            {
                @await Html.PartialAsync("_ProductCard", product)
            }
        </div>
    </section>
}
<!-- END: BestSellersSection -->

<!-- BEGIN: ProductSection -->
<section id="product-section" class="container mx-auto px-4 py-16">
    <div class="flex justify-between items-end mb-12">
        <h2 class="text-4xl font-serif text-brand-dark-brown">WearWhatever</h2>
        
        <!-- Filter Form (Minimal version) -->
        <form method="get" class="flex gap-4">
            <select name="categoryId" onchange="this.form.submit()" class="border-gray-300 rounded text-sm text-gray-700 bg-white">
                <option value="">All Categories</option>
                @foreach (var cat in Model.ShopProducts.Categories)
                {
                    <option value="@cat.CategoryID" selected="@(cat.CategoryID == Model.ShopProducts.CategoryID)">@cat.CategoryName</option>
                }
            </select>
            <select name="sortBy" onchange="this.form.submit()" asp-for="ShopProducts.SortBy" asp-items="Model.ShopProducts.SortOptions" class="border-gray-300 rounded text-sm text-gray-700 bg-white">
                <option value="">Sort By</option>
            </select>
        </form>
    </div>

    @if (!Model.ShopProducts.Products.Any())
    {
        <div class="text-center py-20 text-gray-500">
            <p class="text-xl">No products found.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">
            @foreach (var product in Model.ShopProducts.Products)
            {
                @await Html.PartialAsync("_ProductCard", product)
            }
        </div>

        <!-- Pagination -->
        @if (Model.ShopProducts.TotalPages > 1)
        {
            <div class="flex justify-center mt-12 gap-2">
                @for (int i = 1; i <= Model.ShopProducts.TotalPages; i++)
                {
                    <a href="?page=@i&categoryId=@Model.ShopProducts.CategoryID&search=@Model.ShopProducts.Search&sortBy=@Model.ShopProducts.SortBy" 
                       class="w-10 h-10 flex items-center justify-center border border-gray-200 @(i == Model.ShopProducts.Page ? "bg-brand-dark-brown text-white" : "bg-white text-gray-700 hover:bg-gray-50") transition-colors">
                        @i
                    </a>
                }
            </div>
        }
    }
</section>
<!-- END: ProductSection -->

<!-- BEGIN: NewsletterBanner -->
<section class="bg-brand-brown py-12 px-4">
    <div class="container mx-auto flex justify-center">
        <div class="bg-brand-lavender max-w-2xl w-full p-10 relative rounded shadow-sm">
            <div class="text-center">
                <h2 class="text-3xl font-serif text-brand-dark-brown mb-2">Sign up and save</h2>
                <p class="text-gray-600 mb-8 text-sm">Enter your email to sign up to newsletter and update!</p>
                <form class="flex flex-col sm:flex-row gap-0 justify-center">
                    <input class="w-full sm:w-80 border-none px-4 py-3 bg-white/80 focus:ring-0 focus:outline-none text-sm" placeholder="Email" required type="email" />
                    <button class="bg-brand-dark-brown text-white px-8 py-3 uppercase text-xs font-bold tracking-widest hover:bg-black transition-colors" type="submit">
                        Subscribe
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
<!-- END: NewsletterBanner -->
