@model ClothingStore.Models.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Shop All";
    Layout = "~/Views/Shared/_StoreLayout.cshtml";
}

<!-- BEGIN: Hero Section -->
<section class="py-12 border-b border-gray-100">
    <div class="max-w-7xl mx-auto text-center">
        <h2 class="font-serif text-5xl mb-4">Sản phẩm</h2>
    </div>
</section>
<!-- END: Hero Section -->

<!-- BEGIN: MainContent -->
<main class="max-w-7xl mx-auto px-8 py-12 flex">
    <!-- BEGIN: Sidebar Filters -->
    <aside class="w-56 shrink-0 mr-12 text-base">
        <form method="get" id="filter-form">
            <!-- Search Preservation -->
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <input type="hidden" name="search" value="@Model.Search" />
            }
            
            <div class="mb-8" data-purpose="filter-category">
                <h3 class="font-bold mb-3 uppercase tracking-wider text-sm">Danh mục</h3>
                <ul class="space-y-2 text-brandGray">
                    <li>
                        <label class="flex items-center space-x-2 cursor-pointer hover:text-black transition-colors">
                            <input type="radio" name="categoryId" value="" onchange="this.form.submit()" class="form-radio text-black border-gray-300 focus:ring-black h-3 w-3" @(!Model.CategoryID.HasValue ? "checked" : "") />
                            <span>Tất cả</span>
                        </label>
                    </li>
                    @foreach (var cat in Model.Categories)
                    {
                        <li>
                            <label class="flex items-center space-x-2 cursor-pointer hover:text-black transition-colors">
                                <input type="radio" name="categoryId" value="@cat.CategoryID" onchange="this.form.submit()" class="form-radio text-black border-gray-300 focus:ring-black h-3 w-3" @(Model.CategoryID == cat.CategoryID ? "checked" : "") />
                                <span>@cat.CategoryName</span>
                            </label>
                        </li>
                    }
                </ul>
            </div>

            <div class="mb-8" data-purpose="filter-size">
                <h3 class="font-bold mb-3 uppercase tracking-wider text-sm">Kích cỡ</h3>
                <ul class="space-y-2 text-brandGray">
                    <li>
                        <label class="flex items-center space-x-2 cursor-pointer hover:text-black transition-colors">
                            <input type="radio" name="sizeId" value="" onchange="this.form.submit()" class="form-radio text-black border-gray-300 focus:ring-black h-3 w-3" @(!Model.SizeId.HasValue ? "checked" : "") />
                            <span>Tất cả</span>
                        </label>
                    </li>
                    @foreach (var size in Model.Sizes)
                    {
                        <li>
                            <label class="flex items-center space-x-2 cursor-pointer hover:text-black transition-colors">
                                <input type="radio" name="sizeId" value="@size.SizeID" onchange="this.form.submit()" class="form-radio text-black border-gray-300 focus:ring-black h-3 w-3" @(Model.SizeId == size.SizeID ? "checked" : "") />
                                <span>@size.SizeCode</span>
                            </label>
                        </li>
                    }
                </ul>
            </div>

            <div class="mb-8" data-purpose="filter-color">
                <h3 class="font-bold mb-3 uppercase tracking-wider text-sm">Màu sắc</h3>
                <ul class="space-y-3">
                    <li>
                        <label class="flex items-center space-x-2 cursor-pointer text-brandGray hover:text-black transition-colors">
                            <input type="radio" name="colorId" value="" onchange="this.form.submit()" class="form-radio text-black border-gray-300 focus:ring-black h-3 w-3" @(!Model.ColorId.HasValue ? "checked" : "") />
                            <span>Tất cả</span>
                        </label>
                    </li>
                    @foreach (var color in Model.Colors)
                    {
                        <li>
                            <label class="flex items-center space-x-2 cursor-pointer text-brandGray hover:text-black transition-colors">
                                <input type="radio" name="colorId" value="@color.ColorID" onchange="this.form.submit()" class="form-radio text-black border-gray-300 focus:ring-black h-3 w-3" @(Model.ColorId == color.ColorID ? "checked" : "") />
                                <span class="w-4 h-4 rounded-full border border-gray-200" style="background-color: @color.HexCode"></span>
                                <span>@color.ColorName</span>
                            </label>
                        </li>
                    }
                </ul>
            </div>
            
            <div class="mb-8" data-purpose="filter-sort">
                <h3 class="font-bold mb-3 uppercase tracking-wider text-sm">Sắp xếp</h3>
                <select name="sortBy" onchange="this.form.submit()" asp-for="SortBy" asp-items="Model.SortOptions" class="w-full border-gray-300 rounded text-sm text-gray-700 bg-white py-2 px-3 focus:ring-black">
                    <option value="">Mặc định</option>
                </select>
            </div>
            
            <div class="pt-4 border-t border-gray-100">
                <a href="@Url.Action("ShopAll", "Home")" class="inline-flex items-center justify-center w-full px-4 py-2 text-sm font-medium text-white bg-black hover:bg-gray-800 transition-colors">
                    Đặt lại lọc
                </a>
            </div>
        </form>
    </aside>
    <!-- END: Sidebar Filters -->

    <!-- BEGIN: ProductGrid -->
    <div class="flex-grow">
        @if (!Model.Products.Any())
        {
            <div class="text-center py-20 text-gray-500">
                <p class="text-xl">Không tìm thấy sản phẩm nào phù hợp với bộ lọc.</p>
                <a href="@Url.Action("ShopAll", "Home")" class="inline-block mt-4 text-black underline">Xóa bộ lọc</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12" id="product-grid">
                @foreach (var product in Model.Products)
                {
                    @await Html.PartialAsync("_ProductCard", product)
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="mt-12 flex justify-center space-x-2 text-[13px]">
                    @if (Model.Page > 1)
                    {
                        <a href="@Url.Action("ShopAll", "Home", new { page = Model.Page - 1, categoryId = Model.CategoryID, sizeId = Model.SizeId, colorId = Model.ColorId, search = Model.Search, sortBy = Model.SortBy })" class="px-3 py-1 border border-gray-300 text-gray-600 hover:border-black hover:text-black">Trước</a>
                    }
                    
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a href="@Url.Action("ShopAll", "Home", new { page = i, categoryId = Model.CategoryID, sizeId = Model.SizeId, colorId = Model.ColorId, search = Model.Search, sortBy = Model.SortBy })" 
                           class="px-3 py-1 border @(i == Model.Page ? "border-black bg-black text-white" : "border-gray-300 text-gray-600 hover:border-black hover:text-black")">
                            @i
                        </a>
                    }

                    @if (Model.Page < Model.TotalPages)
                    {
                        <a href="@Url.Action("ShopAll", "Home", new { page = Model.Page + 1, categoryId = Model.CategoryID, sizeId = Model.SizeId, colorId = Model.ColorId, search = Model.Search, sortBy = Model.SortBy })" class="px-3 py-1 border border-gray-300 text-gray-600 hover:border-black hover:text-black">Tiếp</a>
                    }
                </div>
            }
        }
    </div>
    <!-- END: ProductGrid -->
</main>
<!-- END: MainContent -->
