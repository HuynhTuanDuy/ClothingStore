@model OrderSuccessViewModel
@{
    ViewData["Title"] = "Order Placed";
}

<div class="success-panel mx-auto">
    <h1 class="h3">Order placed</h1>
    <p class="text-muted">Your COD order has been saved successfully.</p>
    <dl class="row mb-4">
        <dt class="col-5">Order code</dt>
        <dd class="col-7 fw-semibold">@Model.OrderCode</dd>
        <dt class="col-5">Amount</dt>
        <dd class="col-7">@Model.FinalAmount.ToString("C")</dd>
        <dt class="col-5">Payment</dt>
        <dd class="col-7">@Model.PaymentMethod</dd>
        <dt class="col-5">Status</dt>
        <dd class="col-7">@Model.OrderStatus</dd>
    </dl>
    <a class="btn btn-dark" asp-controller="Home" asp-action="Index">Back to shop</a>
</div>
