@model OrderSuccessViewModel
@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "_StoreLayout";
}

<div class="max-w-xl mx-auto px-4 py-16 text-center">
    <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-[40px]">check_circle</span>
    </div>
    
    <h1 class="text-3xl font-bold font-serif text-gray-900 mb-2">Cảm ơn bạn đã đặt hàng!</h1>
    <p class="text-gray-500 mb-8">Đơn hàng của bạn đã được hệ thống ghi nhận thành công.</p>
    
    <div class="bg-gray-50 rounded-xl p-6 mb-8 text-left text-sm space-y-3">
        <div class="flex justify-between border-b border-gray-200 pb-3">
            <span class="text-gray-500">Mã đơn hàng:</span>
            <span class="font-bold text-gray-900 text-lg">@Model.OrderCode</span>
        </div>
        <div class="flex justify-between">
            <span class="text-gray-500">Tổng tiền:</span>
            <span class="font-medium text-gray-900">@Model.FinalAmount.ToString("N0")đ</span>
        </div>
        <div class="flex justify-between">
            <span class="text-gray-500">Thanh toán:</span>
            <span class="font-medium text-gray-900">@Model.PaymentMethod</span>
        </div>
        <div class="flex justify-between">
            <span class="text-gray-500">Trạng thái:</span>
            <span class="font-medium text-gray-900">@Model.OrderStatus</span>
        </div>
    </div>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="CustomerAccount" asp-action="OrderDetail" asp-route-orderCode="@Model.OrderCode" 
               class="inline-flex items-center justify-center gap-2 bg-black text-white px-8 py-3 rounded-lg font-medium hover:bg-gray-800 transition-colors">
                <span class="material-symbols-outlined text-[20px]">inventory_2</span>
                Quản lý đơn hàng
            </a>
        }
        else
        {
            <a asp-controller="OrderTracking" asp-action="Index" asp-route-code="@Model.OrderCode" asp-route-phone="@Model.ShippingPhone"
               class="inline-flex items-center justify-center gap-2 bg-black text-white px-8 py-3 rounded-lg font-medium hover:bg-gray-800 transition-colors">
                <span class="material-symbols-outlined text-[20px]">local_shipping</span>
                Tra cứu đơn hàng
            </a>
        }
        <a asp-controller="Home" asp-action="Index" 
           class="inline-flex items-center justify-center gap-2 border border-black text-black bg-white px-8 py-3 rounded-lg font-medium hover:bg-gray-50 transition-colors">
            <span class="material-symbols-outlined text-[20px]">storefront</span>
            Tiếp tục mua sắm
        </a>
    </div>
</div>
