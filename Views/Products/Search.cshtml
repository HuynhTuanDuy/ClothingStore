@model ClothingStore.Models.ViewModels.ProductSearchResultViewModel
@{
    ViewData["Title"] = "Tìm kiếm: " + Model.Keyword;
    Layout = "~/Views/Shared/_StoreLayout.cshtml";
    
    var sortOptions = new List<SelectListItem>
    {
        new SelectListItem { Value = "relevance", Text = "Độ liên quan" },
        new SelectListItem { Value = "newest", Text = "Mới nhất" },
        new SelectListItem { Value = "price_asc", Text = "Giá: Thấp đến cao" },
        new SelectListItem { Value = "price_desc", Text = "Giá: Cao đến thấp" },
        new SelectListItem { Value = "name_asc", Text = "Tên: A-Z" },
        new SelectListItem { Value = "name_desc", Text = "Tên: Z-A" }
    };
}

@section Head {
    <meta name="robots" content="noindex,follow" />
}

<!-- BEGIN: Hero Section -->
<section class="py-12 border-b border-gray-100 bg-brand-cream">
    <div class="max-w-7xl mx-auto text-center px-4">
        <h2 class="font-serif text-4xl md:text-5xl mb-4">Kết quả tìm kiếm</h2>
        <p class="text-gray-600 text-lg">Tìm thấy <span class="font-bold text-black">@Model.Products.TotalCount</span> sản phẩm cho từ khóa "<span class="font-bold text-black">@Model.Keyword</span>"</p>
    </div>
</section>
<!-- END: Hero Section -->

<!-- BEGIN: MainContent -->
<main class="max-w-7xl mx-auto px-4 md:px-8 py-12 flex flex-col md:flex-row">
    
    <!-- BEGIN: Sidebar / Sort Options -->
    <aside class="w-full md:w-56 shrink-0 md:mr-12 text-base mb-8 md:mb-0">
        <form method="get" id="search-form" asp-controller="Products" asp-action="Search">
            <input type="hidden" name="keyword" value="@Model.Keyword" />
            
            <div class="mb-8 bg-white p-6 rounded-lg shadow-sm border border-gray-100">
                <h3 class="font-bold mb-4 uppercase tracking-wider text-sm flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"></path></svg>
                    Sắp xếp theo
                </h3>
                <select name="sort" onchange="this.form.submit()" class="w-full border-gray-300 rounded-md text-sm text-gray-700 bg-white py-2.5 px-3 focus:border-brand-brown focus:ring-brand-brown transition-colors">
                    @foreach (var option in sortOptions)
                    {
                        <option value="@option.Value" selected="@(Model.Sort == option.Value)">@option.Text</option>
                    }
                </select>
            </div>
            
            <div class="pt-2">
                <a href="@Url.Action("ShopAll", "Home")" class="inline-flex items-center justify-center w-full px-4 py-2.5 text-sm font-medium text-brand-dark-brown bg-brand-cream hover:bg-brand-brown hover:text-white rounded-md transition-colors border border-brand-brown/20">
                    Xóa tìm kiếm
                </a>
            </div>
        </form>
    </aside>
    <!-- END: Sidebar / Sort Options -->

    <!-- BEGIN: ProductGrid -->
    <div class="flex-grow">
        @if (!Model.Products.Items.Any())
        {
            <div class="text-center py-20 bg-white rounded-lg border border-gray-100 shadow-sm">
                <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <h3 class="text-xl font-medium text-gray-900 mb-2">Không tìm thấy sản phẩm phù hợp.</h3>
                <p class="text-gray-500 mb-6">Hãy thử tìm kiếm với các từ khóa khác hoặc chung chung hơn.</p>
                <a href="@Url.Action("ShopAll", "Home")" class="inline-block px-6 py-2 bg-black text-white rounded-md hover:bg-gray-800 transition-colors">Xem tất cả sản phẩm</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-x-4 md:gap-x-6 gap-y-10 md:gap-y-12" id="product-grid">
                @foreach (var product in Model.Products.Items)
                {
                    @await Html.PartialAsync("_ProductCard", product)
                }
            </div>

            <!-- Pagination -->
            @if (Model.Products.TotalPages > 1)
            {
                <div class="mt-16 flex justify-center items-center space-x-1 md:space-x-2 text-[13px] font-medium">
                    @if (Model.Products.Page > 1)
                    {
                        <a href="@Url.Action("Search", "Products", new { page = Model.Products.Page - 1, keyword = Model.Keyword, sort = Model.Sort })" class="px-3 md:px-4 py-2 border border-gray-200 rounded-md text-gray-600 hover:border-brand-brown hover:text-brand-brown transition-colors">Trước</a>
                    }
                    else
                    {
                        <span class="px-3 md:px-4 py-2 border border-gray-100 rounded-md text-gray-300 cursor-not-allowed">Trước</span>
                    }
                    
                    @for (int i = 1; i <= Model.Products.TotalPages; i++)
                    {
                        // Logic to show a limited number of pages could be added here for large page counts
                        if (i == 1 || i == Model.Products.TotalPages || (i >= Model.Products.Page - 2 && i <= Model.Products.Page + 2))
                        {
                            <a href="@Url.Action("Search", "Products", new { page = i, keyword = Model.Keyword, sort = Model.Sort })" 
                               class="w-8 h-8 md:w-10 md:h-10 flex items-center justify-center rounded-md border transition-colors @(i == Model.Products.Page ? "border-brand-brown bg-brand-brown text-white" : "border-gray-200 text-gray-600 hover:border-brand-brown hover:text-brand-brown")">
                                @i
                            </a>
                        }
                        else if (i == Model.Products.Page - 3 || i == Model.Products.Page + 3)
                        {
                            <span class="px-1 text-gray-400">...</span>
                        }
                    }

                    @if (Model.Products.Page < Model.Products.TotalPages)
                    {
                        <a href="@Url.Action("Search", "Products", new { page = Model.Products.Page + 1, keyword = Model.Keyword, sort = Model.Sort })" class="px-3 md:px-4 py-2 border border-gray-200 rounded-md text-gray-600 hover:border-brand-brown hover:text-brand-brown transition-colors">Tiếp</a>
                    }
                    else
                    {
                        <span class="px-3 md:px-4 py-2 border border-gray-100 rounded-md text-gray-300 cursor-not-allowed">Tiếp</span>
                    }
                </div>
            }
        }
    </div>
    <!-- END: ProductGrid -->
</main>
<!-- END: MainContent -->
