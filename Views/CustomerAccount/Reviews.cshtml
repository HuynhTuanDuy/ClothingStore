@model List<ClothingStore.Models.ViewModels.CustomerReviewItemViewModel>

@{
    ViewData["Title"] = "Quản lý đánh giá";
    Layout = "_AccountLayout";
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-brand-dark-brown">@ViewData["Title"]</h1>
    <p class="text-gray-500 mt-1">Quản lý các nhận xét và đánh giá sản phẩm của bạn.</p>
</div>

@Html.AntiForgeryToken()

@if (!Model.Any())
{
    <div class="bg-gray-50 rounded-lg border border-dashed border-gray-300 p-8 text-center">
        <span class="material-symbols-outlined text-4xl text-gray-400 mb-3 block">rate_review</span>
        <h3 class="text-lg font-medium text-gray-900">Bạn chưa có đánh giá nào</h3>
        <p class="text-gray-500 mt-1">Hãy mua sắm và chia sẻ trải nghiệm của bạn nhé.</p>
        <a asp-controller="Home" asp-action="Index" class="mt-4 inline-block px-6 py-2.5 bg-brand-brown text-white font-medium rounded-md hover:bg-brand-dark-brown transition-colors">
            Mua sắm ngay
        </a>
    </div>
}
else
{
    <div class="space-y-6">
        @foreach (var review in Model)
        {
            <div class="bg-white rounded-lg border border-gray-200 p-6 flex flex-col md:flex-row gap-6 items-start">
                <a href="/Product/@review.ProductSlug" class="shrink-0">
                    <img src="@review.ProductImage" alt="@review.ProductName" class="w-24 h-24 object-cover rounded-md border border-gray-100" />
                </a>
                
                <div class="flex-1 w-full">
                    <div class="flex flex-wrap justify-between items-start gap-4 mb-2">
                        <div>
                            <a href="/Product/@review.ProductSlug" class="text-lg font-medium text-gray-900 hover:text-brand-brown transition-colors">@review.ProductName</a>
                            <div class="flex items-center gap-3 mt-1">
                                <div class="flex text-amber-400">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        if (i <= review.Rating)
                                        {
                                            <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 0;">star</span>
                                        }
                                    }
                                </div>
                                <span class="text-sm text-gray-500">@review.ReviewDate.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                        <button type="button" onclick="openEditReviewModal(@review.ReviewID, @review.Rating, '@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(review.Comment)')" class="px-4 py-2 text-sm font-medium text-brand-brown bg-brand-cream hover:bg-brand-brown hover:text-white rounded-md transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                            Sửa đánh giá
                        </button>
                    </div>
                    
                    <p class="text-gray-700 text-sm mt-3 leading-relaxed">
                        @review.Comment
                    </p>
                    
                    @if (review.Images.Any())
                    {
                        <div class="flex gap-2 mt-4">
                            @foreach (var img in review.Images)
                            {
                                <a href="@img" target="_blank" class="block rounded overflow-hidden border border-gray-200 hover:opacity-80 transition-opacity">
                                    <img src="@img" alt="Review Image" class="w-16 h-16 object-cover" />
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<!-- Edit Review Modal -->
<div id="editReviewModal" class="fixed inset-0 z-50 hidden bg-black/50 backdrop-blur-sm flex justify-center items-center p-4 opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-lg shadow-xl max-w-lg w-full overflow-hidden transform scale-95 transition-transform duration-300">
        <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-gray-900">Chỉnh sửa đánh giá</h3>
            <button type="button" onclick="closeEditReviewModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <div class="p-6">
            <form id="editReviewForm" class="space-y-5">
                <input type="hidden" id="editReviewId" name="ReviewID" />
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Đánh giá của bạn <span class="text-red-500">*</span></label>
                    <div class="flex text-amber-400 cursor-pointer" id="editStarRating">
                        <span class="material-symbols-outlined text-3xl hover:scale-110 transition-transform" data-rating="1">star</span>
                        <span class="material-symbols-outlined text-3xl hover:scale-110 transition-transform" data-rating="2">star</span>
                        <span class="material-symbols-outlined text-3xl hover:scale-110 transition-transform" data-rating="3">star</span>
                        <span class="material-symbols-outlined text-3xl hover:scale-110 transition-transform" data-rating="4">star</span>
                        <span class="material-symbols-outlined text-3xl hover:scale-110 transition-transform" data-rating="5">star</span>
                    </div>
                    <input type="hidden" id="editRating" name="Rating" value="5" />
                    <p class="text-xs text-red-500 mt-1 hidden" id="editRatingError">Vui lòng chọn số sao.</p>
                </div>
                
                <div>
                    <label for="editComment" class="block text-sm font-medium text-gray-700 mb-1">Nội dung <span class="text-red-500">*</span></label>
                    <textarea id="editComment" name="Comment" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-brand-brown focus:border-brand-brown" placeholder="Nhập ít nhất 10 ký tự..."></textarea>
                    <p class="text-xs text-red-500 mt-1 hidden" id="editCommentError">Nội dung đánh giá từ 10 đến 1000 ký tự.</p>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Cập nhật hình ảnh (tối đa 3 ảnh, 2MB/ảnh)</label>
                    <p class="text-xs text-gray-500 mb-2">Lưu ý: Nếu bạn tải lên ảnh mới, toàn bộ ảnh cũ sẽ bị xoá và thay thế. Nếu không tải ảnh mới, hệ thống sẽ giữ nguyên ảnh cũ.</p>
                    <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md relative hover:bg-gray-50 transition-colors">
                        <div class="space-y-1 text-center">
                            <span class="material-symbols-outlined text-3xl text-gray-400">imagesmode</span>
                            <div class="flex text-sm text-gray-600 justify-center">
                                <label for="editImages" class="relative cursor-pointer rounded-md bg-white font-medium text-brand-brown focus-within:outline-none hover:text-brand-dark-brown">
                                    <span>Tải ảnh lên</span>
                                    <input id="editImages" name="Images" type="file" class="sr-only" multiple accept="image/jpeg, image/png, image/webp">
                                </label>
                            </div>
                            <p class="text-xs text-gray-500">PNG, JPG, WEBP</p>
                        </div>
                    </div>
                    <div id="editImagePreviewContainer" class="mt-4 flex gap-2 flex-wrap"></div>
                </div>
                
                <div class="pt-4 border-t border-gray-200 flex justify-end gap-3">
                    <button type="button" onclick="closeEditReviewModal()" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition-colors font-medium">Hủy</button>
                    <button type="submit" id="btnSubmitEdit" class="px-6 py-2 bg-brand-brown text-white rounded-md hover:bg-brand-dark-brown transition-colors font-medium flex items-center gap-2">
                        <span>Lưu thay đổi</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Modal Logic
        const modal = document.getElementById('editReviewModal');
        const modalContent = modal.querySelector('div');
        const starIcons = document.querySelectorAll('#editStarRating span');
        const ratingInput = document.getElementById('editRating');
        
        function openEditReviewModal(reviewId, rating, comment) {
            document.getElementById('editReviewId').value = reviewId;
            document.getElementById('editComment').value = comment;
            document.getElementById('editImages').value = '';
            document.getElementById('editImagePreviewContainer').innerHTML = '';
            
            // Set stars
            setStars(rating);
            
            // Show modal
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            }, 10);
        }
        
        function closeEditReviewModal() {
            modal.classList.add('opacity-0');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }
        
        // Stars interactive logic
        function setStars(rating) {
            ratingInput.value = rating;
            starIcons.forEach(icon => {
                const starVal = parseInt(icon.dataset.rating);
                if (starVal <= rating) {
                    icon.style.fontVariationSettings = "'FILL' 1";
                    icon.classList.add('text-brand-brown');
                } else {
                    icon.style.fontVariationSettings = "'FILL' 0";
                    icon.classList.remove('text-brand-brown');
                }
            });
        }
        
        starIcons.forEach(icon => {
            icon.addEventListener('click', function() {
                setStars(parseInt(this.dataset.rating));
                document.getElementById('editRatingError').classList.add('hidden');
            });
        });
        
        // Image preview logic
        document.getElementById('editImages').addEventListener('change', function(e) {
            const container = document.getElementById('editImagePreviewContainer');
            container.innerHTML = '';
            
            if (this.files.length > 3) {
                Toastify({ text: "Chỉ được chọn tối đa 3 ảnh", backgroundColor: "#ef4444" }).showToast();
                this.value = '';
                return;
            }
            
            for (let i = 0; i < this.files.length; i++) {
                const file = this.files[i];
                if (file.size > 2 * 1024 * 1024) {
                    Toastify({ text: "Dung lượng ảnh vượt quá 2MB", backgroundColor: "#ef4444" }).showToast();
                    this.value = '';
                    container.innerHTML = '';
                    return;
                }
                
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'w-16 h-16 object-cover rounded-md border border-gray-200';
                    container.appendChild(img);
                }
                reader.readAsDataURL(file);
            }
        });
        
        // Form submission
        document.getElementById('editReviewForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const comment = document.getElementById('editComment').value.trim();
            const rating = parseInt(ratingInput.value);
            let hasError = false;
            
            if (!rating || rating < 1 || rating > 5) {
                document.getElementById('editRatingError').classList.remove('hidden');
                hasError = true;
            }
            
            if (comment.length < 10 || comment.length > 1000) {
                document.getElementById('editCommentError').classList.remove('hidden');
                hasError = true;
            } else {
                document.getElementById('editCommentError').classList.add('hidden');
            }
            
            if (hasError) return;
            
            const btn = document.getElementById('btnSubmitEdit');
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin">progress_activity</span> Đang xử lý...';
            
            const formData = new FormData(this);
            // Append AntiForgeryToken
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            formData.append('__RequestVerificationToken', token);
            
            try {
                const response = await fetch('@Url.Action("UpdateReview", "CustomerAccount")', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    Toastify({ text: result.message, backgroundColor: "#10b981" }).showToast();
                    closeEditReviewModal();
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    let errorMsg = result.message;
                    if (result.errors && result.errors.length > 0) {
                        errorMsg += ": " + result.errors.join(", ");
                    }
                    Toastify({ text: errorMsg, backgroundColor: "#ef4444" }).showToast();
                }
            } catch (err) {
                Toastify({ text: "Lỗi kết nối tới máy chủ.", backgroundColor: "#ef4444" }).showToast();
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<span>Lưu thay đổi</span>';
            }
        });
    </script>
}
