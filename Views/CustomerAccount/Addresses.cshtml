@model List<ClothingStore.Models.Entities.ShippingAddress>
@using ClothingStore.Models.ViewModels

@{
    ViewData["Title"] = "Sổ địa chỉ";
    Layout = "_AccountLayout";
    var emptyForm = new AddressFormViewModel();
}

<div class="mb-6 flex justify-between items-center">
    <div>
        <h1 class="text-2xl font-semibold text-brand-dark-brown">Sổ địa chỉ</h1>
        <p class="text-gray-500 mt-2">Quản lý địa chỉ giao hàng của bạn.</p>
    </div>
    <button onclick="document.getElementById('addAddressModal').classList.remove('hidden')" class="px-4 py-2 bg-brand-brown text-white text-sm font-medium rounded hover:bg-brand-dark-brown transition-colors flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Thêm địa chỉ mới
    </button>
</div>

@if (Model.Any())
{
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        @foreach (var address in Model)
        {
            <div class="bg-white border rounded-lg p-5 relative @(address.IsDefault ? "border-brand-brown shadow-sm" : "border-gray-200")">
                @if (address.IsDefault)
                {
                    <span class="absolute top-4 right-4 bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded border border-green-200">
                        Mặc định
                    </span>
                }
                
                <div class="mb-4 pr-16">
                    <h3 class="font-bold text-brand-brown text-base mb-1">
                        @(string.IsNullOrWhiteSpace(address.AddressName) ? $"📍 Địa chỉ #{address.AddressID}" : $"{(address.AddressName.Contains("Nhà", StringComparison.OrdinalIgnoreCase) ? "🏠" : address.AddressName.Contains("Công ty", StringComparison.OrdinalIgnoreCase) ? "🏢" : "📍")} {address.AddressName}")
                    </h3>
                    <h4 class="font-semibold text-gray-900">@address.RecipientName</h4>
                    <p class="text-sm text-gray-600 mt-1">@address.ReceiverPhone</p>
                    <p class="text-sm text-gray-600 mt-2">@address.AddressLine</p>
                    <p class="text-sm text-gray-600">@address.Ward, @address.District, @address.Province</p>
                </div>
                
                <div class="flex items-center gap-3 border-t border-gray-100 pt-4 mt-auto">
                    <button type="button" 
                            onclick="openEditModal(@address.AddressID, '@Html.Raw(address.AddressName?.Replace("'", "\\'"))', '@Html.Raw(address.RecipientName.Replace("'", "\\'"))', '@address.ReceiverPhone', '@Html.Raw(address.AddressLine.Replace("'", "\\'"))', '@address.WardId', '@address.DistrictId', '@address.ProvinceId', '@Html.Raw(address.Note?.Replace("'", "\\'") ?? "")', @(address.IsDefault ? "true" : "false"))"
                            class="text-sm font-medium text-blue-600 hover:text-blue-800">
                        Chỉnh sửa
                    </button>
                    
                    @if (!address.IsDefault)
                    {
                        <span class="text-gray-300">|</span>
                        <form asp-action="SetDefaultAddress" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="addressId" value="@address.AddressID" />
                            <button type="submit" class="text-sm font-medium text-brand-brown hover:text-brand-dark-brown">
                                Đặt mặc định
                            </button>
                        </form>
                    }
                    
                    <span class="text-gray-300">|</span>
                    <form asp-action="DeleteAddress" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc chắn muốn xóa địa chỉ này?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="addressId" value="@address.AddressID" />
                        <button type="submit" class="text-sm font-medium text-red-600 hover:text-red-800">
                            Xóa
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-12 bg-gray-50 rounded-lg border border-gray-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Chưa có địa chỉ nào</h3>
        <p class="text-gray-500 mb-6">Thêm địa chỉ giao hàng để thanh toán nhanh chóng hơn.</p>
    </div>
}

<!-- Modal Thêm Địa Chỉ -->
<div id="addAddressModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg max-h-[90vh] flex flex-col">
        <div class="flex justify-between items-center p-5 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900">Thêm địa chỉ mới</h3>
            <button onclick="document.getElementById('addAddressModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <div class="p-5 overflow-y-auto">
            <partial name="_AddressFormPartial" model="emptyForm" />
        </div>
    </div>
</div>

<!-- Modal Sửa Địa Chỉ -->
<div id="editAddressModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg max-h-[90vh] flex flex-col">
        <div class="flex justify-between items-center p-5 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900">Chỉnh sửa địa chỉ</h3>
            <button onclick="document.getElementById('editAddressModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <div class="p-5 overflow-y-auto" id="editFormContainer">
            <form asp-action="EditAddress" method="post" id="editForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="edit_AddressID" name="AddressID" />
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tên gợi nhớ (Tùy chọn)</label>
                        <input type="text" id="edit_AddressName" name="AddressName" placeholder="Ví dụ: Nhà riêng, Công ty..." maxlength="50" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tên người nhận</label>
                        <input type="text" id="edit_RecipientName" name="RecipientName" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
                        <input type="text" id="edit_ReceiverPhone" name="ReceiverPhone" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Số nhà, Tên đường</label>
                        <input type="text" id="edit_AddressLine" name="AddressLine" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
                    </div>
                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Tỉnh/Thành</label>
                            <select id="edit_Province" name="ProvinceId" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown addr-province" data-target="edit_District">
                                <option value="">-- Chọn --</option>
                                @if (ViewBag.Provinces != null)
                                {
                                    foreach (var p in (IEnumerable<ClothingStore.Models.Entities.Province>)ViewBag.Provinces)
                                    {
                                        <option value="@p.ProvinceId">@p.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Quận/Huyện</label>
                            <select id="edit_District" name="DistrictId" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown addr-district" data-target="edit_Ward">
                                <option value="">-- Chọn --</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Phường/Xã</label>
                            <select id="edit_Ward" name="WardId" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown addr-ward">
                                <option value="">-- Chọn --</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ghi chú (Tòa nhà, Lầu...)</label>
                        <input type="text" id="edit_Note" name="Note" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
                    </div>
                    <div class="flex items-center mt-2">
                        <input type="checkbox" id="edit_IsDefault" name="IsDefault" value="true" class="h-4 w-4 text-brand-brown border-gray-300 rounded" />
                        <label for="edit_IsDefault" class="ml-2 block text-sm text-gray-900">Đặt làm địa chỉ mặc định</label>
                    </div>
                </div>
                <div class="mt-6 flex gap-3 justify-end">
                    <button type="button" onclick="document.getElementById('editAddressModal').classList.add('hidden')" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50">Hủy</button>
                    <button type="submit" class="px-4 py-2 bg-brand-brown text-white rounded-md hover:bg-brand-dark-brown">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Cấu hình AJAX Address
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.addr-province').forEach(el => {
                el.addEventListener('change', async function() {
                    const provinceId = this.value;
                    const targetId = this.getAttribute('data-target');
                    if (!targetId) return;
                    const districtSelect = document.getElementById(targetId);
                    const wardSelect = document.getElementById(districtSelect.getAttribute('data-target'));
                    
                    districtSelect.innerHTML = '<option value="">-- Chọn --</option>';
                    if(wardSelect) wardSelect.innerHTML = '<option value="">-- Chọn --</option>';

                    if (provinceId) {
                        const res = await fetch(`/Address/Districts?provinceId=${provinceId}`);
                        const data = await res.json();
                        data.forEach(d => {
                            const opt = document.createElement('option');
                            opt.value = d.districtId;
                            opt.textContent = d.name;
                            districtSelect.appendChild(opt);
                        });
                    }
                });
            });

            document.querySelectorAll('.addr-district').forEach(el => {
                el.addEventListener('change', async function() {
                    const districtId = this.value;
                    const targetId = this.getAttribute('data-target');
                    if (!targetId) return;
                    const wardSelect = document.getElementById(targetId);
                    
                    wardSelect.innerHTML = '<option value="">-- Chọn --</option>';

                    if (districtId) {
                        const res = await fetch(`/Address/Wards?districtId=${districtId}`);
                        const data = await res.json();
                        data.forEach(w => {
                            const opt = document.createElement('option');
                            opt.value = w.wardId;
                            opt.textContent = w.name;
                            wardSelect.appendChild(opt);
                        });
                    }
                });
            });
        });

        async function openEditModal(id, addressName, name, phone, line, ward, district, province, note, isDefault) {
            document.getElementById('edit_AddressID').value = id;
            document.getElementById('edit_AddressName').value = addressName || '';
            document.getElementById('edit_RecipientName').value = name;
            document.getElementById('edit_ReceiverPhone').value = phone;
            document.getElementById('edit_AddressLine').value = line;
            document.getElementById('edit_Note').value = note || '';
            document.getElementById('edit_IsDefault').checked = isDefault;
            
            // Set Province and trigger change
            const pSelect = document.getElementById('edit_Province');
            pSelect.value = province;
            
            // Fetch Districts manually for modal
            const districtSelect = document.getElementById('edit_District');
            const wardSelect = document.getElementById('edit_Ward');
            districtSelect.innerHTML = '<option value="">-- Chọn --</option>';
            wardSelect.innerHTML = '<option value="">-- Chọn --</option>';

            if (province) {
                const resD = await fetch(`/Address/Districts?provinceId=${province}`);
                const dataD = await resD.json();
                dataD.forEach(d => {
                    const opt = document.createElement('option');
                    opt.value = d.districtId;
                    opt.textContent = d.name;
                    districtSelect.appendChild(opt);
                });
                districtSelect.value = district;

                if (district) {
                    const resW = await fetch(`/Address/Wards?districtId=${district}`);
                    const dataW = await resW.json();
                    dataW.forEach(w => {
                        const opt = document.createElement('option');
                        opt.value = w.wardId;
                        opt.textContent = w.name;
                        wardSelect.appendChild(opt);
                    });
                    wardSelect.value = ward;
                }
            }
            
            document.getElementById('editAddressModal').classList.remove('hidden');
        }
    </script>
}
