@model ClothingStore.Models.ViewModels.CustomerChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "_AccountLayout";
}

<div class="mb-8">
    <h1 class="text-2xl font-semibold text-brand-dark-brown">Đổi mật khẩu</h1>
    <p class="text-gray-500 mt-2">Vui lòng nhập mật khẩu hiện tại và mật khẩu mới để thay đổi.</p>
</div>

<form asp-controller="CustomerAccount" asp-action="ChangePassword" method="post" class="max-w-xl">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

    <div class="space-y-6">
        <div>
            <label asp-for="CurrentPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <input asp-for="CurrentPassword" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
            <span asp-validation-for="CurrentPassword" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="NewPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <input asp-for="NewPassword" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
            <span asp-validation-for="NewPassword" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <input asp-for="ConfirmPassword" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
            <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
        </div>
    </div>

    <div class="mt-8">
        <button type="submit" class="px-6 py-2.5 bg-brand-brown text-white font-medium rounded hover:bg-brand-dark-brown transition-colors">
            Cập nhật mật khẩu
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
