@model ClothingStore.Models.ViewModels.CustomerProfileViewModel

@{
    ViewData["Title"] = "Thông tin cá nhân";
    Layout = "_AccountLayout";
}

<div class="mb-8">
    <h1 class="text-2xl font-semibold text-brand-dark-brown">Thông tin cá nhân</h1>
    <p class="text-gray-500 mt-2">Quản lý thông tin cá nhân và bảo mật của bạn.</p>
</div>

<form asp-controller="CustomerAccount" asp-action="Profile" method="post" class="max-w-2xl">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
            <label asp-for="FullName" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <input asp-for="FullName" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
            <span asp-validation-for="FullName" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <input asp-for="Phone" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
            <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1 block"></span>
        </div>
        
        <div class="md:col-span-2">
            <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
            <input asp-for="Email" class="w-full px-4 py-2 border border-gray-200 bg-gray-50 text-gray-500 rounded-md" readonly />
        </div>
    </div>

    <div class="mt-8">
        <button type="submit" class="px-6 py-2.5 bg-brand-brown text-white font-medium rounded hover:bg-brand-dark-brown transition-colors">
            Lưu thay đổi
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
