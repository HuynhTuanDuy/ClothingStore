@model ClothingStore.Models.ViewModels.CustomerDashboardViewModel

@{
    ViewData["Title"] = "Bảng điều khiển";
    Layout = "_AccountLayout";
}

<div class="mb-8">
    <h1 class="text-2xl font-semibold text-brand-dark-brown">Xin chào, @Model.CustomerName!</h1>
    <p class="text-gray-500 mt-2">Từ bảng điều khiển tài khoản, bạn có thể xem tổng quan về hoạt động mua sắm và quản lý thông tin cá nhân của mình.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-brand-cream rounded-lg p-6 border border-brand-lavender">
        <div class="text-3xl font-bold text-brand-brown mb-1">@Model.TotalOrders</div>
        <div class="text-sm font-medium text-gray-600">Tổng đơn hàng</div>
    </div>
    
    <div class="bg-blue-50 rounded-lg p-6 border border-blue-100">
        <div class="text-3xl font-bold text-blue-800 mb-1">@Model.PendingOrders</div>
        <div class="text-sm font-medium text-blue-600">Đang xử lý</div>
    </div>
    
    <div class="bg-orange-50 rounded-lg p-6 border border-orange-100">
        <div class="text-3xl font-bold text-orange-800 mb-1">@Model.ShippingOrders</div>
        <div class="text-sm font-medium text-orange-600">Đang giao hàng</div>
    </div>
    
    <div class="bg-green-50 rounded-lg p-6 border border-green-100">
        <div class="text-3xl font-bold text-green-800 mb-1">@Model.CompletedOrders</div>
        <div class="text-sm font-medium text-green-600">Đã hoàn thành</div>
    </div>
</div>

<div class="bg-gray-50 rounded-lg p-6 border border-gray-100">
    <div class="flex items-center gap-4">
        <div class="bg-yellow-100 p-4 rounded-full text-yellow-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div>
            <h3 class="text-lg font-semibold text-gray-800">Điểm thưởng của bạn</h3>
            <p class="text-2xl font-bold text-yellow-600">@Model.RewardPoints <span class="text-sm font-normal text-gray-500">điểm</span></p>
        </div>
    </div>
</div>
