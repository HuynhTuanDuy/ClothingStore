@model ClothingStore.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_AuthLayout";
}

<div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Quên mật khẩu</h1>
    <p class="text-sm text-gray-500 mt-2">Nhập email để nhận liên kết đặt lại mật khẩu</p>
</div>

<form asp-controller="Account" asp-action="ForgotPassword" method="post" class="space-y-6">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 p-3 rounded border border-red-100"></div>

    <div>
        <label asp-for="Email" class="block text-sm font-medium text-gray-700">Email của bạn</label>
        <div class="mt-1">
            <input asp-for="Email" class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-brand-brown focus:border-brand-brown sm:text-sm" placeholder="email@example.com" />
        </div>
        <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
    </div>

    <div>
        <button type="submit" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-brand-brown hover:bg-brand-dark-brown focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-brown transition-colors">
            Gửi yêu cầu
        </button>
    </div>
</form>

<div class="mt-6 text-center">
    <p class="text-sm text-gray-600">
        Quay lại
        <a asp-controller="Account" asp-action="Login" class="font-medium text-brand-brown hover:text-brand-dark-brown">Đăng nhập</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
