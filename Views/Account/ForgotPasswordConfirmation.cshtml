@{
    ViewData["Title"] = "Đã gửi email";
    Layout = "_AuthLayout";
}

<div class="text-center py-8">
    <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-green-100 mb-6">
        <svg class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-4">Kiểm tra email của bạn</h1>
    <p class="text-gray-600 mb-8 leading-relaxed max-w-sm mx-auto">
        Nếu email này tồn tại trong hệ thống, chúng tôi đã gửi một liên kết để đặt lại mật khẩu. Vui lòng kiểm tra hộp thư đến (và thư mục Spam).
    </p>

    <a asp-controller="Account" asp-action="Login" class="inline-flex justify-center py-2.5 px-6 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-brand-brown hover:bg-brand-dark-brown focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-brown transition-colors">
        Quay lại đăng nhập
    </a>
</div>
