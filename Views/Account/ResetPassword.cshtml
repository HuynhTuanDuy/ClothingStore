@model ClothingStore.Models.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu mới";
    Layout = "_AuthLayout";
}

<div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Đặt lại mật khẩu</h1>
    <p class="text-sm text-gray-500 mt-2">Vui lòng nhập mật khẩu mới của bạn</p>
</div>

<form asp-controller="Account" asp-action="ResetPassword" method="post" class="space-y-5">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Token" />

    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 p-3 rounded border border-red-100"></div>

    <div>
        <label asp-for="Password" class="block text-sm font-medium text-gray-700">Mật khẩu mới</label>
        <div class="mt-1 relative">
            <input asp-for="Password" type="password" id="reset_password" class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-brand-brown focus:border-brand-brown sm:text-sm" placeholder="••••••••" />
            <button type="button" onclick="toggleResetPassword()" class="absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5">
                <svg class="h-5 w-5 text-gray-400 hover:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-xs text-red-500 mt-1 block"></span>
    </div>

    <div>
        <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700">Xác nhận mật khẩu</label>
        <div class="mt-1 relative">
            <input asp-for="ConfirmPassword" type="password" id="reset_confirm_password" class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-brand-brown focus:border-brand-brown sm:text-sm" placeholder="••••••••" />
            <button type="button" onclick="toggleResetConfirmPassword()" class="absolute inset-y-0 right-0 pr-3 flex items-center text-sm leading-5">
                <svg class="h-5 w-5 text-gray-400 hover:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-xs text-red-500 mt-1 block"></span>
    </div>

    <div class="pt-2">
        <button type="submit" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-brand-brown hover:bg-brand-dark-brown focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-brown transition-colors">
            Xác nhận
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleResetPassword() {
            var x = document.getElementById("reset_password");
            if (x.type === "password") {
                x.type = "text";
            } else {
                x.type = "password";
            }
        }
        function toggleResetConfirmPassword() {
            var x = document.getElementById("reset_confirm_password");
            if (x.type === "password") {
                x.type = "text";
            } else {
                x.type = "password";
            }
        }
    </script>
}
