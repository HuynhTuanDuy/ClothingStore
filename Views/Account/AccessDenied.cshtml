@{
    ViewData["Title"] = "Không có quyền truy cập";
    Layout = "_AuthLayout";
}

<div class="text-center py-8">
    <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-red-100 mb-6">
        <svg class="h-8 w-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
    </div>
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight mb-2">Truy cập bị từ chối (403)</h1>
    <p class="text-gray-500 mb-8">Xin lỗi, bạn không có quyền truy cập vào trang này. Vui lòng kiểm tra lại tài khoản hoặc liên hệ quản trị viên.</p>
    
    <a asp-controller="Home" asp-action="Index" class="inline-flex justify-center items-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-brown hover:bg-brand-dark-brown focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-brown transition-colors">
        Quay về Trang chủ
    </a>
</div>
