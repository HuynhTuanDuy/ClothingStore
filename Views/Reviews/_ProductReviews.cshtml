@model List<ClothingStore.Models.ViewModels.ReviewViewModel>

@if (Model == null || !Model.Any())
{
    <div class="text-center py-12 bg-[#fcfaf9] rounded-lg border border-[#f0eded]">
        <p class="text-gray-500 text-sm">Chưa có đánh giá phù hợp với bộ lọc hiện tại.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 gap-6">
        @foreach (var review in Model)
        {
            <div class="bg-[#fcfaf9] p-6 rounded-lg border border-[#f0eded]">
                <div class="flex justify-between items-start mb-3">
                    <div>
                        <span class="font-semibold text-[#553722] text-sm">@review.CustomerName</span>
                        <span class="text-xs text-gray-400 ml-2">@review.ReviewDate.AddHours(7).ToString("HH:mm dd/MM/yyyy")</span>
                    </div>
                    <div class="flex text-yellow-400 text-sm">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= review.Rating)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                            }
                        }
                    </div>
                </div>
                <p class="text-sm text-gray-600 leading-relaxed mb-3">@review.Comment</p>
                @if (review.Images != null && review.Images.Any())
                {
                    <div class="flex gap-2 mt-2">
                        @foreach (var img in review.Images)
                        {
                            <img src="@img" loading="lazy" decoding="async" class="w-16 h-16 object-cover rounded border border-gray-200 cursor-pointer" onclick="window.open(this.src)" />
                        }
                    </div>
                }
                
                <div class="mt-4 border-t border-gray-100 pt-3 flex items-center justify-end">
                    <button type="button" 
                            onclick="toggleHelpful(@review.ReviewID, this)" 
                            aria-pressed="@(review.IsCurrentUserVoted.ToString().ToLower())"
                            class="flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full transition-colors border @(review.IsCurrentUserVoted ? "bg-green-50 text-green-700 border-green-200" : "bg-white text-gray-500 border-gray-200 hover:bg-gray-50")">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.514" />
                        </svg>
                        Hữu ích (<span class="helpful-count">@review.HelpfulCount</span>)
                    </button>
                </div>
            </div>
        }
    </div>

    <!-- Pagination controls passed from Controller via ViewBag -->
    @if (ViewBag.TotalCount > ViewBag.PageSize)
    {
        var totalPages = (int)Math.Ceiling((double)ViewBag.TotalCount / ViewBag.PageSize);
        <div class="mt-8 flex justify-center gap-2">
            @for (int i = 1; i <= totalPages; i++)
            {
                <button type="button" 
                        onclick="loadReviews(@i)" 
                        class="px-4 py-2 text-sm border rounded transition-colors @(i == ViewBag.Page ? "bg-[#553722] text-white border-[#553722]" : "bg-white text-gray-600 hover:bg-gray-50 border-gray-200")">
                    @i
                </button>
            }
        </div>
    }
}
