@model ClothingStore.Models.ViewModels.ProductCardViewModel

<article class="product-card group cursor-pointer" data-purpose="product-item" onclick="location.href='@Url.Action("Details", "Home", new { id = Model.ProductID })'">
    <div class="relative mb-4 overflow-hidden" style="padding-bottom: 125%; background: #f1f1f1;">
        @if (!Model.HasStock)
        {
            <span class="absolute top-2 right-2 bg-gray-500 text-white text-[9px] px-2 py-0.5 tracking-tighter uppercase font-medium z-10">Sold Out</span>
        }
        else if (Model.HasDiscount)
        {
            <span class="absolute top-2 right-2 bg-red-500 text-white text-[9px] px-2 py-0.5 tracking-tighter uppercase font-medium z-10">Sale</span>
        }

        @if (Model.IsBestSeller)
        {
            <span class="absolute top-2 left-2 bg-black text-white text-[9px] px-2 py-0.5 tracking-tighter uppercase font-medium z-10">Bán chạy</span>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ThumbnailUrl))
        {
            <img alt="@Model.ProductName" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="@Model.ThumbnailUrl"/>
        }
        else
        {
            <div class="absolute inset-0 flex flex-col items-center justify-center bg-gray-100 text-gray-400 gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M6 4h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2zm8 4a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                <span class="text-[10px] uppercase tracking-widest">Chưa có ảnh</span>
            </div>
        }
    </div>
    <div class="space-y-1 mt-2">
        <h3 class="text-lg font-medium leading-tight group-hover:underline">@Model.ProductName</h3>
        <p class="text-base text-gray-900 font-medium">
            @if (Model.HasDiscount)
            {
                <span class="text-red-600 mr-2">@(Model.MinPrice?.ToString("N0") ?? "0") VNĐ</span>
                <span class="line-through text-gray-400">@(Model.OriginalMinPrice?.ToString("N0") ?? "0") VNĐ</span>
            }
            else
            {
                <span>@(Model.MinPrice?.ToString("N0") ?? "0") VNĐ</span>
            }
        </p>
        
        @if (Model.Colors.Any())
        {
            <div class="flex space-x-2 py-2">
                @foreach (var color in Model.Colors.Take(4))
                {
                    <span class="w-4 h-4 rounded-full border border-gray-200" style="background-color: @color.HexCode"></span>
                }
                @if (Model.Colors.Count > 4)
                {
                    <span class="text-[10px] text-gray-500 self-center">+@(Model.Colors.Count - 4)</span>
                }
            </div>
        }
    </div>
</article>
