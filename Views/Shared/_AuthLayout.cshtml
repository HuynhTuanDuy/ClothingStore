<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WearWhatever</title>
    
    <!-- Tailwind CSS v3 CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <!-- Google Fonts: Kanit -->
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['Kanit', 'sans-serif'],
                        sans: ['Kanit', 'sans-serif']
                    },
                    colors: {
                        brand: {
                            cream: '#F9F5F0',
                            sand: '#E5D5C5',
                            brown: '#8B5A2B',
                            "dark-brown": '#4A3320',
                            gray: '#7A7A7A'
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-50 font-sans min-h-screen flex flex-col selection:bg-brand-brown selection:text-white">

    <!-- Header tối giản -->
    <header class="w-full bg-white border-b border-gray-100 py-4 shadow-sm">
        <div class="container mx-auto px-4 flex justify-center">
            <a href="/" class="flex items-center gap-2 group">
                <div class="h-10 w-10 bg-brand-brown text-brand-cream rounded flex items-center justify-center font-serif text-2xl font-bold group-hover:bg-brand-dark-brown transition-colors">
                    A
                </div>
                <span class="font-serif text-2xl font-bold tracking-tight text-brand-dark-brown">WearWhatever</span>
            </a>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
        <div class="w-full max-w-md space-y-8 bg-white p-8 rounded-xl shadow-lg border border-gray-100">
            @RenderBody()
        </div>
    </main>

    <!-- Footer tối giản -->
    <footer class="w-full py-6 text-center text-sm text-gray-500">
        <p>&copy; @DateTime.Now.Year WearWhatever. Bảo lưu mọi quyền.</p>
        <div class="mt-2 space-x-4">
            <a href="#" class="hover:text-brand-brown transition-colors">Điều khoản</a>
            <a href="#" class="hover:text-brand-brown transition-colors">Bảo mật</a>
            <a href="#" class="hover:text-brand-brown transition-colors">Trợ giúp</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
