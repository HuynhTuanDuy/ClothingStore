@model ClothingStore.Models.ViewModels.AddressFormViewModel

<form asp-action="AddAddress" method="post">
    @Html.AntiForgeryToken()
    <div class="space-y-4">
        <div>
            <label asp-for="AddressName" class="block text-sm font-medium text-gray-700 mb-1">Tên gợi nhớ (Tùy chọn)</label>
            <input asp-for="AddressName" placeholder="Ví dụ: Nhà riêng, Công ty..." maxlength="50" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
            <span asp-validation-for="AddressName" class="text-red-500 text-xs mt-1 block"></span>
        </div>
        <div>
            <label asp-for="RecipientName" class="block text-sm font-medium text-gray-700 mb-1">Tên người nhận</label>
            <input asp-for="RecipientName" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
            <span asp-validation-for="RecipientName" class="text-red-500 text-xs mt-1 block"></span>
        </div>
        
        <div>
            <label asp-for="ReceiverPhone" class="block text-sm font-medium text-gray-700 mb-1">Số điện thoại</label>
            <input asp-for="ReceiverPhone" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
            <span asp-validation-for="ReceiverPhone" class="text-red-500 text-xs mt-1 block"></span>
        </div>
        
        <div>
            <label asp-for="AddressLine" class="block text-sm font-medium text-gray-700 mb-1">Số nhà, Tên đường</label>
            <input asp-for="AddressLine" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
            <span asp-validation-for="AddressLine" class="text-red-500 text-xs mt-1 block"></span>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label asp-for="ProvinceId" class="block text-sm font-medium text-gray-700 mb-1">Tỉnh/Thành phố</label>
                <select asp-for="ProvinceId" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown addr-province" data-target="add_districtId">
                    <option value="">-- Chọn --</option>
                    @if (ViewBag.Provinces != null)
                    {
                        foreach (var p in (IEnumerable<ClothingStore.Models.Entities.Province>)ViewBag.Provinces)
                        {
                            <option value="@p.ProvinceId">@p.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="ProvinceId" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="DistrictId" class="block text-sm font-medium text-gray-700 mb-1">Quận/Huyện</label>
                <select asp-for="DistrictId" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown addr-district" id="add_districtId" data-target="add_wardId">
                    <option value="">-- Chọn --</option>
                </select>
                <span asp-validation-for="DistrictId" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="WardId" class="block text-sm font-medium text-gray-700 mb-1">Phường/Xã</label>
                <select asp-for="WardId" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown addr-ward" id="add_wardId">
                    <option value="">-- Chọn --</option>
                </select>
                <span asp-validation-for="WardId" class="text-red-500 text-xs mt-1 block"></span>
            </div>
        </div>
        
        <div>
            <label asp-for="Note" class="block text-sm font-medium text-gray-700 mb-1">Ghi chú (Tòa nhà, Lầu...)</label>
            <input asp-for="Note" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brand-brown focus:border-brand-brown" />
        </div>
        
        <div class="flex items-center mt-2">
            <input asp-for="IsDefault" class="h-4 w-4 text-brand-brown border-gray-300 rounded" />
            <label asp-for="IsDefault" class="ml-2 block text-sm text-gray-900">Đặt làm địa chỉ mặc định</label>
        </div>
    </div>
    
    <div class="mt-6 flex gap-3 justify-end">
        <button type="button" onclick="document.getElementById('addAddressModal').classList.add('hidden')" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50">Hủy</button>
        <button type="submit" class="px-4 py-2 bg-brand-brown text-white rounded-md hover:bg-brand-dark-brown">Thêm mới</button>
    </div>
</form>
