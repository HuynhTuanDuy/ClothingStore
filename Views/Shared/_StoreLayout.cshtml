    </footer>
    <!-- END: Footer -->
    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        // Handle clicking outside the account dropdown to close it
        document.addEventListener('click', function(event) {
            var container = document.getElementById('account-dropdown-container');
            var menu = document.getElementById('account-dropdown-menu');
            if (container && menu && !container.contains(event.target)) {
                menu.classList.add('hidden');
            }
        });

        // Search Autocomplete with LocalStorage & Trending
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('search-input-desktop');
            const searchSuggestions = document.getElementById('search-suggestions-desktop');
            const searchContainer = document.getElementById('search-container-desktop');
            const searchForm = searchContainer.querySelector('form');
            
            if (!searchInput || !searchSuggestions || !searchContainer) return;
            
            let debounceTimer;
            let abortController = null;
            let lastKeyword = '';
            let currentRequestId = 0;
            const suggestionCache = new Map();
            const MAX_CACHE_SIZE = 20;
            let activeIndex = -1;
            let trendingSearches = [];
            
            const currentUserId = '@(User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier) ?? "guest")';
            const recentSearchesKey = `recentSearches_${currentUserId}`;
            
            // Save search to local storage on submit
            searchForm.addEventListener('submit', function() {
                const kw = searchInput.value.trim();
                if (kw.length >= 2) {
                    let recents = JSON.parse(localStorage.getItem(recentSearchesKey) || '[]');
                    recents = recents.filter(x => x.toLowerCase() !== kw.toLowerCase());
                    recents.unshift(kw);
                    if (recents.length > 5) recents.pop();
                    localStorage.setItem(recentSearchesKey, JSON.stringify(recents));
                }
            });

            // Fetch trending searches once
            fetch('/Products/Trending')
                .then(res => res.json())
                .then(data => { if(data.items) trendingSearches = data.items; })
                .catch(err => console.error(err));
            
            function showDropdown() {
                searchSuggestions.classList.remove('hidden');
            }
            
            function hideDropdown() {
                searchSuggestions.classList.add('hidden');
                activeIndex = -1;
            }
            
            function formatCurrency(value) {
                return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(value);
            }
            
            function renderEmptyState() {
                searchSuggestions.innerHTML = '';
                
                let recents = JSON.parse(localStorage.getItem(recentSearchesKey) || '[]');
                
                if (recents.length > 0) {
                    const recentHeader = document.createElement('li');
                    recentHeader.className = 'px-4 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider bg-gray-50';
                    recentHeader.textContent = 'Tìm kiếm gần đây';
                    searchSuggestions.appendChild(recentHeader);
                    
                    recents.forEach((item, index) => {
                        const li = document.createElement('li');
                        li.className = 'border-b border-gray-50 last:border-b-0 group cursor-pointer hover:bg-gray-50 transition-colors';
                        li.setAttribute('role', 'option');
                        li.setAttribute('data-index', index);
                        
                        const a = document.createElement('a');
                        a.href = `/Products/Search?keyword=${encodeURIComponent(item)}`;
                        a.className = 'flex items-center px-4 py-2';
                        a.innerHTML = `<span class="material-symbols-outlined text-gray-400 mr-3 text-lg">history</span><span class="text-sm text-gray-700">${item}</span>`;
                        li.appendChild(a);
                        searchSuggestions.appendChild(li);
                    });
                }
                
                if (trendingSearches.length > 0) {
                    const trendHeader = document.createElement('li');
                    trendHeader.className = 'px-4 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider bg-gray-50';
                    trendHeader.textContent = 'Tìm kiếm phổ biến';
                    searchSuggestions.appendChild(trendHeader);
                    
                    trendingSearches.forEach((item, index) => {
                        const li = document.createElement('li');
                        li.className = 'border-b border-gray-50 last:border-b-0 group cursor-pointer hover:bg-gray-50 transition-colors';
                        li.setAttribute('role', 'option');
                        li.setAttribute('data-index', (recents.length || 0) + index);
                        
                        const a = document.createElement('a');
                        a.href = `/Products/Search?keyword=${encodeURIComponent(item)}`;
                        a.className = 'flex items-center px-4 py-2';
                        a.innerHTML = `<span class="material-symbols-outlined text-brand-brown mr-3 text-lg">trending_up</span><span class="text-sm font-medium text-gray-900">${item}</span>`;
                        li.appendChild(a);
                        searchSuggestions.appendChild(li);
                    });
                }
                
                if (recents.length === 0 && trendingSearches.length === 0) {
                    const li = document.createElement('li');
                    li.className = 'px-4 py-3 text-sm text-gray-500 text-center empty';
                    li.textContent = 'Nhập từ khóa để tìm kiếm';
                    searchSuggestions.appendChild(li);
                }
                
                showDropdown();
            }

            function renderSuggestions(keyword, items) {
                searchSuggestions.innerHTML = '';
                
                if (items.length === 0) {
                    const li = document.createElement('li');
                    li.className = 'px-4 py-3 text-sm text-gray-500 text-center empty';
                    li.textContent = 'Không tìm thấy sản phẩm phù hợp';
                    searchSuggestions.appendChild(li);
                } else {
                    const categories = items.filter(x => x.productId === 0);
                    const products = items.filter(x => x.productId > 0);

                    if (categories.length > 0) {
                        const catHeader = document.createElement('li');
                        catHeader.className = 'px-4 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider bg-gray-50';
                        catHeader.textContent = 'Danh mục';
                        searchSuggestions.appendChild(catHeader);

                        categories.forEach((item, index) => {
                            const li = document.createElement('li');
                            li.className = 'border-b border-gray-50 group cursor-pointer hover:bg-gray-50 transition-colors';
                            const a = document.createElement('a');
                            a.href = `/Products/Search?keyword=${encodeURIComponent(item.name)}`;
                            a.className = 'flex items-center px-4 py-2';
                            a.innerHTML = `<span class="material-symbols-outlined text-gray-400 mr-3 text-lg">search</span><span class="text-sm font-medium text-gray-900 group-hover:text-brand-brown">${item.name}</span>`;
                            li.appendChild(a);
                            searchSuggestions.appendChild(li);
                        });
                    }

                    if (products.length > 0) {
                        const prodHeader = document.createElement('li');
                        prodHeader.className = 'px-4 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider bg-gray-50';
                        prodHeader.textContent = 'Sản phẩm';
                        searchSuggestions.appendChild(prodHeader);

                        products.forEach((item, index) => {
                            const li = document.createElement('li');
                            li.className = 'border-b border-gray-50 last:border-b-0 group cursor-pointer';
                            li.setAttribute('role', 'option');
                            li.setAttribute('data-index', index);
                            
                            const a = document.createElement('a');
                            a.href = `/Products/Details/${item.productSlug}`;
                            a.className = 'flex items-center px-4 py-2 hover:bg-gray-50 transition-colors';
                            
                            if (item.thumbnailUrl) {
                                const imgContainer = document.createElement('div');
                                imgContainer.className = 'flex-shrink-0 w-10 h-10 mr-3 overflow-hidden rounded-md border border-gray-100 bg-gray-50';
                                const img = document.createElement('img');
                                img.src = item.thumbnailUrl;
                                img.alt = item.name;
                                img.className = 'w-full h-full object-cover';
                                imgContainer.appendChild(img);
                                a.appendChild(imgContainer);
                            }
                            
                            const infoDiv = document.createElement('div');
                            infoDiv.className = 'flex-grow min-w-0';
                            
                            const nameSpan = document.createElement('div');
                            nameSpan.className = 'text-sm font-medium text-gray-900 truncate group-hover:text-brand-brown';
                            nameSpan.textContent = item.name;
                            infoDiv.appendChild(nameSpan);
                            
                            const priceSpan = document.createElement('div');
                            priceSpan.className = 'text-xs text-brand-brown font-bold';
                            priceSpan.textContent = formatCurrency(item.price);
                            
                            if (item.originalPrice) {
                                const originalSpan = document.createElement('span');
                                originalSpan.className = 'text-[10px] text-gray-400 line-through ml-2 font-normal';
                                originalSpan.textContent = formatCurrency(item.originalPrice);
                                priceSpan.appendChild(originalSpan);
                            }
                            
                            infoDiv.appendChild(priceSpan);
                            a.appendChild(infoDiv);
                            
                            li.appendChild(a);
                            searchSuggestions.appendChild(li);
                        });
                    }
                    
                    // Add View All link
                    const viewAllLi = document.createElement('li');
                    viewAllLi.className = 'view-all sticky bottom-0 bg-white border-t border-gray-100 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]';
                    const viewAllA = document.createElement('a');
                    viewAllA.href = `/Products/Search?keyword=${encodeURIComponent(keyword)}`;
                    viewAllA.className = 'block w-full text-center px-4 py-2.5 text-sm font-medium text-brand-brown hover:bg-brand-cream transition-colors';
                    viewAllA.textContent = `Xem tất cả kết quả cho "${keyword}"`;
                    viewAllLi.appendChild(viewAllA);
                    searchSuggestions.appendChild(viewAllLi);
                }
                
                showDropdown();
            }
            
            function showLoading() {
                searchSuggestions.innerHTML = '';
                const li = document.createElement('li');
                li.className = 'px-4 py-3 text-sm text-gray-500 text-center flex items-center justify-center';
                li.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-brand-brown" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Đang tìm kiếm...';
                searchSuggestions.appendChild(li);
                showDropdown();
            }
            
            searchInput.addEventListener('input', function() {
                const keyword = this.value.trim();
                
                if (keyword === lastKeyword) return;
                lastKeyword = keyword;
                activeIndex = -1;
                
                if (keyword.length < 2) {
                    if (abortController) abortController.abort();
                    renderEmptyState();
                    return;
                }
                
                // Check cache
                const cacheKey = keyword.toLowerCase();
                if (suggestionCache.has(cacheKey)) {
                    renderSuggestions(keyword, suggestionCache.get(cacheKey));
                    return;
                }
                
                showLoading();
                
                clearTimeout(debounceTimer);
                if (abortController) {
                    abortController.abort();
                }
                
                debounceTimer = setTimeout(() => {
                    abortController = new AbortController();
                    const signal = abortController.signal;
                    const reqId = ++currentRequestId;
                    
                    fetch(`/Products/Suggestions?keyword=${encodeURIComponent(keyword)}`, { signal })
                        .then(response => response.json())
                        .then(data => {
                            if (reqId !== currentRequestId) return;
                            
                            // Update cache
                            if (suggestionCache.size >= MAX_CACHE_SIZE) {
                                const firstKey = suggestionCache.keys().next().value;
                                suggestionCache.delete(firstKey);
                            }
                            suggestionCache.set(cacheKey, data.items);
                            
                            // Only render if the input value still matches
                            if (searchInput.value.trim() === keyword) {
                                renderSuggestions(keyword, data.items);
                            }
                        })
                        .catch(err => {
                            if (err.name === 'AbortError') {
                                console.log('Request aborted');
                            } else {
                                console.error('Error fetching suggestions:', err);
                            }
                        });
                }, 300);
            });
            
            // Keyboard navigation
            searchInput.addEventListener('keydown', function(e) {
                const items = searchSuggestions.querySelectorAll('li[role="option"]');
                
                if (searchSuggestions.classList.contains('hidden') || items.length === 0) return;
                
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    activeIndex = (activeIndex + 1) % items.length;
                    updateActiveItem(items);
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    activeIndex = (activeIndex - 1 + items.length) % items.length;
                    updateActiveItem(items);
                } else if (e.key === 'Enter' && activeIndex > -1) {
                    e.preventDefault();
                    items[activeIndex].querySelector('a').click();
                } else if (e.key === 'Escape') {
                    hideDropdown();
                }
            });
            
            function updateActiveItem(items) {
                items.forEach((item, index) => {
                    if (index === activeIndex) {
                        item.classList.add('bg-gray-100');
                        item.scrollIntoView({ block: 'nearest' });
                    } else {
                        item.classList.remove('bg-gray-100');
                    }
                });
            }
            
            // Focus and click outside
            searchInput.addEventListener('focus', function() {
                const keyword = this.value.trim();
                if (keyword.length < 2) {
                    renderEmptyState();
                } else {
                    if (suggestionCache.has(keyword.toLowerCase())) {
                        renderSuggestions(keyword, suggestionCache.get(keyword.toLowerCase()));
                    } else {
                        showDropdown();
                    }
                }
            });
            
            document.addEventListener('click', function(e) {
                if (!searchContainer.contains(e.target)) {
                    hideDropdown();
                }
            });
        });
    </script>
    <script src="~/js/fly-to-cart.js" asp-append-version="true"></script>
</body>
</html>
