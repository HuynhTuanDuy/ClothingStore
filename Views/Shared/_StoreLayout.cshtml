@using ClothingStore.Services
@inject ICartService CartService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - WearWhatever</title>
    <!-- Tailwind CSS v3 CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Google Fonts: Kanit -->
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['Kanit', 'sans-serif'],
                        sans: ['Kanit', 'sans-serif'],
                        "display-lg": ["Kanit"],
                        "body-lg": ["Kanit"],
                        "body-md": ["Kanit"],
                        "display-lg-mobile": ["Kanit"],
                        "headline-lg-mobile": ["Kanit"],
                        "body-sm": ["Kanit"],
                        "label-caps": ["Kanit"],
                        "headline-lg": ["Kanit"],
                        "headline-md": ["Kanit"]
                    },
                    fontSize: {
                        "display-lg": ["64px", { "lineHeight": "72px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "display-lg-mobile": ["40px", { "lineHeight": "48px", "letterSpacing": "-0.01em", "fontWeight": "700" }],
                        "headline-lg-mobile": ["32px", { "lineHeight": "40px", "fontWeight": "600" }],
                        "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "label-caps": ["12px", { "lineHeight": "16px", "letterSpacing": "0.1em", "fontWeight": "600" }],
                        "headline-lg": ["40px", { "lineHeight": "48px", "fontWeight": "600" }],
                        "headline-md": ["28px", { "lineHeight": "36px", "fontWeight": "500" }]
                    },
                    spacing: {
                        "margin-desktop": "64px",
                        "gutter": "24px",
                        "base": "8px",
                        "section-gap": "120px",
                        "margin-mobile": "20px"
                    },
                    colors: {
                        'brand-cream': '#F9F7F2',
                        'brand-brown': '#6B4F3F',
                        'brand-dark-brown': '#523B2F',
                        'brand-lavender': '#E2D8E8',
                        'brand-green-muted': '#A4B494',
                        "primary-container": "#6f4e37",
                        "surface-container-lowest": "#ffffff",
                        "on-tertiary-fixed": "#1b1c19",
                        "inverse-surface": "#303030",
                        "surface-variant": "#e4e2e1",
                        "surface-tint": "#79573f",
                        "surface-bright": "#fbf9f8",
                        "surface": "#fbf9f8",
                        "outline": "#82746d",
                        "on-secondary": "#ffffff",
                        "secondary": "#53634a",
                        "outline-variant": "#d4c3ba",
                        "on-primary": "#ffffff",
                        "secondary-fixed-dim": "#bbccae",
                        "on-tertiary-container": "#cbcac5",
                        "primary-fixed-dim": "#eabda0",
                        "surface-container-high": "#eae8e7",
                        "surface-container": "#f0eded",
                        "on-error-container": "#93000a",
                        "on-background": "#1b1c1c",
                        "primary-fixed": "#ffdcc6",
                        "on-tertiary": "#ffffff",
                        "on-error": "#ffffff",
                        "tertiary": "#3e3e3b",
                        "surface-dim": "#dcd9d9",
                        "surface-container-highest": "#e4e2e1",
                        "inverse-primary": "#eabda0",
                        "on-surface-variant": "#50453e",
                        "inverse-on-surface": "#f3f0f0",
                        "tertiary-container": "#555552",
                        "on-secondary-fixed": "#121f0c",
                        "on-tertiary-fixed-variant": "#474744",
                        "on-surface": "#1b1c1c",
                        "surface-container-low": "#f6f3f2",
                        "on-secondary-container": "#596950",
                        "secondary-fixed": "#d6e8c9",
                        "on-primary-fixed-variant": "#5f402a",
                        "secondary-container": "#d6e8c9",
                        "primary": "#553722",
                        "on-primary-fixed": "#2d1604",
                        "on-primary-container": "#eec1a4",
                        "error-container": "#ffdad6",
                        "tertiary-fixed": "#e4e2dd",
                        "tertiary-fixed-dim": "#c8c6c2",
                        "on-secondary-fixed-variant": "#3c4b34",
                        "error": "#ba1a1a",
                        "background": "#fbf9f8"
                    }
                }
            }
        }
    </script>
    <style data-purpose="custom-typography">
        body {
            font-family: 'Kanit', sans-serif, Arial, sans-serif;
            color: #333;
        }
        h1, h2, h3, .serif-font {
            font-family: 'Kanit', sans-serif, Arial, sans-serif;
        }
        /* Smooth transitions for interactive elements */
        a, button {
            transition: all 0.2s ease-in-out;
        }
    </style>
</head>
<body class="bg-brand-cream">
    <!-- BEGIN: MainHeader -->
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
        <div class="container mx-auto px-4 py-4">
            <!-- Top Bar: Logo and Icons -->
            <div class="flex justify-between items-center mb-4">
                <div class="w-24"></div> <!-- Spacer for centering logo -->
                <a class="text-3xl font-serif tracking-tight text-brand-dark-brown" asp-controller="Home" asp-action="Index">WearWhatever</a>
                <div class="flex items-center space-x-6 text-gray-600">
                    <button aria-label="Search" class="hover:text-black">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                    </button>
                    <div class="relative" id="account-dropdown-container">
                        <button id="account-dropdown-button" aria-label="Profile" class="hover:text-black flex items-center gap-1 focus:outline-none" onclick="document.getElementById('account-dropdown-menu').classList.toggle('hidden');">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                var fullName = User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value;
                                <span class="hidden sm:block text-xs font-medium">@(fullName ?? User.Identity.Name)</span>
                            }
                        </button>
                        <!-- Dropdown Menu -->
                        <div id="account-dropdown-menu" class="absolute right-0 mt-2 w-48 bg-white border border-gray-100 rounded-md shadow-lg hidden z-50">
                            <div class="py-1">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    @if (Context.HasPermission("Dashboard.View"))
                                    {
                                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="block px-4 py-2 text-sm text-brand-brown font-bold bg-brand-cream/50 hover:bg-brand-cream hover:text-brand-dark-brown border-b border-gray-100">Quản trị hệ thống</a>
                                    }
                                    <a asp-controller="CustomerAccount" asp-action="Index" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-cream hover:text-brand-brown">Tài khoản của tôi</a>
                                    <a asp-controller="CustomerAccount" asp-action="Orders" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-cream hover:text-brand-brown">Đơn hàng của tôi</a>
                                    <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-cream hover:text-brand-brown">Danh sách yêu thích</a>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        <button type="submit" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-brand-cream hover:text-brand-brown">Đăng xuất</button>
                                    </form>
                                }
                                else
                                {
                                    <a asp-controller="Account" asp-action="Login" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-cream hover:text-brand-brown">Đăng nhập</a>
                                    <a asp-controller="Account" asp-action="Register" class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-cream hover:text-brand-brown">Đăng ký</a>
                                }
                            </div>
                        </div>
                    </div>
                    <a href="/Cart" aria-label="Cart" class="hover:text-black flex items-center">
                        <div id="cart-anchor" class="relative inline-block">
                            <svg class="h-6 w-6 transition-transform duration-200" id="cart-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
                            @{ var cartCount = await CartService.GetCartItemCountAsync(); }
                            <span id="cart-badge" class="absolute -top-1 -right-2 bg-brand-brown text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full @(cartCount > 0 ? "" : "hidden") transition-transform duration-300">@cartCount</span>
                        </div>
                    </a>
                </div>
            </div>
            <!-- Navigation Links -->
            <nav class="flex justify-center space-x-8 text-xs font-medium uppercase tracking-widest text-gray-700">
                <a class="hover:text-brand-brown" asp-controller="Home" asp-action="ShopAll">Sản phẩm</a>
                <a class="hover:text-brand-brown" href="#">Bộ sưu tập</a>
                <a class="hover:text-brand-brown" href="#">Về chúng tôi</a>
                <a class="hover:text-brand-brown" href="#">Liên hệ</a>
                <a class="hover:text-brand-brown" href="#">Điều khoản</a>
            </nav>
        </div>
    </header>
    <!-- END: MainHeader -->

    <main>
        @if (TempData["Success"] is string success)
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative container mx-auto mt-4" role="alert">
                <span class="block sm:inline">@success</span>
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative container mx-auto mt-4" role="alert">
                <span class="block sm:inline">@error</span>
            </div>
        }
        
        @RenderBody()
    </main>

    <!-- BEGIN: Footer -->
    <footer class="bg-brand-dark-brown text-brand-cream py-12">
        <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-start md:items-end">
            <!-- Footer Links Area -->
            <div class="flex flex-col md:flex-row gap-8 mb-8 md:mb-0">
                <!-- Footer Left Links -->
                <div class="flex flex-col space-y-2">
                    <span class="text-lg font-bold mb-2">Về chúng tôi</span>
                    <a class="text-sm hover:underline" href="#">Sơ đồ trang</a>
                    <a class="text-sm hover:underline" href="#">Giới thiệu</a>
                    <a class="text-sm hover:underline" href="#">Liên hệ</a>
                </div>
                
                <!-- Footer Support Links -->
                <div class="flex flex-col space-y-2">
                    <span class="text-lg font-bold mb-2">Hỗ trợ khách hàng</span>
                    <a class="text-sm hover:underline" asp-controller="OrderTracking" asp-action="Index">Tra cứu đơn hàng</a>
                </div>
            </div>

            <!-- Footer Right Socials -->
            <div class="flex space-x-6">
                <a aria-label="Facebook" class="hover:opacity-75" href="#">
                    <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M18.77,7.46H14.5v-1.9c0-.9.6-1.1,1-1.1h3V.5h-4.33c-4.8,0-5.9,3.6-5.9,5.8v1.1h-2.8v3.9h2.8v12h4.9v-12h3.33l.5-3.9Z"></path></svg>
                </a>
                <a aria-label="X" class="hover:opacity-75" href="#">
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 1200 1227"><path d="M714.163 519.284L1160.89 0H1055.03L664.137 454.41L354.45 0H0L468.492 681.821L0 1226.37H105.866L518.475 746.682L845.55 1226.37H1200L714.137 519.284H714.163ZM572.288 684.101L524.811 616.148L146.541 75.3138H309.208L614.417 512.195L661.894 580.148L1055.08 1143.01H892.413L572.288 684.127V684.101Z"></path></svg>
                </a>
                <a aria-label="Instagram" class="hover:opacity-75" href="#">
                    <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12,2.16c3.2,0,3.58.01,4.85.07,1.17.05,1.81.25,2.23.41.56.22.95.48,1.37.9.42.42.68.81.9,1.37.16.42.36,1.06.41,2.23.06,1.27.07,1.65.07,4.85s-.01,3.58-.07,4.85c-.05,1.17-.25,1.81-.41,2.23-.22.56-.48.95-.9,1.37-.42.42-.81.68-1.37.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.81-.25-2.23-.41-.56-.22-.95-.48-1.37-.9-.42-.42-.68-.81-.9-1.37-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.81.41-2.23.22-.56.48-.95.9-1.37.42-.42.81-.68,1.37-.9.42-.16,1.06-.36,2.23-.41C8.42,2.17,8.8,2.16,12,2.16ZM12,0c-3.26,0-3.67.01-4.95.07-1.28.06-2.15.26-2.91.56-.78.3-1.45.71-2.11,1.37-.66.66-1.07,1.33-1.37,2.11-.3.76-.5,1.63-.56,2.91C0.01,8.33,0,8.74,0,12s.01,3.67.07,4.95c.06,1.28.26,2.15.56,2.91.3.78.71,1.45,1.37,2.11.66.66,1.33,1.07,2.11,1.37.76.3,1.63.5,2.91.56,1.28.06,1.69.07,4.95.07s3.67-.01,4.95-.07c1.28-.06,2.15-.26,2.91-.56.78-.3,1.45-.71,2.11-1.37.66-.66,1.07-1.33,1.37-2.11.3-.76.5-1.63.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.28-.26-2.15-.56-2.91-.3-.78-.71-1.45-1.37-2.11-.66-.66-1.33-1.07-2.11-1.37-.76-.3-1.63-.5-2.91-.56-1.28-.06-1.69-.07-4.95-.07Z"></path><path d="M12,5.84c-3.4,0-6.16,2.76-6.16,6.16s2.76,6.16,6.16,6.16,6.16-2.76,6.16-6.16-2.76-6.16-6.16-6.16ZM12,16c-2.21,0-4-1.79-4-4s1.79-4,4-4,4,1.79,4,4-1.79,4-4,4Z"></path><circle cx="18.41" cy="5.59" r="1.44"></circle></svg>
                </a>
                <a aria-label="TikTok" class="hover:opacity-75" href="#">
                    <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12.53,3.41c.21,0,.41,0,.62,0,.04,2.39,1.43,4.41,3.41,5.32v3.13c-1.37-.36-2.43-1.31-3.13-2.45v6.52c0,3.31-2.69,6-6,6s-6-2.69-6-6,2.69-6,6-6c.21,0,.41.01.62.04v3.16c-.2-.03-.41-.05-.62-.05-1.66,0-3,1.34-3,3s1.34,3,3,3,3-1.34,3-3V3.41Z"></path></svg>
                </a>
            </div>
        </div>
    </footer>
    <!-- END: Footer -->
    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        // Handle clicking outside the account dropdown to close it
        document.addEventListener('click', function(event) {
            var container = document.getElementById('account-dropdown-container');
            var menu = document.getElementById('account-dropdown-menu');
            if (container && menu && !container.contains(event.target)) {
                menu.classList.add('hidden');
            }
        });
    </script>
    <script src="~/js/fly-to-cart.js" asp-append-version="true"></script>
</body>
</html>
