<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shipper</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
        :root {
            --md-sys-color-primary: #8a5a44;
            --md-sys-color-on-primary: #ffffff;
            --md-sys-color-primary-container: #ffdbcc;
            --md-sys-color-on-primary-container: #351000;
        }
        .text-primary { color: var(--md-sys-color-primary); }
        .bg-primary { background-color: var(--md-sys-color-primary); }
        .bg-primary-container { background-color: var(--md-sys-color-primary-container); }
        .text-on-primary { color: var(--md-sys-color-on-primary); }
    </style>
</head>
<body class="bg-gray-50 font-sans antialiased text-gray-800">
    <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex">
                    <div class="flex-shrink-0 flex items-center">
                        <span class="font-bold text-xl text-primary flex items-center gap-2">
                            <span class="material-symbols-outlined">local_shipping</span>
                            Shipper Portal
                        </span>
                    </div>
                    <div class="hidden sm:-my-px sm:ml-8 sm:flex sm:space-x-8">
                        <a href="@Url.Action("Dashboard", "Shipper", new { area = "Shipper" })" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
                            Dashboard
                        </a>
                        <a href="@Url.Action("Orders", "Shipper", new { area = "Shipper" })" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
                            Đơn Hàng
                        </a>
                    </div>
                </div>
                <div class="flex items-center">
                    <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="text-sm font-medium text-gray-500 hover:text-gray-700 flex items-center gap-1">
                            <span class="material-symbols-outlined text-[18px]">logout</span> Đăng xuất
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        @if (TempData["Success"] != null)
        {
            <div class="mb-4 p-4 rounded-lg bg-green-50 text-green-800 border border-green-200">
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mb-4 p-4 rounded-lg bg-red-50 text-red-800 border border-red-200">
                @TempData["Error"]
            </div>
        }
        
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
