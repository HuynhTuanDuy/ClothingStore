@model List<ClothingStore.Models.ViewModels.ShipperOrderViewModel>
@inject ClothingStore.Services.IDateTimeService DateTimeService
@{
    ViewData["Title"] = "Đơn Hàng";
    string currentStatus = ViewBag.CurrentStatus as string ?? "ReadyToShip";
}

<div class="mb-6 flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900">Danh sách đơn hàng</h1>
</div>

<!-- Tabs -->
<div class="border-b border-gray-200 mb-6 flex overflow-x-auto">
    <a href="@Url.Action("Orders", new { status = "ReadyToShip" })" class="px-6 py-3 font-medium text-sm whitespace-nowrap border-b-2 transition-colors @(currentStatus == "ReadyToShip" ? "border-primary text-primary" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
        Cần lấy hàng
    </a>
    <a href="@Url.Action("Orders", new { status = "Shipping" })" class="px-6 py-3 font-medium text-sm whitespace-nowrap border-b-2 transition-colors @(currentStatus == "Shipping" ? "border-amber-500 text-amber-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
        Đang giao
    </a>
    <a href="@Url.Action("Orders", new { status = "Delivered" })" class="px-6 py-3 font-medium text-sm whitespace-nowrap border-b-2 transition-colors @(currentStatus == "Delivered" ? "border-green-500 text-green-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
        Đã giao
    </a>
    <a href="@Url.Action("Orders", new { status = "DeliveryAttemptFailed" })" class="px-6 py-3 font-medium text-sm whitespace-nowrap border-b-2 transition-colors @(currentStatus == "DeliveryAttemptFailed" ? "border-amber-500 text-amber-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
        Chờ giao lại
    </a>
    <a href="@Url.Action("Orders", new { status = "DeliveryFailed" })" class="px-6 py-3 font-medium text-sm whitespace-nowrap border-b-2 transition-colors @(currentStatus == "DeliveryFailed" ? "border-red-500 text-red-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
        Giao thất bại
    </a>
</div>

<!-- Orders List -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @if (!Model.Any())
    {
        <div class="col-span-full py-12 text-center text-gray-500 bg-white rounded-xl border border-gray-100 shadow-sm">
            <span class="material-symbols-outlined text-4xl mb-2 opacity-50">inbox</span>
            <p>Không có đơn hàng nào.</p>
        </div>
    }
    else
    {
        foreach (var order in Model)
        {
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
                <div class="p-4 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                    <span class="font-bold text-gray-900">#@order.OrderCode</span>
                    <span class="text-xs font-medium px-2.5 py-1 rounded-full 
                        @(order.Status == "ReadyToShip" ? "bg-blue-100 text-blue-700" :
                          order.Status == "Shipping" ? "bg-amber-100 text-amber-700" :
                          order.Status == "DeliveryAttemptFailed" ? "bg-amber-100 text-amber-700" :
                          order.Status == "Delivered" ? "bg-green-100 text-green-700" :
                          order.Status == "DeliveryFailed" ? "bg-red-100 text-red-700" : "bg-gray-100 text-gray-700")">
                        @(order.Status switch {
                            "ReadyToShip" => "Cần lấy hàng",
                            "Shipping" => "Đang giao",
                            "DeliveryAttemptFailed" => "Chờ giao lại",
                            "Delivered" => "Đã giao",
                            "DeliveryFailed" => "Giao thất bại",
                            _ => order.Status
                        })
                    </span>
                </div>
                <div class="p-5 space-y-3">
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1 font-semibold">Khách hàng</p>
                        <p class="font-medium text-gray-900">@order.CustomerName</p>
                        <p class="text-sm text-gray-600 flex items-center gap-1 mt-1">
                            <span class="material-symbols-outlined text-[16px]">call</span>
                            @order.Phone
                        </p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1 font-semibold">Địa chỉ giao</p>
                        <p class="text-sm text-gray-800 line-clamp-2" title="@order.Address">@order.Address</p>
                    </div>
                    @if (order.Status == "DeliveryAttemptFailed")
                    {
                        <div class="bg-amber-50 rounded p-2 text-sm text-amber-800">
                            Lần giao: <strong>@order.DeliveryAttemptCount</strong><br/>
                            @{
                                string displayDate = "Chưa rõ";
                                if (order.NextDeliveryDate.HasValue)
                                {
                                    var localDate = DateTimeService.ConvertUtcToLocal(order.NextDeliveryDate.Value);
                                    displayDate = localDate.ToString("HH:mm dd/MM/yyyy");
                                }
                            }
                            Hẹn lại: <strong>@displayDate</strong>
                        </div>
                    }
                    <div class="pt-3 border-t border-gray-100 flex justify-between items-center">
                        <span class="font-bold text-lg text-primary">@order.FinalAmount.ToString("N0")đ</span>
                        <a href="@Url.Action("Details", new { id = order.OrderID })" class="text-sm font-medium text-primary hover:text-primary/80 flex items-center gap-1">
                            Chi tiết <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>
