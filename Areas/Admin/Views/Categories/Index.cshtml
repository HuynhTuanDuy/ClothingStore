@model List<ClothingStore.Models.Entities.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var parentCategories = ViewBag.ParentCategories as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
}

<!-- Page Action Header -->
<div class="flex justify-between items-end mb-12">
    <div>
        <h3 class="font-headline-lg text-headline-lg text-primary">Danh mục</h3>
        <p class="font-body-md text-on-surface-variant mt-2 max-w-lg">Quản lý cấu trúc phân loại của cửa hàng.</p>
    </div>
    <div class="flex items-center gap-4">
        <a asp-action="ExportCsv" class="text-primary font-label-caps text-label-caps flex items-center gap-1 hover:underline">
            Tải xuống báo cáo CSV <span class="material-symbols-outlined text-sm" data-icon="download">download</span>
        </a>
        <a asp-action="Create" class="bg-primary text-white px-8 py-4 font-label-caps text-label-caps flex items-center gap-2 hover:opacity-90 transition-opacity">
            <span class="material-symbols-outlined" data-icon="add">add</span>
            Tạo danh mục mới
        </a>
    </div>
</div>

<!-- Category Card Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-8">
    @foreach (var category in Model)
    {
        var count = category.Products?.Count ?? 0;
        var isRoot = !category.ParentCategoryID.HasValue;
        var badgeColor = isRoot ? "bg-blue-100 text-blue-800 border-blue-200" : "bg-purple-100 text-purple-800 border-purple-200";
        var statusColor = category.IsActive ? "bg-green-100 text-green-800 border-green-200" : "bg-gray-100 text-gray-800 border-gray-200";
        var statusText = category.IsActive ? "Hoạt động" : "Không hoạt động";
        var parentText = isRoot ? "Danh mục gốc" : $"Thuộc: {category.ParentCategory?.CategoryName}";
        var createdAt = category.CreatedAt?.ToString("dd/MM/yyyy") ?? "N/A";

        <div class="category-card bg-surface border border-outline-variant rounded-lg p-6 hover:border-primary transition-all duration-300 relative overflow-hidden group flex flex-col" data-id="@category.CategoryID" data-parent-id="@(category.ParentCategoryID?.ToString() ?? "")" data-active="@(category.IsActive ? "true" : "false")">
            
            <!-- View Mode -->
            <div class="view-mode flex-1 flex flex-col">
                <div class="flex justify-between items-start mb-4">
                    <div class="flex flex-col gap-1">
                        <span class="status-badge px-2 py-0.5 text-[10px] font-bold rounded-full uppercase tracking-wider border inline-block w-max @statusColor">@statusText</span>
                        <span class="parent-badge px-2 py-0.5 text-[10px] font-bold rounded-full uppercase tracking-wider border inline-block w-max @badgeColor">@parentText</span>
                    </div>
                    <span class="text-on-surface-variant font-label-caps text-[10px]">CAT-@category.CategoryID.ToString("D3")</span>
                </div>
                
                <h4 class="category-name-display font-headline-md text-xl text-primary font-semibold mb-2 truncate" title="@category.CategoryName">@category.CategoryName</h4>
                
                <div class="mt-auto pt-4 border-t border-outline-variant/50">
                    <div class="flex justify-between items-end">
                        <div>
                            <p class="font-body-sm text-on-surface-variant"><strong>@count</strong> sản phẩm</p>
                            <p class="font-body-sm text-on-surface-variant text-[11px] mt-1">Tạo: @createdAt</p>
                        </div>
                        <button type="button" class="btn-edit w-8 h-8 flex items-center justify-center rounded-full bg-surface-container hover:bg-primary hover:text-on-primary transition-colors text-primary" title="Chỉnh sửa">
                            <span class="material-symbols-outlined text-[16px]">edit</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Edit Mode -->
            <div class="edit-mode hidden flex-1 flex flex-col">
                <form class="edit-form flex-1 flex flex-col" method="post" action="/Admin/Categories/EditAjax/@category.CategoryID">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CategoryID" value="@category.CategoryID" />
                    
                    <div class="mb-3">
                        <label class="block text-xs text-on-surface-variant uppercase tracking-wider mb-1">Tên danh mục</label>
                        <input type="text" name="CategoryName" class="w-full bg-surface-container-low border border-outline-variant focus:border-primary rounded px-3 py-2 text-sm" value="@category.CategoryName" required />
                    </div>

                    <div class="mb-3">
                        <label class="block text-xs text-on-surface-variant uppercase tracking-wider mb-1">Danh mục cha</label>
                        <select name="ParentCategoryID" class="w-full bg-surface-container-low border border-outline-variant focus:border-primary rounded px-3 py-2 text-sm parent-select">
                            <option value="">-- Trở thành Danh mục gốc --</option>
                            @if (parentCategories != null)
                            {
                                foreach (var opt in parentCategories)
                                {
                                    // Bỏ qua chính nó trong danh sách để chống lỗi cơ bản
                                    if (opt.Value != category.CategoryID.ToString())
                                    {
                                        if (category.ParentCategoryID?.ToString() == opt.Value) { <option value="@opt.Value" selected>@opt.Text</option> }
                                        else { <option value="@opt.Value">@opt.Text</option> }
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="block text-xs text-on-surface-variant uppercase tracking-wider mb-1">Trạng thái</label>
                        <select name="IsActive" class="w-full bg-surface-container-low border border-outline-variant focus:border-primary rounded px-3 py-2 text-sm">
                            <option value="true" selected="@(category.IsActive)">Hoạt động</option>
                            <option value="false" selected="@(!category.IsActive)">Không hoạt động</option>
                        </select>
                    </div>
                    
                    <div class="mt-auto pt-3 flex gap-2 justify-end border-t border-outline-variant/50">
                        <button type="button" class="btn-cancel px-3 py-1.5 text-xs font-semibold uppercase rounded hover:bg-surface-container text-on-surface-variant transition-colors">Hủy</button>
                        <button type="submit" class="btn-save px-3 py-1.5 text-xs font-semibold uppercase rounded bg-primary text-white hover:bg-primary/90 transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">save</span> Lưu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }

    <!-- Create Category Card -->
    <a asp-action="Create" class="bg-surface-container-lowest border-2 border-dashed border-outline-variant rounded-lg p-6 hover:border-primary hover:bg-surface-container-low transition-all duration-300 flex flex-col items-center justify-center min-h-[200px] group cursor-pointer">
        <div class="w-14 h-14 rounded-full bg-surface-container-high flex items-center justify-center group-hover:bg-primary transition-colors mb-3">
            <span class="material-symbols-outlined text-primary group-hover:text-on-primary text-2xl">add</span>
        </div>
        <p class="font-label-caps text-sm text-outline group-hover:text-primary font-medium">Tạo danh mục mới</p>
    </a>
</div>

<!-- Pagination -->
<div class="flex justify-between items-center mt-6 mb-24">
    <div class="flex items-center gap-4">
        <p class="font-body-sm text-on-surface-variant">Hiển thị @Model.Count trên tổng số @ViewBag.TotalItems danh mục</p>
        <form method="get" asp-action="Index" class="flex items-center gap-2">
            <span class="text-sm text-on-surface-variant">Hiển thị:</span>
            <select name="pageSize" onchange="this.form.submit()" class="bg-surface border border-outline-variant rounded py-1 px-2 text-sm focus:outline-none focus:border-primary">
                <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                <option value="25" selected="@(ViewBag.PageSize == 25)">25</option>
                <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                <option value="100" selected="@(ViewBag.PageSize == 100)">100</option>
            </select>
        </form>
    </div>
    <div class="flex gap-2">
        @if (ViewBag.CurrentPage > 1)
        {
            <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })" class="px-3 py-1 border border-outline-variant text-outline hover:border-primary hover:text-primary transition-all rounded">Trước</a>
        }
        else
        {
            <span class="px-3 py-1 border border-outline-variant text-outline opacity-50 cursor-not-allowed rounded">Trước</span>
        }

        <span class="px-3 py-1 border border-primary text-on-primary bg-primary transition-all rounded">@ViewBag.CurrentPage / @ViewBag.TotalPages</span>

        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })" class="px-3 py-1 border border-outline-variant text-outline hover:border-primary hover:text-primary transition-all rounded">Sau</a>
        }
        else
        {
            <span class="px-3 py-1 border border-outline-variant text-outline opacity-50 cursor-not-allowed rounded">Sau</span>
        }
    </div>
</div>

<!-- Toast Container -->
<div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2"></div>

@section Scripts {
    <script>
        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            const bgClass = type === 'success' ? 'bg-green-600' : 'bg-red-600';
            const icon = type === 'success' ? 'check_circle' : 'error';
            
            toast.className = `${bgClass} text-white px-4 py-3 rounded shadow-lg flex items-center gap-2 transform transition-all duration-300 translate-y-10 opacity-0`;
            toast.innerHTML = `<span class="material-symbols-outlined text-sm">${icon}</span> <span class="text-sm font-medium">${message}</span>`;
            
            document.getElementById('toast-container').appendChild(toast);
            
            // Animate in
            setTimeout(() => {
                toast.classList.remove('translate-y-10', 'opacity-0');
            }, 10);
            
            // Remove after 3s
            setTimeout(() => {
                toast.classList.add('opacity-0');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Edit Button Toggle
            document.querySelectorAll('.btn-edit').forEach(btn => {
                btn.addEventListener('click', function() {
                    const card = this.closest('.category-card');
                    card.querySelector('.view-mode').classList.add('hidden');
                    card.querySelector('.edit-mode').classList.remove('hidden');
                });
            });

            // Cancel Button Toggle
            document.querySelectorAll('.btn-cancel').forEach(btn => {
                btn.addEventListener('click', function() {
                    const card = this.closest('.category-card');
                    card.querySelector('.edit-mode').classList.add('hidden');
                    card.querySelector('.view-mode').classList.remove('hidden');
                    // Reset form by calling form.reset()
                    card.querySelector('.edit-form').reset();
                });
            });

            // AJAX Form Submit
            document.querySelectorAll('.edit-form').forEach(form => {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    
                    const btnSave = this.querySelector('.btn-save');
                    const originalBtnHtml = btnSave.innerHTML;
                    btnSave.innerHTML = '<span class="material-symbols-outlined text-[14px] animate-spin">refresh</span> Đang lưu...';
                    btnSave.disabled = true;

                    const formData = new FormData(this);
                    
                    fetch(this.action, {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        btnSave.innerHTML = originalBtnHtml;
                        btnSave.disabled = false;

                        if (data.success) {
                            showToast(data.message, 'success');
                            
                            // Update View Mode DOM elements
                            const card = this.closest('.category-card');
                            
                            // Update Title
                            card.querySelector('.category-name-display').textContent = data.data.categoryName;
                            
                            // Update Status Badge
                            const statusBadge = card.querySelector('.status-badge');
                            if (data.data.isActive) {
                                statusBadge.textContent = "Hoạt động";
                                statusBadge.className = "status-badge px-2 py-0.5 text-[10px] font-bold rounded-full uppercase tracking-wider border inline-block w-max bg-green-100 text-green-800 border-green-200";
                            } else {
                                statusBadge.textContent = "Không hoạt động";
                                statusBadge.className = "status-badge px-2 py-0.5 text-[10px] font-bold rounded-full uppercase tracking-wider border inline-block w-max bg-gray-100 text-gray-800 border-gray-200";
                            }

                            // Update Parent Badge
                            const parentBadge = card.querySelector('.parent-badge');
                            if (data.data.parentCategoryId === null || data.data.parentCategoryId === "") {
                                parentBadge.textContent = "Danh mục gốc";
                                parentBadge.className = "parent-badge px-2 py-0.5 text-[10px] font-bold rounded-full uppercase tracking-wider border inline-block w-max bg-blue-100 text-blue-800 border-blue-200";
                            } else {
                                parentBadge.textContent = "Thuộc: " + data.data.parentName;
                                parentBadge.className = "parent-badge px-2 py-0.5 text-[10px] font-bold rounded-full uppercase tracking-wider border inline-block w-max bg-purple-100 text-purple-800 border-purple-200";
                            }

                            // Update data attributes
                            card.setAttribute('data-parent-id', data.data.parentCategoryId || "");
                            card.setAttribute('data-active', data.data.isActive);
                            
                            // Switch back to view mode
                            card.querySelector('.edit-mode').classList.add('hidden');
                            card.querySelector('.view-mode').classList.remove('hidden');

                            // Update all other dropdowns in the grid to reflect name change if needed
                            const categoryId = card.getAttribute('data-id');
                            document.querySelectorAll(`.parent-select option[value="${categoryId}"]`).forEach(opt => {
                                opt.textContent = data.data.categoryName;
                            });

                        } else {
                            showToast(data.message, 'error');
                        }
                    })
                    .catch(error => {
                        btnSave.innerHTML = originalBtnHtml;
                        btnSave.disabled = false;
                        showToast('Đã xảy ra lỗi hệ thống.', 'error');
                        console.error('Error:', error);
                    });
                });
            });
        });
    </script>
}
