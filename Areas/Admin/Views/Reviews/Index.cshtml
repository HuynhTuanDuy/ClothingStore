@model ClothingStore.Models.ViewModels.AdminReviewPageViewModel

@{
    ViewData["Title"] = "Quản lý Đánh giá";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Khách hàng</th>
                        <th>Sản phẩm</th>
                        <th>Đánh giá</th>
                        <th>Nội dung</th>
                        <th>Ảnh</th>
                        <th>Thời gian</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Reviews.Any())
                    {
                        foreach (var item in Model.Reviews)
                        {
                            <tr>
                                <td>@item.CustomerName</td>
                                <td>@item.ProductName</td>
                                <td>
                                    <div class="text-warning">
                                        @for (var i = 1; i <= 5; i++)
                                        {
                                            if (i <= item.Rating)
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star"></i>
                                            }
                                        }
                                    </div>
                                </td>
                                <td style="max-width: 300px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                                    @item.Comment
                                </td>
                                <td>
                                    @if (item.Images.Any())
                                    {
                                        <div class="d-flex gap-1">
                                            @foreach (var img in item.Images)
                                            {
                                                <img src="@img" alt="Review Image" loading="lazy" class="rounded" style="width: 40px; height: 40px; object-fit: cover;" />
                                            }
                                        </div>
                                    }
                                </td>
                                <td>@item.ReviewDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.IsApproved)
                                    {
                                        <span class="badge bg-success">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        @if (!item.IsApproved)
                                        {
                                            <form asp-action="Approve" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.ReviewID" />
                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Duyệt">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Delete" method="post" class="d-inline ms-1" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đánh giá này?');">
                                            <input type="hidden" name="id" value="@item.ReviewID" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                Không có đánh giá nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-white">
            <nav aria-label="Page navigation">
                <ul class="pagination mb-0 justify-content-center">
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
