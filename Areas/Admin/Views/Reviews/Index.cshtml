@model ClothingStore.Models.ViewModels.AdminReviewPageViewModel

@{
    ViewData["Title"] = "Quản lý Đánh giá";
}

<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800 dark:text-white">@ViewData["Title"]</h2>
</div>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-900/50">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Khách hàng</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Sản phẩm</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Đánh giá</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Nội dung</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Ảnh</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Thời gian</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Trạng thái</th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Hành động</th>
                </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                @if (Model.Reviews.Any())
                {
                    foreach (var item in Model.Reviews)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100 font-medium">@item.CustomerName</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">@item.ProductName</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex text-amber-400">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        if (i <= item.Rating)
                                        {
                                            <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 0;">star</span>
                                        }
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400 max-w-[300px]">
                                <div class="line-clamp-2" title="@item.Comment">
                                    @item.Comment
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (item.Images.Any())
                                {
                                    <div class="flex gap-2">
                                        @foreach (var img in item.Images)
                                        {
                                            <a href="@img" target="_blank" class="block hover:opacity-80 transition-opacity" title="Nhấn để xem ảnh gốc">
                                                <img src="@img" alt="Review Image" loading="lazy" decoding="async" class="w-10 h-10 object-cover rounded-md border border-gray-200 dark:border-gray-600 shadow-sm" />
                                            </a>
                                        }
                                    </div>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                                @item.ReviewDate.AddHours(7).ToString("HH:mm dd/MM/yyyy")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (item.IsApproved)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">
                                        Đã duyệt
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400">
                                        Chờ duyệt
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex justify-end gap-2">
                                    @if (!item.IsApproved)
                                    {
                                        <form asp-action="Approve" method="post" class="inline">
                                            <input type="hidden" name="id" value="@item.ReviewID" />
                                            <button type="submit" class="p-1 text-green-600 hover:text-green-900 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-md transition-colors" title="Duyệt">
                                                <span class="material-symbols-outlined text-[20px]">check_circle</span>
                                            </button>
                                        </form>
                                    }
                                    <button type="button" onclick="showReviewDetails('@item.CustomerName', '@item.CustomerEmail', '@item.CustomerPhone', '@item.ProductName', @item.Rating, '@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Comment)', '@item.ReviewDate.AddHours(7).ToString("HH:mm dd/MM/yyyy")', [@Html.Raw(string.Join(",", item.Images.Select(i => $"'{i}'")))])" class="p-1 text-blue-600 hover:text-blue-900 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-md transition-colors" title="Xem chi tiết">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </button>
                                    <form asp-action="Delete" method="post" class="inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đánh giá này?');">
                                        <input type="hidden" name="id" value="@item.ReviewID" />
                                        <button type="submit" class="p-1 text-red-600 hover:text-red-900 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-md transition-colors" title="Xóa">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                            <span class="material-symbols-outlined text-4xl mb-2 text-gray-300 dark:text-gray-600">rate_review</span>
                            <p>Không có đánh giá nào.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (Model.TotalPages > 1)
    {
        <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 flex justify-center">
            <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.Page)
                    {
                        <span aria-current="page" class="relative z-10 inline-flex items-center bg-primary px-4 py-2 text-sm font-semibold text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">@i</span>
                    }
                    else
                    {
                        var roundedClass = i == 1 ? "rounded-l-md" : (i == Model.TotalPages ? "rounded-r-md" : "");
                        <a asp-action="Index" asp-route-page="@i" class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-900 dark:text-gray-300 ring-1 ring-inset ring-gray-300 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 focus:z-20 focus:outline-offset-0 @roundedClass">@i</a>
                    }
                }
            </nav>
        </div>
    }
</div>

<!-- Review Details Modal -->
<div id="reviewDetailsModal" class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto transform scale-95 transition-transform duration-300">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center sticky top-0 bg-white/95 dark:bg-gray-800/95 backdrop-blur z-10">
            <h3 class="text-xl font-bold text-gray-800 dark:text-white">Chi tiết đánh giá</h3>
            <button type="button" onclick="closeReviewDetails()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors rounded-full p-1 hover:bg-gray-100 dark:hover:bg-gray-700">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 space-y-6">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider block mb-1">Khách hàng</span>
                    <p id="modalCustomerName" class="text-base font-medium text-gray-900 dark:text-gray-100"></p>
                    <p id="modalCustomerContact" class="text-xs text-gray-500 dark:text-gray-400 mt-1"></p>
                </div>
                <div>
                    <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider block mb-1">Thời gian</span>
                    <p id="modalDate" class="text-sm text-gray-600 dark:text-gray-300"></p>
                </div>
                <div class="col-span-2">
                    <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider block mb-1">Sản phẩm</span>
                    <p id="modalProductName" class="text-base font-medium text-gray-900 dark:text-gray-100"></p>
                </div>
                <div class="col-span-2">
                    <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider block mb-1">Đánh giá sao</span>
                    <div id="modalRating" class="flex text-amber-400 mt-1"></div>
                </div>
            </div>
            
            <div class="border-t border-gray-100 dark:border-gray-700 pt-6">
                <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider block mb-2">Nội dung đánh giá</span>
                <p id="modalComment" class="text-gray-700 dark:text-gray-300 whitespace-pre-wrap p-4 bg-gray-50 dark:bg-gray-900/50 rounded-lg border border-gray-200 dark:border-gray-700 leading-relaxed"></p>
            </div>

            <div id="modalImagesContainer" class="border-t border-gray-100 dark:border-gray-700 pt-6 hidden">
                <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider block mb-3">Hình ảnh đính kèm</span>
                <div id="modalImages" class="grid grid-cols-2 sm:grid-cols-3 gap-3"></div>
            </div>
        </div>
        <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 flex justify-end">
            <button type="button" onclick="closeReviewDetails()" class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">Đóng</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showReviewDetails(customer, email, phone, product, rating, comment, date, images) {
            document.getElementById('modalCustomerName').textContent = customer;
            let contactInfo = [];
            if (email) contactInfo.push(email);
            if (phone) contactInfo.push(phone);
            document.getElementById('modalCustomerContact').textContent = contactInfo.join(' - ');
            
            document.getElementById('modalProductName').textContent = product;
            document.getElementById('modalDate').textContent = date;
            
            // Set rating
            const ratingContainer = document.getElementById('modalRating');
            ratingContainer.innerHTML = '';
            for (let i = 1; i <= 5; i++) {
                const icon = document.createElement('span');
                icon.className = 'material-symbols-outlined text-[24px]';
                icon.style.fontVariationSettings = i <= rating ? "'FILL' 1" : "'FILL' 0";
                icon.textContent = 'star';
                ratingContainer.appendChild(icon);
            }
            
            // Set comment
            document.getElementById('modalComment').textContent = comment || 'Không có bình luận.';
            
            // Set images
            const imagesContainer = document.getElementById('modalImagesContainer');
            const imagesDiv = document.getElementById('modalImages');
            imagesDiv.innerHTML = '';
            
            if (images && images.length > 0) {
                imagesContainer.classList.remove('hidden');
                images.forEach(img => {
                    const a = document.createElement('a');
                    a.href = img;
                    a.target = '_blank';
                    a.className = 'block rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 shadow-sm hover:opacity-80 transition-opacity';
                    
                    const el = document.createElement('img');
                    el.src = img;
                    el.className = 'w-full h-32 object-cover';
                    
                    a.appendChild(el);
                    imagesDiv.appendChild(a);
                });
            } else {
                imagesContainer.classList.add('hidden');
            }
            
            // Show modal
            const modal = document.getElementById('reviewDetailsModal');
            const modalContent = modal.querySelector('div');
            modal.classList.remove('hidden');
            // Small delay for transition to work
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            }, 10);
        }
        
        function closeReviewDetails() {
            const modal = document.getElementById('reviewDetailsModal');
            const modalContent = modal.querySelector('div');
            
            modal.classList.add('opacity-0');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }
    </script>
}
