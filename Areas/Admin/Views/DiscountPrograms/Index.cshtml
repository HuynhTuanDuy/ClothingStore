@using ClothingStore.Models.Entities
@using ClothingStore.Models.ViewModels
@model IEnumerable<DiscountProgram>
@{
    ViewData["Title"] = "Quản lý Chương trình giảm giá";
    var stats = ViewBag.Stats as DiscountProgramDashboardStats;
    var filter = ViewBag.CurrentFilter as DiscountProgramFilter;
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <style>
        .font-headline-lg { font-family: 'Playfair Display', serif; }
        .font-headline-md { font-family: 'Playfair Display', serif; }
        .font-display-lg { font-family: 'Playfair Display', serif; }
        .font-label-caps { text-transform: uppercase; letter-spacing: 0.1em; }
    </style>
}

<!-- Header Section -->
<header class="flex justify-between items-end mb-12">
    <div>
        <nav class="flex items-center gap-2 mb-2">
            <span class="font-label-caps text-[10px] text-outline">ADMIN</span>
            <span class="material-symbols-outlined text-[12px] text-outline">chevron_right</span>
            <span class="font-label-caps text-[10px] text-primary">KHUYẾN MÃI</span>
        </nav>
        <h2 class="font-headline-lg text-[40px] leading-[48px] font-semibold text-primary">Chương trình giảm giá</h2>
    </div>
    <a asp-action="Create" class="bg-primary-container text-on-primary px-8 py-4 font-label-caps text-[12px] font-semibold tracking-[0.1em] hover:bg-primary transition-all duration-300 shadow-sm active:scale-95 inline-block">
        TẠO CHƯƠNG TRÌNH MỚI
    </a>
</header>

<!-- Stats Widgets (Top) -->
<section class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
    <!-- Total Programs -->
    <div class="bg-surface border border-outline-variant p-6 flex flex-col justify-between h-40 rounded-sm">
        <div class="flex justify-between items-start">
            <span class="font-label-caps text-[12px] font-semibold tracking-[0.1em] text-outline">TỔNG CHƯƠNG TRÌNH</span>
            <span class="material-symbols-outlined text-outline">list_alt</span>
        </div>
        <div class="flex items-baseline gap-2">
            <span class="font-display-lg text-[48px] leading-tight font-bold">@(stats?.TotalPrograms ?? 0)</span>
        </div>
    </div>
    <!-- Active Programs -->
    <div class="bg-surface border border-outline-variant p-6 flex flex-col justify-between h-40 rounded-sm">
        <div class="flex justify-between items-start">
            <span class="font-label-caps text-[12px] font-semibold tracking-[0.1em] text-outline">ĐANG HOẠT ĐỘNG</span>
            <span class="material-symbols-outlined text-outline">local_activity</span>
        </div>
        <div class="flex items-baseline gap-2">
            <span class="font-display-lg text-[48px] leading-tight font-bold text-secondary">@(stats?.ActivePrograms ?? 0)</span>
        </div>
    </div>
    <!-- Upcoming Programs -->
    <div class="bg-surface border border-outline-variant p-6 flex flex-col justify-between h-40 rounded-sm">
        <div class="flex justify-between items-start">
            <span class="font-label-caps text-[12px] font-semibold tracking-[0.1em] text-outline">SẮP DIỄN RA</span>
            <span class="material-symbols-outlined text-outline">schedule</span>
        </div>
        <div>
            <span class="font-display-lg text-[48px] leading-tight font-bold text-primary">@(stats?.UpcomingPrograms ?? 0)</span>
        </div>
    </div>
    <!-- Expired Programs -->
    <div class="bg-surface border border-outline-variant p-6 flex flex-col justify-between h-40 rounded-sm">
        <div class="flex justify-between items-start">
            <span class="font-label-caps text-[12px] font-semibold tracking-[0.1em] text-outline">ĐÃ HẾT HẠN</span>
            <span class="material-symbols-outlined text-outline">history</span>
        </div>
        <div class="flex items-center gap-4">
            <span class="font-display-lg text-[48px] leading-tight font-bold text-error">@(stats?.ExpiredPrograms ?? 0)</span>
        </div>
    </div>
</section>

<!-- Main Section: Table & Filters -->
<section class="bg-surface border border-outline-variant rounded-sm">
    <!-- Table Header / Filters -->
    <div class="p-6 border-b border-outline-variant flex flex-wrap gap-4 items-center justify-between">
        <form method="get" class="flex items-center gap-4 flex-1 max-w-xl">
            <div class="relative flex-1">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">search</span>
                <input name="SearchKeyword" value="@filter?.SearchKeyword" class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 pl-10 py-2 font-body-md text-sm transition-all outline-none" placeholder="Tìm kiếm tên chương trình..." type="text"/>
            </div>
            <select name="Status" onchange="this.form.submit()" class="bg-transparent border-none font-label-caps text-[11px] font-semibold tracking-[0.1em] text-outline cursor-pointer focus:ring-0 uppercase">
                <option value="">Trạng thái: Tất cả</option>
                <option value="Active" selected="@(filter?.Status == "Active")">Đang hoạt động</option>
                <option value="Inactive" selected="@(filter?.Status == "Inactive")">Ngừng kích hoạt</option>
                <option value="Upcoming" selected="@(filter?.Status == "Upcoming")">Sắp diễn ra</option>
                <option value="Expired" selected="@(filter?.Status == "Expired")">Hết hạn</option>
            </select>
            <noscript><button type="submit" class="hidden"></button></noscript>
        </form>
        <div class="flex items-center gap-2">
            <a asp-action="Index" class="p-2 text-outline hover:text-primary transition-colors text-[12px] uppercase tracking-widest font-semibold" title="Xóa bộ lọc">
                Xóa lọc
            </a>
        </div>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-outline-variant">
                    <th class="px-6 py-4 font-label-caps text-[12px] font-semibold tracking-[0.1em] text-outline">TÊN CHƯƠNG TRÌNH</th>
                    <th class="px-6 py-4 font-label-caps text-[12px] font-semibold tracking-[0.1em] text-outline">MỨC GIẢM</th>
                    <th class="px-6 py-4 font-label-caps text-[12px] font-semibold tracking-[0.1em] text-outline">THỜI GIAN</th>
                    <th class="px-6 py-4 font-label-caps text-[12px] font-semibold tracking-[0.1em] text-outline">TRẠNG THÁI</th>
                    <th class="px-6 py-4 font-label-caps text-[12px] font-semibold tracking-[0.1em] text-outline text-right">THAO TÁC</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/30">
                @foreach (var item in Model)
                {
                    var today = DateTime.Today;
                    var isExpired = item.EndDate.Date < today;
                    var isScheduled = item.StartDate.Date > today;
                    
                    var statusColor = "bg-secondary/10 text-secondary";
                    var dotColor = "bg-secondary";
                    var statusText = "ĐANG HOẠT ĐỘNG";
                    
                    if (isExpired) {
                        statusColor = "bg-error/5 text-error opacity-60";
                        dotColor = "bg-error";
                        statusText = "HẾT HẠN";
                    } else if (isScheduled && item.IsActive) {
                        statusColor = "bg-surface-container-high text-outline";
                        dotColor = "bg-outline";
                        statusText = "SẮP DIỄN RA";
                    } else if (!item.IsActive) {
                        statusColor = "bg-surface-container-high text-outline";
                        dotColor = "bg-outline";
                        statusText = "VÔ HIỆU HÓA";
                    }

                    <tr class="hover:bg-surface-container-lowest transition-colors group">
                        <td class="px-6 py-5">
                            <span class="font-body-md font-semibold tracking-wider @(isExpired ? "text-outline" : "text-primary")">@item.ProgramName</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="font-body-md @(isExpired ? "text-outline" : "text-on-surface")">
                                Giảm @item.DiscountPercent%
                            </span>
                        </td>
                        <td class="px-6 py-5">
                            <div class="font-body-sm @(isExpired ? "text-outline" : "text-on-surface-variant")">
                                @item.StartDate.AddHours(7).ToString("HH:mm dd/MM/yyyy") - @item.EndDate.AddHours(7).ToString("HH:mm dd/MM/yyyy")
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full @statusColor font-label-caps text-[10px] font-semibold tracking-[0.1em]">
                                <span class="w-1.5 h-1.5 rounded-full @dotColor"></span>
                                @statusText
                            </span>
                        </td>
                        <td class="px-6 py-5 text-right">
                            <div class="flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a asp-action="Edit" asp-route-id="@item.ProgramID" class="text-outline hover:text-primary">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </a>
                                <form asp-action="Toggle" asp-route-id="@item.ProgramID" method="post" class="inline" onsubmit="return confirm('Bạn có chắc muốn đổi trạng thái chương trình này?');">
                                    <button type="submit" class="text-outline hover:text-error" title="@(item.IsActive ? "Khóa" : "Mở khóa")">
                                        <span class="material-symbols-outlined text-[18px]">@(item.IsActive ? "lock" : "lock_open")</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-outline font-body-md">
                            Không tìm thấy chương trình giảm giá nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination (Placeholder for UI) -->
    <div class="p-6 border-t border-outline-variant flex justify-between items-center font-label-caps text-[11px] font-semibold tracking-[0.1em] text-outline">
        <span>HIỂN THỊ @Model.Count() KẾT QUẢ</span>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('tbody tr').forEach(row => {
            row.addEventListener('mouseenter', () => {
                row.style.transform = 'translateX(4px)';
                row.style.transition = 'transform 0.2s ease-out';
            });
            row.addEventListener('mouseleave', () => {
                row.style.transform = 'translateX(0)';
            });
        });
    </script>
}
