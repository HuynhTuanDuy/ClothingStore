@model VariantEditViewModel

<form asp-action="@(Model.VariantID == 0 ? "CreateVariant" : "EditVariant")" method="post" class="admin-panel">
    @Html.AntiForgeryToken()
    <input asp-for="VariantID" type="hidden" />
    <input asp-for="ProductID" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <div class="text-muted small">Product</div>
        <div class="fw-semibold">@Model.ProductName</div>
    </div>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="SKU" class="form-label"></label>
            <input asp-for="SKU" class="form-control" />
            <span asp-validation-for="SKU" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="SizeID" class="form-label">Size</label>
            <select asp-for="SizeID" asp-items="Model.Sizes" class="form-select"></select>
            <span asp-validation-for="SizeID" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="ColorID" class="form-label">Color</label>
            <select asp-for="ColorID" asp-items="Model.Colors" class="form-select"></select>
            <span asp-validation-for="ColorID" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="SellingPrice" class="form-label"></label>
            <input asp-for="SellingPrice" class="form-control" />
            <span asp-validation-for="SellingPrice" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="StockQuantity" class="form-label"></label>
            <input asp-for="StockQuantity" class="form-control" />
            <span asp-validation-for="StockQuantity" class="text-danger"></span>
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
    </div>
    <div class="d-flex justify-content-between mt-4">
        <a class="btn btn-outline-dark" asp-action="Variants" asp-route-id="@Model.ProductID">Back</a>
        <button class="btn btn-dark" type="submit">Save variant</button>
    </div>
</form>
