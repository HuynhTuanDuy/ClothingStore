@model ClothingStore.Models.ViewModels.VariantEditViewModel

<form asp-action="@(Model.VariantID == 0 ? "CreateVariant" : "EditVariant")" method="post" class="max-w-4xl mx-auto w-full">
    @Html.AntiForgeryToken()
    <input asp-for="VariantID" type="hidden" />
    <input asp-for="ProductID" type="hidden" />
    
    <!-- Page Header -->
    <div class="mb-10 flex items-end justify-between">
        <div>
            <a asp-action="Variants" asp-route-id="@Model.ProductID" class="inline-flex items-center text-on-surface-variant hover:text-primary transition-colors font-label-caps text-label-caps mb-4">
                <span class="material-symbols-outlined text-sm mr-1">arrow_back</span>
                Trở lại danh sách
            </a>
            <h2 class="font-headline-lg text-headline-lg text-on-background">
                @(Model.VariantID == 0 ? "Thêm biến thể mới" : "Chỉnh sửa biến thể")
            </h2>
            <p class="font-body-md text-on-surface-variant mt-2">Sản phẩm: <span class="font-semibold text-primary">@Model.ProductName</span></p>
        </div>
        <div class="flex gap-4">
            <a asp-action="Variants" asp-route-id="@Model.ProductID" class="border border-primary text-primary px-6 py-2.5 font-label-caps text-label-caps rounded-DEFAULT hover:bg-surface-container transition-colors">
                Hủy
            </a>
            <button type="submit" class="bg-primary text-on-primary px-6 py-2.5 font-label-caps text-label-caps rounded-DEFAULT hover:bg-on-primary-fixed-variant transition-colors flex items-center gap-2 shadow-sm uppercase tracking-widest">
                Lưu biến thể
                <span class="material-symbols-outlined text-[18px]">save</span>
            </button>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-6">
            <div asp-validation-summary="ModelOnly" class="text-sm"></div>
        </div>
    }

    <div class="bg-surface rounded-xl p-8 border border-outline-variant shadow-sm mb-8">
        <h3 class="font-headline-md text-on-background mb-6">Thông tin biến thể</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- SKU -->
            <div class="col-span-2 md:col-span-1">
                <label asp-for="SKU" class="block font-label-caps text-label-caps text-on-surface-variant mb-2 uppercase tracking-widest">SKU (Mã lưu kho)</label>
                <input asp-for="SKU" class="w-full bg-surface-container-low border border-outline-variant rounded p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="VD: SM-TRANG-M" />
                <span asp-validation-for="SKU" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- Empty space for grid alignment -->
            <div class="hidden md:block"></div>

            <!-- Size -->
            <div>
                <label asp-for="SizeID" class="block font-label-caps text-label-caps text-on-surface-variant mb-2 uppercase tracking-widest">Kích thước</label>
                <select asp-for="SizeID" asp-items="Model.Sizes" class="w-full bg-surface-container-low border border-outline-variant rounded p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary transition-colors"></select>
                <span asp-validation-for="SizeID" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- Color -->
            <div>
                <label asp-for="ColorID" class="block font-label-caps text-label-caps text-on-surface-variant mb-2 uppercase tracking-widest">Màu sắc</label>
                <select asp-for="ColorID" asp-items="Model.Colors" class="w-full bg-surface-container-low border border-outline-variant rounded p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary transition-colors"></select>
                <span asp-validation-for="ColorID" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- Selling Price -->
            <div>
                <label asp-for="SellingPrice" class="block font-label-caps text-label-caps text-on-surface-variant mb-2 uppercase tracking-widest">Giá bán (₫)</label>
                <input asp-for="SellingPrice" type="number" step="1000" class="w-full bg-surface-container-low border border-outline-variant rounded p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="SellingPrice" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- Stock Quantity -->
            <div>
                <label asp-for="StockQuantity" class="block font-label-caps text-label-caps text-on-surface-variant mb-2 uppercase tracking-widest">Tồn kho</label>
                <input asp-for="StockQuantity" type="number" class="w-full bg-surface-container-low border border-outline-variant rounded p-3 text-body-md focus:border-primary focus:ring-1 focus:ring-primary transition-colors" />
                <span asp-validation-for="StockQuantity" class="text-error text-xs mt-1 block"></span>
            </div>

            <!-- IsActive Toggle -->
            <div class="col-span-2 mt-4">
                <label class="flex items-center gap-3 cursor-pointer">
                    <div class="relative">
                        <input asp-for="IsActive" type="checkbox" class="sr-only peer" />
                        <div class="w-11 h-6 bg-surface-dim peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </div>
                    <span class="font-body-md text-on-background font-medium">Trạng thái (Đang hoạt động)</span>
                </label>
            </div>
        </div>
    </div>
</form>
