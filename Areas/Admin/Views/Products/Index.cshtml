@model ClothingStore.Models.ViewModels.AdminProductPageViewModel
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var f = Model.Filter;
    
    // Helper to generate sort link
    string GetSortUrl(string sortBy)
    {
        var isDesc = (f.SortBy == sortBy) ? !f.SortDesc : false;
        if (f.SortBy == sortBy && f.SortDesc == false) {
            sortBy = ""; // third click = default
        }
        return Url.Action("Index", new { 
            Search = f.Search, CategoryId = f.CategoryId, Status = f.Status, 
            StockStatus = f.StockStatus, MinPrice = f.MinPrice, MaxPrice = f.MaxPrice,
            HasDiscount = f.HasDiscount, DateFrom = f.DateFrom, DateTo = f.DateTo,
            SortBy = sortBy, SortDesc = isDesc, PageSize = f.PageSize 
        }) ?? "";
    }

    string GetSortIcon(string sortBy)
    {
        if (f.SortBy != sortBy) return "↕";
        return f.SortDesc ? "↓" : "↑";
    }
}

@section Styles {
    <style>
        .table-sortable th { cursor: pointer; user-select: none; }
        .table-sortable th:hover { color: var(--color-primary); }
    </style>
}

<!-- Dashboard Stats -->
<div class="grid grid-cols-5 gap-4 mb-8">
    <div class="bg-surface-container p-4 rounded text-center shadow-sm border border-outline-variant">
        <p class="text-xs font-semibold text-on-surface-variant uppercase mb-1">Tổng SP</p>
        <p class="text-2xl font-bold text-primary">@Model.Stats.TotalProducts</p>
    </div>
    <div class="bg-surface-container p-4 rounded text-center shadow-sm border border-outline-variant">
        <p class="text-xs font-semibold text-on-surface-variant uppercase mb-1">Hoạt động</p>
        <p class="text-2xl font-bold text-green-600">@Model.Stats.ActiveProducts</p>
    </div>
    <div class="bg-surface-container p-4 rounded text-center shadow-sm border border-outline-variant">
        <p class="text-xs font-semibold text-on-surface-variant uppercase mb-1">Bị ẩn</p>
        <p class="text-2xl font-bold text-gray-500">@Model.Stats.InactiveProducts</p>
    </div>
    <div class="bg-surface-container p-4 rounded text-center shadow-sm border border-outline-variant">
        <p class="text-xs font-semibold text-on-surface-variant uppercase mb-1">Hết hàng</p>
        <p class="text-2xl font-bold text-red-600">@Model.Stats.OutOfStockProducts</p>
    </div>
    <div class="bg-surface-container p-4 rounded text-center shadow-sm border border-outline-variant">
        <p class="text-xs font-semibold text-on-surface-variant uppercase mb-1">Sắp hết</p>
        <p class="text-2xl font-bold text-orange-500">@Model.Stats.LowStockProducts</p>
    </div>
</div>

<!-- Header & Export Buttons -->
<div class="flex justify-between items-end mb-8">
    <div>
        <p class="text-sm text-on-surface-variant uppercase tracking-wider mb-2 font-medium">Kho hàng</p>
        <h3 class="font-headline-lg text-[40px] leading-[48px] font-semibold text-primary mb-2">Quản lý sản phẩm</h3>
    </div>
    <div class="flex items-center gap-4">
        <a href="@Url.Action("ExportExcel", new { Search = f.Search, CategoryId = f.CategoryId, Status = f.Status, StockStatus = f.StockStatus, MinPrice = f.MinPrice, MaxPrice = f.MaxPrice, HasDiscount = f.HasDiscount, DateFrom = f.DateFrom, DateTo = f.DateTo, SortBy = f.SortBy, SortDesc = f.SortDesc })" class="text-primary font-label-caps text-label-caps flex items-center gap-1 hover:underline border border-outline-variant px-4 py-2 rounded">
            Xuất Excel <span class="material-symbols-outlined text-sm" data-icon="download">download</span>
        </a>
        <a asp-action="Create" class="bg-primary text-white text-sm font-semibold uppercase tracking-wider px-6 py-3 rounded hover:bg-primary/90 transition-colors shadow-sm">
            THÊM SẢN PHẨM MỚI
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="bg-green-100 text-green-800 p-4 rounded mb-6 text-sm font-medium">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-100 text-red-800 p-4 rounded mb-6 text-sm font-medium">
        @TempData["Error"]
    </div>
}

<!-- Advanced Filters -->
<form method="get" asp-action="Index" id="filterForm" class="bg-surface-container p-6 rounded shadow-sm mb-8 border border-outline-variant">
    <div class="grid grid-cols-4 gap-4 mb-4">
        <div>
            <label class="text-xs uppercase text-on-surface-variant block mb-1">Tìm kiếm</label>
            <input type="text" name="Search" value="@f.Search" placeholder="Tên, SKU..." class="w-full bg-background border border-outline-variant p-2 text-sm rounded focus:border-primary">
        </div>
        <div>
            <label class="text-xs uppercase text-on-surface-variant block mb-1">Danh mục</label>
            <select name="CategoryId" class="w-full bg-background border border-outline-variant p-2 text-sm rounded focus:border-primary" asp-items="ViewBag.ParentCategories">
                <option value="">-- Tất cả --</option>
            </select>
        </div>
        <div>
            <label class="text-xs uppercase text-on-surface-variant block mb-1">Trạng thái</label>
            <select name="Status" class="w-full bg-background border border-outline-variant p-2 text-sm rounded focus:border-primary">
                <option value="" selected="@(string.IsNullOrEmpty(f.Status))">-- Tất cả --</option>
                <option value="active" selected="@(f.Status=="active")">Đang hoạt động</option>
                <option value="inactive" selected="@(f.Status=="inactive")">Bị ẩn</option>
            </select>
        </div>
        <div>
            <label class="text-xs uppercase text-on-surface-variant block mb-1">Tồn kho</label>
            <select name="StockStatus" class="w-full bg-background border border-outline-variant p-2 text-sm rounded focus:border-primary">
                <option value="" selected="@(string.IsNullOrEmpty(f.StockStatus))">-- Tất cả --</option>
                <option value="instock" selected="@(f.StockStatus=="instock")">Còn hàng</option>
                <option value="outofstock" selected="@(f.StockStatus=="outofstock")">Hết hàng</option>
                <option value="lowstock" selected="@(f.StockStatus=="lowstock")">Sắp hết hàng</option>
            </select>
        </div>
        <div>
            <label class="text-xs uppercase text-on-surface-variant block mb-1">Giá từ</label>
            <input type="number" name="MinPrice" value="@f.MinPrice" class="w-full bg-background border border-outline-variant p-2 text-sm rounded focus:border-primary">
        </div>
        <div>
            <label class="text-xs uppercase text-on-surface-variant block mb-1">Giá đến</label>
            <input type="number" name="MaxPrice" value="@f.MaxPrice" class="w-full bg-background border border-outline-variant p-2 text-sm rounded focus:border-primary">
        </div>
        <div>
            <label class="text-xs uppercase text-on-surface-variant block mb-1">Khuyến mãi</label>
            <select name="HasDiscount" class="w-full bg-background border border-outline-variant p-2 text-sm rounded focus:border-primary">
                <option value="" selected="@(string.IsNullOrEmpty(f.HasDiscount))">-- Tất cả --</option>
                <option value="yes" selected="@(f.HasDiscount=="yes")">Có khuyến mãi</option>
                <option value="no" selected="@(f.HasDiscount=="no")">Không có KM</option>
            </select>
        </div>
        <div class="flex items-end gap-2">
            <button type="submit" class="bg-primary text-white text-sm px-4 py-2 rounded">Lọc</button>
            <a href="@Url.Action("Index")" class="bg-outline-variant text-on-surface text-sm px-4 py-2 rounded hover:bg-gray-300">Xóa bộ lọc</a>
        </div>
    </div>
    <input type="hidden" name="SortBy" value="@f.SortBy" />
    <input type="hidden" name="SortDesc" value="@(f.SortDesc.ToString().ToLower())" />
    <input type="hidden" name="PageSize" value="@f.PageSize" />
</form>

<!-- Bulk Actions -->
<form method="post" asp-action="BulkAction" id="bulkForm">
    <div id="bulkActions" class="hidden bg-surface-container-low p-3 mb-4 rounded flex gap-4 items-center shadow border border-outline-variant">
        <span class="text-sm font-semibold ml-2"><span id="selectedCount">0</span> SP đang chọn:</span>
        <button type="submit" name="actionType" value="activate" class="text-sm bg-green-600 text-white px-3 py-1.5 rounded hover:bg-green-700">Kích hoạt</button>
        <button type="submit" name="actionType" value="deactivate" class="text-sm bg-gray-500 text-white px-3 py-1.5 rounded hover:bg-gray-600">Vô hiệu hóa</button>
        <button type="submit" name="actionType" value="delete" class="text-sm bg-red-600 text-white px-3 py-1.5 rounded hover:bg-red-700" onclick="return confirm('Bạn có chắc chắn muốn xóa mềm các sản phẩm này?')">Xóa mềm</button>
        <select name="categoryId" class="text-sm border border-outline-variant p-1.5 rounded" asp-items="ViewBag.ParentCategories">
            <option value="">-- Chuyển danh mục --</option>
        </select>
        <button type="submit" name="actionType" value="changeCategory" class="text-sm bg-blue-600 text-white px-3 py-1.5 rounded hover:bg-blue-700" onclick="return confirm('Bạn muốn chuyển danh mục?')">Đổi Danh Mục</button>
    </div>

    <!-- Product Table -->
    <div class="w-full text-left overflow-x-auto bg-surface-container rounded border border-outline-variant shadow-sm">
        <table class="w-full table-sortable">
            <thead>
                <tr class="border-b border-outline-variant/50 text-xs font-semibold uppercase tracking-wider text-on-surface-variant text-left bg-surface-container-low">
                    <th class="py-3 px-4 w-8"><input type="checkbox" id="selectAll" /></th>
                    <th class="py-3 px-2"><a href="@GetSortUrl("name")">Sản phẩm @GetSortIcon("name")</a></th>
                    <th class="py-3 px-2"><a href="@GetSortUrl("category")">Danh mục @GetSortIcon("category")</a></th>
                    <th class="py-3 px-2"><a href="@GetSortUrl("price")">Giá @GetSortIcon("price")</a></th>
                    <th class="py-3 px-2 text-center"><a href="@GetSortUrl("stock")">Tồn kho @GetSortIcon("stock")</a></th>
                    <th class="py-3 px-2 text-center"><a href="@GetSortUrl("sold")">Đã bán @GetSortIcon("sold")</a></th>
                    <th class="py-3 px-2 text-center"><a href="@GetSortUrl("status")">Trạng thái @GetSortIcon("status")</a></th>
                    <th class="py-3 px-2"><a href="@GetSortUrl("created")">Ngày tạo @GetSortIcon("created")</a></th>
                    <th class="py-3 px-4 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Products.Any())
                {
                    <tr><td colspan="9" class="py-12 text-center text-on-surface-variant font-medium">Không tìm thấy sản phẩm nào phù hợp.</td></tr>
                }
                @foreach (var p in Model.Products)
                {
                    <tr class="border-b border-outline-variant/30 hover:bg-surface-container/30 transition-colors bg-background">
                        <td class="py-3 px-4"><input type="checkbox" name="productIds" value="@p.ProductID" class="row-chk" /></td>
                        <td class="py-3 px-2 flex items-center gap-3">
                            <div class="w-12 h-12 bg-surface-container-low rounded flex items-center justify-center overflow-hidden shrink-0 border border-outline-variant">
                                @if (string.IsNullOrEmpty(p.ThumbnailUrl))
                                {
                                    <span class="text-[10px] text-center text-on-surface-variant opacity-50 uppercase font-medium">Chưa có<br/>hình ảnh</span>
                                }
                                else
                                {
                                    <img src="@p.ThumbnailUrl" class="w-full h-full object-cover" />
                                }
                            </div>
                            <div>
                                <a asp-action="Edit" asp-route-id="@p.ProductID" class="font-medium text-on-background hover:text-primary transition-colors">@p.ProductName</a>
                                <div class="text-xs text-on-surface-variant mt-1">SKU: @(string.IsNullOrEmpty(p.SKU) ? "N/A" : p.SKU)</div>
                            </div>
                        </td>
                        <td class="py-3 px-2 text-sm text-on-surface-variant">@p.CategoryName</td>
                        <td class="py-3 px-2 text-sm font-medium">
                            @if (p.MinPrice == p.MaxPrice) {
                                <span>@p.MinPrice.ToString("N0")đ</span>
                            } else {
                                <span>@p.MinPrice.ToString("N0") - @p.MaxPrice.ToString("N0")đ</span>
                            }
                        </td>
                        <td class="py-3 px-2 text-center text-sm @(p.TotalStock == 0 ? "text-red-600 font-bold" : (p.TotalStock <= 5 ? "text-orange-500 font-bold" : "text-on-surface-variant"))">
                            @p.TotalStock
                        </td>
                        <td class="py-3 px-2 text-center text-sm text-on-surface-variant font-medium">@p.TotalSold</td>
                        <td class="py-3 px-2 text-center">
                            @if (p.IsActive) {
                                <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded font-medium border border-green-200">Hoạt động</span>
                            } else {
                                <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded font-medium border border-gray-200">Bị ẩn</span>
                            }
                        </td>
                        <td class="py-3 px-2 text-sm text-on-surface-variant">@p.CreatedAt?.AddHours(7).ToString("HH:mm dd/MM/yyyy")</td>
                        <td class="py-3 px-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a asp-action="Edit" asp-route-id="@p.ProductID" class="text-on-surface-variant hover:text-primary transition-colors" title="Sửa"><span class="material-symbols-outlined text-[20px]">edit</span></a>
                                <button type="submit" asp-action="Duplicate" asp-route-id="@p.ProductID" class="text-on-surface-variant hover:text-primary transition-colors" title="Nhân bản" onclick="return confirm('Bạn muốn nhân bản sản phẩm này?')"><span class="material-symbols-outlined text-[20px]">content_copy</span></button>
                                <button type="submit" asp-action="Delete" asp-route-id="@p.ProductID" class="text-on-surface-variant hover:text-red-600 transition-colors" title="Xóa mềm" onclick="return confirm('Xóa mềm sản phẩm?')"><span class="material-symbols-outlined text-[20px]">delete</span></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</form>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-between mt-6 border-t border-outline-variant pt-6">
        <div class="text-sm text-on-surface-variant">
            Hiển thị <span class="font-medium text-on-background">@((f.Page - 1) * f.PageSize + 1)</span> - 
            <span class="font-medium text-on-background">@(Math.Min(f.Page * f.PageSize, Model.TotalCount))</span> 
            trong số <span class="font-medium text-on-background">@Model.TotalCount</span> sản phẩm
        </div>
        
        <div class="flex items-center gap-4">
            <!-- Page Size Dropdown -->
            <div class="flex items-center gap-2 text-sm">
                <span>Số dòng:</span>
                <select id="pageSizeSelect" class="bg-transparent border border-outline-variant rounded p-1 text-sm focus:border-primary">
                    <option value="10" selected="@(f.PageSize == 10)">10</option>
                    <option value="25" selected="@(f.PageSize == 25)">25</option>
                    <option value="50" selected="@(f.PageSize == 50)">50</option>
                    <option value="100" selected="@(f.PageSize == 100)">100</option>
                </select>
            </div>

            <div class="flex gap-2">
                @if (f.Page > 1)
                {
                    <a href="@Url.Action("Index", new { Search = f.Search, CategoryId = f.CategoryId, Status = f.Status, StockStatus = f.StockStatus, MinPrice = f.MinPrice, MaxPrice = f.MaxPrice, HasDiscount = f.HasDiscount, DateFrom = f.DateFrom, DateTo = f.DateTo, SortBy = f.SortBy, SortDesc = f.SortDesc, Page = f.Page - 1, PageSize = f.PageSize })" class="w-10 h-10 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant hover:bg-surface-container hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">chevron_left</span></a>
                }

                @for (int i = Math.Max(1, f.Page - 2); i <= Math.Min(Model.TotalPages, f.Page + 2); i++)
                {
                    <a href="@Url.Action("Index", new { Search = f.Search, CategoryId = f.CategoryId, Status = f.Status, StockStatus = f.StockStatus, MinPrice = f.MinPrice, MaxPrice = f.MaxPrice, HasDiscount = f.HasDiscount, DateFrom = f.DateFrom, DateTo = f.DateTo, SortBy = f.SortBy, SortDesc = f.SortDesc, Page = i, PageSize = f.PageSize })" 
                       class="w-10 h-10 flex items-center justify-center rounded-full text-sm font-medium transition-colors @(i == f.Page ? "bg-primary text-white border-primary" : "border border-outline-variant text-on-surface-variant hover:bg-surface-container hover:text-primary")">
                        @i
                    </a>
                }

                @if (f.Page < Model.TotalPages)
                {
                    <a href="@Url.Action("Index", new { Search = f.Search, CategoryId = f.CategoryId, Status = f.Status, StockStatus = f.StockStatus, MinPrice = f.MinPrice, MaxPrice = f.MaxPrice, HasDiscount = f.HasDiscount, DateFrom = f.DateFrom, DateTo = f.DateTo, SortBy = f.SortBy, SortDesc = f.SortDesc, Page = f.Page + 1, PageSize = f.PageSize })" class="w-10 h-10 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant hover:bg-surface-container hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">chevron_right</span></a>
                }
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Handle select all checkbox
        const selectAll = document.getElementById('selectAll');
        const rowCheckboxes = document.querySelectorAll('.row-chk');
        const bulkActions = document.getElementById('bulkActions');
        const selectedCount = document.getElementById('selectedCount');

        function updateBulkActions() {
            const count = Array.from(rowCheckboxes).filter(c => c.checked).length;
            selectedCount.textContent = count;
            if (count > 0) {
                bulkActions.classList.remove('hidden');
            } else {
                bulkActions.classList.add('hidden');
            }
        }

        if (selectAll) {
            selectAll.addEventListener('change', function () {
                rowCheckboxes.forEach(c => c.checked = this.checked);
                updateBulkActions();
            });
        }

        rowCheckboxes.forEach(c => c.addEventListener('change', function () {
            if (!this.checked) selectAll.checked = false;
            updateBulkActions();
        }));

        // Handle PageSize change
        const pageSizeSelect = document.getElementById('pageSizeSelect');
        if (pageSizeSelect) {
            pageSizeSelect.addEventListener('change', function() {
                document.querySelector('input[name="PageSize"]').value = this.value;
                document.getElementById('filterForm').submit();
            });
        }
    </script>
}
