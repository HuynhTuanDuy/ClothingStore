@model ClothingStore.Models.ViewModels.ProductEditViewModel
@{
    ViewData["Title"] = "Thuộc tính sản phẩm";
}

<div class="max-w-5xl mx-auto w-full">
    <!-- Page Header -->
    <div class="mb-10 flex items-end justify-between">
        <div>
            <a asp-action="Index" class="inline-flex items-center text-on-surface-variant hover:text-primary transition-colors font-label-caps text-label-caps mb-4">
                <span class="material-symbols-outlined text-sm mr-1">arrow_back</span>
                Back to Products
            </a>
            <h2 class="font-headline-lg text-headline-lg text-on-background">@(Model?.ProductID == 0 ? "Thêm sản phẩm" : "Cập nhật sản phẩm")</h2>
        </div>
        <div class="flex gap-4">
            <a asp-action="Index" class="border border-primary text-primary px-6 py-2.5 font-label-caps text-label-caps rounded-DEFAULT hover:bg-surface-container transition-colors">
                Hủy
            </a>
            <!-- Note: Form submission is not fully wired yet -->
            <button type="submit" class="bg-primary text-on-primary px-6 py-2.5 font-label-caps text-label-caps rounded-DEFAULT hover:bg-on-primary-fixed-variant transition-colors flex items-center gap-2 shadow-sm uppercase tracking-widest">
                Lưu thuộc tính
                <span class="material-symbols-outlined text-[18px]">save</span>
            </button>
        </div>
    </div>
    
    <partial name="_ProductTabs" model="Model?.ProductID ?? 0" />

    <div class="mb-12 mt-10">
        <div class="flex justify-between items-end">
            <div>
                <h2 class="font-headline-lg text-headline-lg text-on-background mb-2">Thuộc tính</h2>
                <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">Cấu hình màu sắc, chất liệu và kích thước cho sản phẩm này. Các thuộc tính này sẽ tạo ra các SKU riêng biệt để theo dõi tồn kho.</p>
            </div>
            <!-- Progress Indication -->
            <div class="flex gap-2">
                <div class="w-12 h-1 bg-surface-container rounded-full overflow-hidden">
                    <div class="w-full h-full bg-primary opacity-30"></div>
                </div>
                <div class="w-12 h-1 bg-surface-container rounded-full overflow-hidden">
                    <div class="w-full h-full bg-primary"></div>
                </div>
                <div class="w-12 h-1 bg-surface-container rounded-full"></div>
            </div>
        </div>
    </div>

    <!-- Form Container -->
    <form class="space-y-12">
        <!-- Section: Color Management -->
        <section class="bg-surface rounded-xl border border-outline-variant p-8 shadow-[0_4px_20px_rgba(121,87,63,0.03)] relative overflow-hidden">
            <!-- Decorative subtle gradient -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-secondary-fixed/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4 pointer-events-none"></div>
            <div class="flex justify-between items-start mb-8 relative z-10">
                <div>
                    <h3 class="font-headline-md text-headline-md text-on-background mb-1">Bảng màu</h3>
                    <p class="font-body-sm text-body-sm text-on-surface-variant">Chọn hoặc tạo màu sắc cho biến thể sản phẩm này.</p>
                </div>
            </div>
            <!-- Color Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 relative z-10">
                @foreach(var color in Model.AvailableColors)
                {
                    <label class="cursor-pointer relative block">
                        <input type="checkbox" name="SelectedColors" value="@color.ColorID" class="peer hidden" />
                        <div class="group border border-outline-variant rounded-lg p-4 bg-background transition-all peer-checked:border-blue-500 peer-checked:ring-2 peer-checked:ring-blue-500 hover:border-blue-500/50">
                            <div class="w-full h-24 rounded-md mb-4 shadow-sm swatch-texture" style="background-color: @color.HexCode;"></div>
                            <h4 class="font-body-md text-body-md font-medium text-on-background">@color.ColorName</h4>
                            <p class="font-body-sm text-body-sm text-on-surface-variant mt-1">@color.HexCode</p>
                            
                            <!-- Selection Indicator -->
                            <div class="absolute top-6 right-6 bg-blue-500 text-white rounded-full w-6 h-6 flex items-center justify-center opacity-0 peer-checked:opacity-100 transition-opacity shadow-sm">
                                <span class="material-symbols-outlined" style="font-size: 16px;">check</span>
                            </div>
                        </div>
                    </label>
                }
            </div>
        </section>
        
        <!-- Section: Size Management -->
        <section class="bg-surface rounded-xl border border-outline-variant p-8 shadow-[0_4px_20px_rgba(121,87,63,0.03)]">
            <div class="mb-6">
                <h3 class="font-headline-md text-headline-md text-on-background mb-1">Cấu hình kích thước</h3>
                <p class="font-body-sm text-body-sm text-on-surface-variant">Định nghĩa các kích thước có sẵn. Nhấn enter hoặc dấu phẩy để thêm thẻ mới.</p>
            </div>
            <div class="border-b border-outline-variant pb-6 mb-6">
                <!-- Size Grid -->
                <div class="flex flex-wrap gap-3">
                    @foreach(var size in Model.AvailableSizes)
                    {
                        <label class="cursor-pointer relative inline-block">
                            <input type="checkbox" name="SelectedSizes" value="@size.SizeID" class="peer hidden" />
                            <div class="px-6 py-3 border border-outline-variant rounded-lg bg-surface-container-low transition-all peer-checked:border-blue-500 peer-checked:ring-2 peer-checked:ring-blue-500 peer-checked:bg-blue-50 hover:border-blue-500/50 flex items-center gap-2">
                                <span class="font-body-md text-body-md font-medium text-on-background peer-checked:text-blue-600 transition-colors">@size.SizeCode</span>
                            </div>
                        </label>
                    }
                </div>
            </div>
            <!-- Helper / Recommended Sizing -->
            <div class="bg-surface-container-low rounded-lg p-4 flex gap-4 items-start border border-outline-variant/50">
                <span class="material-symbols-outlined text-secondary mt-0.5">info</span>
                <div>
                    <h4 class="font-body-sm text-body-sm font-medium text-on-background">Kích thước chuẩn Editorial</h4>
                    <p class="font-body-sm text-body-sm text-on-surface-variant mt-1">Cân nhắc tạo hướng dẫn chọn size riêng cho kiểu dáng này. Các form rộng (relaxed) có thể cần ít tùy chọn size hơn.</p>
                </div>
            </div>
        </section>

        <!-- Actions / Navigation -->
        <div class="flex justify-between items-center pt-8 border-t border-outline-variant">
            <a asp-action="@(Model?.ProductID == 0 ? "Create" : "Edit")" asp-route-id="@(Model?.ProductID == 0 ? null : Model?.ProductID)" class="px-6 py-3 border border-outline text-on-surface rounded font-label-caps text-label-caps hover:bg-surface-container transition-colors uppercase tracking-widest flex items-center gap-2">
                <span class="material-symbols-outlined" style="font-size: 18px;">arrow_back</span>
                Trở lại
            </a>
            <a asp-action="Variants" asp-route-id="@Model?.ProductID" class="px-8 py-3 bg-primary text-on-primary rounded font-label-caps text-label-caps hover:bg-primary-container hover:text-on-primary-container transition-colors shadow-sm uppercase tracking-widest flex items-center gap-2">
                Tạo biến thể
                <span class="material-symbols-outlined" style="font-size: 18px;">arrow_forward</span>
            </a>
        </div>
    </form>
</div>

@section Styles {
    <style>
        /* Subtle texture for the color swatches */
        .swatch-texture {
            background-image: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 20 20' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23000000' fill-opacity='0.02' fill-rule='evenodd'%3E%3Ccircle cx='3' cy='3' r='3'/%3E%3Ccircle cx='13' cy='13' r='3'/%3E%3C/g%3E%3C/svg%3E");
        }
    </style>
}
