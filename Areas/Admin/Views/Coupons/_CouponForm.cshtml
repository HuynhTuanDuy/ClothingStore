@using ClothingStore.Models.ViewModels
@model CouponEditViewModel

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div>
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Mã Coupon</label>
        <input asp-for="CouponCode" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white uppercase" />
        <span asp-validation-for="CouponCode" class="text-error text-xs mt-1 block"></span>
    </div>
    <div class="flex items-center pt-8">
        <label class="inline-flex items-center cursor-pointer">
            <input type="checkbox" asp-for="IsActive" class="sr-only peer">
            <div class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/30 dark:peer-focus:ring-primary/80 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary"></div>
            <span class="ms-3 text-sm font-medium text-gray-700 dark:text-gray-300">Cho phép hoạt động</span>
        </label>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div>
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Loại giảm giá</label>
        <select asp-for="DiscountType" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white">
            <option value="Percentage">Phần trăm (%)</option>
            <option value="FixedAmount">Số tiền cố định (VNĐ)</option>
        </select>
        <span asp-validation-for="DiscountType" class="text-error text-xs mt-1 block"></span>
    </div>
    <div>
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Giá trị giảm</label>
        <input asp-for="DiscountValue" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white" type="number" step="0.01" />
        <span asp-validation-for="DiscountValue" class="text-error text-xs mt-1 block"></span>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div>
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Giá trị đơn hàng tối thiểu (VNĐ)</label>
        <input asp-for="MinOrderValue" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white" type="number" step="1000" />
        <span asp-validation-for="MinOrderValue" class="text-error text-xs mt-1 block"></span>
    </div>
    <div>
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Giới hạn số lần sử dụng</label>
        <input asp-for="UsageLimit" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white" type="number" placeholder="Để trống nếu không giới hạn" />
        <span asp-validation-for="UsageLimit" class="text-error text-xs mt-1 block"></span>
        @if(Model.CouponID > 0)
        {
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">Đã sử dụng: <strong class="text-primary font-bold">@Model.UsedCount</strong> lượt</p>
        }
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-6 border-t border-gray-200 dark:border-gray-700">
    <div>
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Ngày bắt đầu</label>
        <input asp-for="ValidFrom" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white" type="date" />
        <span asp-validation-for="ValidFrom" class="text-error text-xs mt-1 block"></span>
    </div>
    <div>
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Ngày kết thúc</label>
        <input asp-for="ValidTo" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white" type="date" />
        <span asp-validation-for="ValidTo" class="text-error text-xs mt-1 block"></span>
    </div>
</div>
