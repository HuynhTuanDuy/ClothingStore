@using ClothingStore.Models.ViewModels
@model CouponEditViewModel

<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label font-weight-bold">Mã Coupon</label>
        <input asp-for="CouponCode" class="form-control" style="text-transform: uppercase" />
        <span asp-validation-for="CouponCode" class="text-danger"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label font-weight-bold">Trạng thái</label>
        <div class="custom-control custom-switch mt-2">
            <input type="checkbox" class="custom-control-input" id="IsActiveSwitch" asp-for="IsActive">
            <label class="custom-control-label" for="IsActiveSwitch">Cho phép hoạt động</label>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label font-weight-bold">Loại giảm giá</label>
        <select asp-for="DiscountType" class="form-control">
            <option value="Percentage">Phần trăm (%)</option>
            <option value="FixedAmount">Số tiền cố định (VNĐ)</option>
        </select>
        <span asp-validation-for="DiscountType" class="text-danger"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label font-weight-bold">Giá trị giảm</label>
        <input asp-for="DiscountValue" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="DiscountValue" class="text-danger"></span>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label font-weight-bold">Giá trị đơn hàng tối thiểu (VNĐ)</label>
        <input asp-for="MinOrderValue" class="form-control" type="number" step="1000" />
        <span asp-validation-for="MinOrderValue" class="text-danger"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label font-weight-bold">Giới hạn số lần sử dụng</label>
        <input asp-for="UsageLimit" class="form-control" type="number" placeholder="Để trống nếu không giới hạn" />
        <span asp-validation-for="UsageLimit" class="text-danger"></span>
        @if(Model.CouponID > 0)
        {
            <small class="text-muted mt-1 d-block">Đã sử dụng: <strong class="text-primary">@Model.UsedCount</strong> lượt</small>
        }
    </div>
</div>

<div class="row border-top pt-3 mt-2">
    <div class="col-md-6 mb-3">
        <label class="form-label font-weight-bold">Ngày bắt đầu</label>
        <input asp-for="ValidFrom" class="form-control" type="date" />
        <span asp-validation-for="ValidFrom" class="text-danger"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label font-weight-bold">Ngày kết thúc</label>
        <input asp-for="ValidTo" class="form-control" type="date" />
        <span asp-validation-for="ValidTo" class="text-danger"></span>
    </div>
</div>
