@using ClothingStore.Models.ViewModels
@model CouponEditViewModel
@{
    ViewData["Title"] = "Thêm mã giảm giá mới";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 text-gray-800">Thêm mã giảm giá mới</h2>
    <a asp-action="Index" class="btn btn-secondary shadow-sm">
        <i class="fas fa-arrow-left fa-sm text-white-50"></i> Quay lại
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <partial name="_CouponForm" model="Model" />
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Tạo mã</button>
            </div>
        </form>
    </div>
</div>
