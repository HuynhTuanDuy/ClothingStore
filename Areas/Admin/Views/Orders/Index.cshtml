@model ClothingStore.Models.ViewModels.AdminOrderListViewModel
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Header & Filter Bar -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-10">
    <div>
        <h3 class="font-headline-lg text-[40px] leading-[48px] font-semibold text-primary mb-2">Quản lý đơn hàng</h3>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-xl">Kiểm soát và quản lý hành trình của các sản phẩm từ WearWhatever đến tay khách hàng.</p>
    </div>
    <div class="flex items-center gap-3">

        <form method="get" class="flex items-center gap-2">
            <input type="hidden" name="status" value="@Model.StatusFilter" />
            
            <select name="day" class="pl-3 pr-8 py-2 border border-outline-variant rounded font-body-sm text-body-sm bg-transparent focus:outline-none focus:border-primary appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2349454F%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px_16px] bg-[right_8px_center] bg-no-repeat">
                <option value="">Ngày</option>
                @for (int d = 1; d <= 31; d++)
                {
                    if (Model.FilterDay == d) { <option value="@d" selected>@d</option> } else { <option value="@d">@d</option> }
                }
            </select>
            
            <select name="month" class="pl-3 pr-8 py-2 border border-outline-variant rounded font-body-sm text-body-sm bg-transparent focus:outline-none focus:border-primary appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2349454F%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px_16px] bg-[right_8px_center] bg-no-repeat">
                <option value="">Tháng</option>
                @for (int m = 1; m <= 12; m++)
                {
                    if (Model.FilterMonth == m) { <option value="@m" selected>Tháng @m</option> } else { <option value="@m">Tháng @m</option> }
                }
            </select>
            
            <select name="year" class="pl-3 pr-8 py-2 border border-outline-variant rounded font-body-sm text-body-sm bg-transparent focus:outline-none focus:border-primary appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2349454F%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:16px_16px] bg-[right_8px_center] bg-no-repeat">
                <option value="">Năm</option>
                @for (int y = DateTime.Now.Year - 4; y <= DateTime.Now.Year; y++)
                {
                    if (Model.FilterYear == y) { <option value="@y" selected>@y</option> } else { <option value="@y">@y</option> }
                }
            </select>

            <button type="submit" class="p-2 border border-outline-variant rounded hover:bg-surface-container transition-all text-primary bg-surface-container-low" title="Lọc">
                <span class="material-symbols-outlined text-[18px]">filter_alt</span>
            </button>
            <a href="?status=@Model.StatusFilter" class="p-2 border border-outline-variant rounded hover:bg-surface-container transition-all text-on-surface-variant" title="Xóa bộ lọc">
                <span class="material-symbols-outlined text-[18px]">clear</span>
            </a>
        </form>
        
        <a asp-action="ExportCsv" class="bg-primary text-on-primary px-6 py-2 font-label-caps text-label-caps rounded flex items-center gap-2 hover:opacity-90 transition-all active:scale-95">
            <span class="material-symbols-outlined text-[18px]">download</span>
            Xuất CSV
        </a>
    </div>
</div>

<!-- Tabbed Interface -->
<div class="mb-8 border-b border-outline-variant flex items-center justify-between">
    <div class="flex gap-8">
        <a href="?status=&day=@Model.FilterDay&month=@Model.FilterMonth&year=@Model.FilterYear" class="pb-4 font-label-caps text-label-caps transition-all px-1 @(string.IsNullOrEmpty(Model.StatusFilter) ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">Tất cả</a>
        <a href="?status=Pending&day=@Model.FilterDay&month=@Model.FilterMonth&year=@Model.FilterYear" class="pb-4 font-label-caps text-label-caps transition-all px-1 @(Model.StatusFilter == "Pending" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">Chờ xác nhận</a>
        <a href="?status=Processing&day=@Model.FilterDay&month=@Model.FilterMonth&year=@Model.FilterYear" class="pb-4 font-label-caps text-label-caps transition-all px-1 @(Model.StatusFilter == "Processing" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">Đang xử lý</a>
        <a href="?status=Shipping&day=@Model.FilterDay&month=@Model.FilterMonth&year=@Model.FilterYear" class="pb-4 font-label-caps text-label-caps transition-all px-1 @(Model.StatusFilter == "Shipping" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">Đang giao</a>
        <a href="?status=Delivered&day=@Model.FilterDay&month=@Model.FilterMonth&year=@Model.FilterYear" class="pb-4 font-label-caps text-label-caps transition-all px-1 @(Model.StatusFilter == "Delivered" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">Đã giao</a>
        <a href="?status=Cancelled&day=@Model.FilterDay&month=@Model.FilterMonth&year=@Model.FilterYear" class="pb-4 font-label-caps text-label-caps transition-all px-1 @(Model.StatusFilter == "Cancelled" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">Đã hủy</a>
    </div>
    <div class="pb-4 text-on-surface-variant font-body-sm text-body-sm">
        Hiển thị @Model.TotalCount đơn hàng
    </div>
</div>

<!-- Modern Editorial Table Layout -->
<div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden border border-outline-variant/30">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[900px]">
            <thead>
                <tr class="bg-surface-container-low border-b border-outline-variant/50">
                    <th class="px-6 py-5 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest">Mã đơn hàng</th>
                    <th class="px-6 py-5 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest">Ngày đặt</th>
                    <th class="px-6 py-5 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest">Khách hàng</th>
                    <th class="px-6 py-5 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest">Tổng tiền</th>
                    <th class="px-6 py-5 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest text-center">Thanh toán</th>
                    <th class="px-6 py-5 font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest text-center">Trạng thái</th>
                    <th class="px-6 py-5"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/20">
                @if (Model.Orders.Any())
                {
                    foreach (var order in Model.Orders)
                    {
                        string paymentColor = order.PaymentStatus switch {
                            "Paid" => "bg-green-100 text-green-700",
                            "Unpaid" => "bg-surface-variant text-on-surface-variant",
                            "Refunded" => "bg-red-100 text-red-700",
                            "PartialRefund" => "bg-orange-100 text-orange-700",
                            _ => "bg-surface-variant text-on-surface-variant"
                        };

                        string statusColor = order.OrderStatus switch {
                            "Pending" => "bg-amber-100 text-amber-700",
                            "Confirmed" => "bg-blue-100 text-blue-700",
                            "Processing" => "bg-purple-100 text-purple-700",
                            "Shipping" => "bg-cyan-100 text-cyan-700",
                            "Delivered" => "bg-green-100 text-green-700",
                            "Cancelled" => "bg-red-100 text-red-700",
                            _ => "bg-surface-variant text-on-surface-variant"
                        };

                        string statusLabel = order.OrderStatus switch {
                            "Pending" => "CHỜ XÁC NHẬN",
                            "Confirmed" => "ĐÃ XÁC NHẬN",
                            "Processing" => "ĐANG XỬ LÝ",
                            "Shipping" => "ĐANG GIAO",
                            "Delivered" => "ĐĐÃ GIAO",
                            "Cancelled" => "ĐÃ HỦY",
                            _ => order.OrderStatus.ToUpper()
                        };

                        string paymentLabel = order.PaymentStatus switch {
                            "Paid" => "ĐÃ THANH TOÁN",
                            "Unpaid" => "CHƯA THANH TOÁN",
                            "Refunded" => "ĐÃ HOÀN TIỀN",
                            "PartialRefund" => "HOÀN 1 PHẦN",
                            _ => order.PaymentStatus.ToUpper()
                        };

                        string rankColor = order.MembershipRank.ToLower() switch {
                            "gold" => "bg-yellow-500 text-white",
                            "silver" => "bg-gray-400 text-white",
                            "platinum" => "bg-purple-600 text-white",
                            "khách vãng lai" => "hidden",
                            _ => "bg-blue-500 text-white"
                        };
                        
                        var initial = string.IsNullOrWhiteSpace(order.CustomerName) ? "A" : order.CustomerName.Substring(0, 1).ToUpper();

                        <tr class="hover:bg-surface-container/30 transition-colors group cursor-pointer" onclick="window.location.href='@Url.Action("Detail", "Orders", new { id = order.OrderID })'">
                            <td class="px-6 py-6 font-body-md text-body-md font-semibold text-primary">
                                @order.OrderCode
                            </td>
                            <td class="px-6 py-6 font-body-sm text-body-sm text-on-surface-variant">@order.OrderDate.ToString("dd/MM/yyyy")</td>
                            <td class="px-6 py-6">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-secondary-container flex items-center justify-center text-secondary font-semibold text-xs shrink-0">@initial</div>
                                    <div class="min-w-0">
                                        <div class="flex items-center gap-2">
                                            <p class="font-body-sm text-body-sm font-medium truncate">@order.CustomerName</p>
                                            <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold @rankColor shrink-0">@order.MembershipRank</span>
                                        </div>
                                        <p class="font-body-sm text-[12px] text-on-surface-variant opacity-70 truncate">@order.OrderEmail</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-6 font-body-md text-body-md text-primary font-medium">@order.FinalAmount.ToString("N0")đ</td>
                            <td class="px-6 py-6 text-center">
                                <span class="inline-block px-3 py-1 rounded-full @paymentColor font-label-caps text-[10px]">@paymentLabel</span>
                            </td>
                            <td class="px-6 py-6 text-center">
                                <span class="inline-block px-3 py-1 rounded-full @statusColor font-label-caps text-[10px]">@statusLabel</span>
                            </td>
                            <td class="px-6 py-6 text-right">
                                <a href="@Url.Action("Detail", "Orders", new { id = order.OrderID })" class="p-2 hover:bg-surface-container rounded-full transition-colors opacity-0 group-hover:opacity-100 text-on-surface-variant inline-block">
                                    <span class="material-symbols-outlined text-[20px]">arrow_forward_ios</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-on-surface-variant font-body-md">
                            Không tìm thấy đơn hàng nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="bg-surface-container-low px-6 py-4 flex items-center justify-between">
            <div class="font-body-sm text-body-sm text-on-surface-variant">
                Trang @Model.Page / @Model.TotalPages
            </div>
            <div class="flex items-center gap-2">
                <a href="@(Model.Page > 1 ? $"?page={Model.Page - 1}&status={Model.StatusFilter}&day={Model.FilterDay}&month={Model.FilterMonth}&year={Model.FilterYear}" : "javascript:void(0)")" 
                   class="p-2 border border-outline-variant rounded transition-all @(Model.Page > 1 ? "hover:bg-surface" : "opacity-30 cursor-not-allowed") text-on-surface-variant">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </a>
                
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <a href="?page=@p&status=@Model.StatusFilter&day=@Model.FilterDay&month=@Model.FilterMonth&year=@Model.FilterYear" 
                       class="px-3 py-1 font-label-caps text-label-caps border rounded transition-all @(p == Model.Page ? "border-primary bg-primary text-on-primary" : "border-outline-variant hover:border-primary text-on-surface-variant")">
                       @p
                    </a>
                }
                
                <a href="@(Model.Page < Model.TotalPages ? $"?page={Model.Page + 1}&status={Model.StatusFilter}&day={Model.FilterDay}&month={Model.FilterMonth}&year={Model.FilterYear}" : "javascript:void(0)")" 
                   class="p-2 border border-outline-variant rounded transition-all @(Model.Page < Model.TotalPages ? "hover:bg-surface" : "opacity-30 cursor-not-allowed") text-on-surface-variant">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </a>
            </div>
        </div>
    }
</div>

<!-- Asymmetric Editorial Stats (Bottom Grid) -->
<div class="mt-[120px] grid grid-cols-1 md:grid-cols-12 gap-6 pb-12">
    <div class="md:col-span-5 bg-primary-container p-8 rounded-xl text-on-primary-container flex flex-col justify-between">
        <div>
            <h4 class="font-headline-md text-[28px] leading-[36px] font-medium mb-2">Thống kê</h4>
            <p class="font-body-md text-body-md opacity-80">Cập nhật theo thời gian thực về tình trạng đơn hàng.</p>
        </div>
        <div class="mt-8">
            <span class="font-display-lg text-[64px] leading-[72px] font-bold">@Model.ShippingOrders.ToString("N0")</span>
            <p class="font-label-caps text-label-caps mt-2">Đơn đang giao</p>
        </div>
    </div>
    <div class="md:col-span-7 grid grid-cols-2 gap-6">
        <div class="bg-secondary-container p-8 rounded-xl flex flex-col justify-center text-on-secondary-container">
            <span class="font-headline-lg text-[40px] leading-[48px] font-semibold">@Model.CompletionRate%</span>
            <p class="font-label-caps text-label-caps">Tỉ lệ giao thành công</p>
        </div>
        <div class="bg-tertiary-fixed p-8 rounded-xl flex flex-col justify-center text-on-tertiary-fixed-variant border border-outline-variant/30">
            <span class="font-headline-lg text-[40px] leading-[48px] font-semibold">@Model.TotalProductsSold.ToString("N0")</span>
            <p class="font-label-caps text-label-caps">Sản phẩm đã bán</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Simple Micro-interactions for table rows
        document.querySelectorAll('tbody tr.group').forEach(row => {
            row.addEventListener('click', (e) => {
                if(e.target.tagName !== 'A' && e.target.parentElement.tagName !== 'A') {
                    const link = row.querySelector('a');
                    if(link) window.location.href = link.href;
                }
            });
        });
    </script>
}
