<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>@ViewData["Title"] - WearWhatever Admin</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "outline": "#82746d", "on-tertiary-fixed": "#1b1c19",
                        "on-background": "#1b1c1c", "on-secondary-fixed-variant": "#3c4b34",
                        "surface-dim": "#dcd9d9", "secondary-fixed": "#d6e8c9",
                        "surface-container": "#f0eded", "surface-tint": "#79573f",
                        "tertiary-fixed": "#e4e2dd", "surface-container-high": "#eae8e7",
                        "secondary-fixed-dim": "#bbccae", "on-tertiary": "#ffffff",
                        "outline-variant": "#d4c3ba", "error-container": "#ffdad6",
                        "primary-fixed-dim": "#eabda0", "inverse-surface": "#303030",
                        "on-secondary-container": "#596950", "error": "#ba1a1a",
                        "on-secondary": "#ffffff", "on-tertiary-container": "#cbcac5",
                        "on-primary": "#ffffff", "secondary": "#53634a",
                        "inverse-primary": "#eabda0", "on-primary-fixed": "#2d1604",
                        "on-secondary-fixed": "#121f0c", "tertiary-fixed-dim": "#c8c6c2",
                        "surface-container-highest": "#e4e2e1", "secondary-container": "#d6e8c9",
                        "tertiary": "#3e3e3b", "surface-container-lowest": "#ffffff",
                        "surface-variant": "#e4e2e1", "primary-fixed": "#ffdcc6",
                        "primary-container": "#6f4e37", "on-surface": "#1b1c1c",
                        "tertiary-container": "#555552", "on-error": "#ffffff",
                        "on-tertiary-fixed-variant": "#474744", "inverse-on-surface": "#f3f0f0",
                        "primary": "#553722", "background": "#fbf9f8",
                        "surface-bright": "#fbf9f8", "on-surface-variant": "#50453e",
                        "on-primary-fixed-variant": "#5f402a", "on-primary-container": "#eec1a4",
                        "surface": "#fbf9f8", "on-error-container": "#93000a",
                        "surface-container-low": "#f6f3f2"
                    },
                    "fontFamily": {
                        "body-lg": ["Inter"],
                        "display-lg": ["Kanit"],
                        "label-caps": ["Inter"],
                        "headline-lg-mobile": ["Kanit"],
                        "display-lg-mobile": ["Kanit"],
                        "body-sm": ["Inter"],
                        "body-md": ["Inter"],
                        "headline-md": ["Kanit"],
                        "headline-lg": ["Kanit"],
                        "sans": ["Inter", "sans-serif"]
                    },
                    "fontSize": {
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                        "display-lg": ["64px", {"lineHeight": "72px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "label-caps": ["12px", {"lineHeight": "16px", "letterSpacing": "0.1em", "fontWeight": "600"}],
                        "headline-lg-mobile": ["32px", {"lineHeight": "40px", "fontWeight": "600"}],
                        "display-lg-mobile": ["40px", {"lineHeight": "48px", "letterSpacing": "-0.01em", "fontWeight": "700"}],
                        "body-sm": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "headline-md": ["28px", {"lineHeight": "36px", "fontWeight": "500"}],
                        "headline-lg": ["40px", {"lineHeight": "48px", "fontWeight": "600"}]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-family: 'Material Symbols Outlined' !important;
            font-weight: normal; font-style: normal; font-size: 22px;
            line-height: 1; letter-spacing: normal; text-transform: none;
            display: inline-block; white-space: nowrap; word-wrap: normal;
            direction: ltr; -webkit-font-smoothing: antialiased;
        }
        body { font-family: 'Inter', sans-serif; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background text-on-background min-h-screen">

    <!-- Sidebar -->
    <nav class="bg-background text-primary h-screen w-64 fixed left-0 top-0 border-r border-outline-variant flex flex-col py-8 px-6 z-50">
        <div class="mb-10">
            <h1 class="text-xl font-bold text-primary tracking-tight">WearWhatever</h1>
            <p class="text-xs text-on-surface-variant mt-0.5">Editorial Admin</p>
        </div>
        <ul class="flex flex-col gap-1 flex-grow">
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
            }
            @if (Context.HasPermission("Dashboard.View"))
            {
            <li>
                <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200 @(ctrl == "Dashboard" ? "bg-surface-container-high text-primary font-semibold" : "text-on-surface-variant hover:bg-surface-container-high")"
                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: '@(ctrl == "Dashboard" ? "FILL" : "FILL") 1';">dashboard</span>
                    Dashboard
                </a>
            </li>
            }

            @if (Context.HasPermission("Product.View") || Context.HasPermission("Category.Manage") || Context.HasPermission("Order.View") || Context.HasPermission("Review.Manage"))
            {
            <li class="pt-2 pb-1 mt-2">
                <span class="px-4 text-xs font-semibold text-outline uppercase tracking-wider">Bán hàng</span>
            </li>
            }

            @if (Context.HasPermission("Product.View"))
            {
            <li>
                <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200 @(ctrl == "Products" ? "bg-surface-container-high text-primary font-semibold" : "text-on-surface-variant hover:bg-surface-container-high")"
                   asp-area="Admin" asp-controller="Products" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">inventory_2</span>
                    Sản phẩm
                </a>
            </li>
            }
            @if (Context.HasPermission("Category.Manage"))
            {
            <li>
                <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200 @(ctrl == "Categories" ? "bg-surface-container-high text-primary font-semibold" : "text-on-surface-variant hover:bg-surface-container-high")"
                   asp-area="Admin" asp-controller="Categories" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">category</span>
                    Danh mục
                </a>
            </li>
            }
            @if (Context.HasPermission("Order.View"))
            {
            <li>
                <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200 @(ctrl == "Orders" ? "bg-surface-container-high text-primary font-semibold" : "text-on-surface-variant hover:bg-surface-container-high")"
                   asp-area="Admin" asp-controller="Orders" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">shopping_bag</span>
                    Đơn hàng
                </a>
            </li>
            }
            @if (Context.HasPermission("Review.Manage"))
            {
            <li>
                <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200 @(ctrl == "Reviews" ? "bg-surface-container-high text-primary font-semibold" : "text-on-surface-variant hover:bg-surface-container-high")"
                   asp-area="Admin" asp-controller="Reviews" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">reviews</span>
                    Đánh giá
                </a>
            </li>
            }

            @if (Context.HasPermission("Coupon.Manage"))
            {
            <li class="pt-2 pb-1 mt-2">
                <span class="px-4 text-xs font-semibold text-outline uppercase tracking-wider">Khuyến mãi</span>
            </li>
            <li>
                <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200 @(ctrl == "Coupons" ? "bg-surface-container-high text-primary font-semibold" : "text-on-surface-variant hover:bg-surface-container-high")"
                   asp-area="Admin" asp-controller="Coupons" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">local_offer</span>
                    Mã giảm giá
                </a>
            </li>
            <li>
                <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200 @(ctrl == "DiscountPrograms" ? "bg-surface-container-high text-primary font-semibold" : "text-on-surface-variant hover:bg-surface-container-high")"
                   asp-area="Admin" asp-controller="DiscountPrograms" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">sell</span>
                    Chương trình giảm giá
                </a>
            </li>
            }

            @if (User.IsInRole("Admin") || Context.HasPermission("Account.Manage"))
            {
            <li class="pt-2 pb-1 mt-2">
                <span class="px-4 text-xs font-semibold text-outline uppercase tracking-wider">Hệ thống</span>
            </li>
            <li>
                <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200 @(ctrl == "Accounts" ? "bg-surface-container-high text-primary font-semibold" : "text-on-surface-variant hover:bg-surface-container-high")"
                   asp-area="Admin" asp-controller="Accounts" asp-action="Index">
                    <span class="material-symbols-outlined text-[20px]">manage_accounts</span>
                    Tài khoản nội bộ
                </a>
            </li>
            }
        </ul>
        <div class="mt-auto border-t border-outline-variant pt-6">
            <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm text-on-surface-variant hover:bg-surface-container-high transition-colors"
               asp-area="" asp-controller="Home" asp-action="Index">
                <span class="material-symbols-outlined text-[20px]">storefront</span>
                Xem cửa hàng
            </a>
            <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm text-on-surface-variant hover:bg-surface-container-high transition-colors"
               asp-area="" asp-controller="Account" asp-action="Logout">
                <span class="material-symbols-outlined text-[20px]">logout</span>
                Đăng xuất
            </a>
        </div>
    </nav>

    <!-- Top Bar -->
    <header class="bg-background/90 backdrop-blur-md fixed top-0 right-0 w-[calc(100%-16rem)] z-40 border-b border-outline-variant flex justify-between items-center h-14 px-8">
        <div class="relative w-64">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">search</span>
            <input class="w-full bg-surface-container-low border border-outline-variant rounded-full py-1.5 pl-9 pr-4 focus:outline-none focus:border-primary text-sm placeholder:text-outline"
                   placeholder="Tìm kiếm..." type="text"/>
        </div>
        <div class="flex items-center gap-4">
            @if (TempData["Success"] is string)
            {
                <span class="text-xs bg-green-100 text-green-700 px-3 py-1 rounded-full">✓ @TempData["Success"]</span>
            }
            @if (TempData["Error"] is string)
            {
                <span class="text-xs bg-red-100 text-red-700 px-3 py-1 rounded-full">⚠ @TempData["Error"]</span>
            }
            <button class="text-on-surface-variant hover:text-primary transition-colors relative">
                <span class="material-symbols-outlined text-[22px]">notifications</span>
                <span class="absolute top-0 right-0 w-2 h-2 bg-error rounded-full"></span>
            </button>
            <div class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container text-xs font-bold">
                A
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="ml-64 pt-14 min-h-screen">
        <div class="px-8 py-8">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
